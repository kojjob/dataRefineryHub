<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= @organization.name %> - Multi-Format Report</title>
  <style>
    body {
      font-family: Arial, sans-serif;
      line-height: 1.6;
      color: #333;
      max-width: 600px;
      margin: 0 auto;
      padding: 20px;
    }
    .header {
      background: #f8f9fa;
      padding: 20px;
      border-radius: 8px;
      margin-bottom: 20px;
      text-align: center;
    }
    .content {
      padding: 20px 0;
    }
    .report-summary {
      background: #f9f9f9;
      padding: 15px;
      border-left: 4px solid #007bff;
      margin: 20px 0;
    }
    .attachments-info {
      background: #e8f5e8;
      border: 1px solid #c3e6c3;
      border-radius: 4px;
      padding: 15px;
      margin: 20px 0;
    }
    .footer {
      margin-top: 40px;
      padding-top: 20px;
      border-top: 1px solid #eee;
      font-size: 14px;
      color: #666;
    }
  </style>
</head>
<body>
  <div class="header">
    <h1><%= @organization.name %></h1>
    <p><%= @report_type.humanize %> Report</p>
  </div>

  <div class="content">
    <p>Hello <%= @user.first_name || @user.email %>,</p>
    
    <div class="report-summary">
      <h3>Report Summary</h3>
      <p><strong>Report Type:</strong> <%= @report_type.humanize %></p>
      <p><strong>Generated:</strong> <%= Time.current.strftime('%B %d, %Y at %I:%M %p %Z') %></p>
      
      <% if @report_data.is_a?(Hash) %>
        <% @report_data.each do |key, value| %>
          <p><strong><%= key.to_s.humanize %>:</strong> 
          <% if value.is_a?(Hash) %>
            <%= value.map { |k, v| "#{k.to_s.humanize}: #{v}" }.join(', ') %>
          <% else %>
            <%= value %>
          <% end %>
          </p>
        <% end %>
      <% end %>
    </div>
    
    <div class="attachments-info">
      <h3>📎 Report Attachments</h3>
      <p>This email includes your report data in multiple formats for your convenience:</p>
      <ul>
        <li><strong>PDF Format:</strong> Professional formatted report suitable for sharing and printing</li>
        <li><strong>CSV Format:</strong> Raw data that can be imported into spreadsheet applications</li>
      </ul>
      <p>All attached files have been securely validated and are safe to download.</p>
    </div>
  </div>

  <div class="footer">
    <p>This multi-format report was automatically generated by the Data Refinery Platform.</p>
    <p>If you have any questions about the report data or attachments, please contact your system administrator.</p>
    
    <hr>
    <p style="font-size: 12px; color: #999;">
      <%= @organization.name %> | Data Refinery Platform<br>
      You received this email because you are subscribed to <%= @report_type.humanize.downcase %> reports from this organization.
    </p>
  </div>
</body>
</html>