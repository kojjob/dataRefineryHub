<%= @organization.name %> - <%= @report_type.humanize %> Report
<%= "=" * (@organization.name.length + @report_type.humanize.length + 12) %>

Hello <%= @user.first_name || @user.email %>,

Here is your <%= @report_type.humanize.downcase %> report generated on <%= @generated_at.strftime('%B %d, %Y at %I:%M %p %Z') %>.

<% if @report_data.is_a?(Hash) %>
<% @report_data.each do |section, data| %>
<%= section.to_s.humanize.upcase %>
<%= "-" * section.to_s.humanize.length %>

<% if data.is_a?(Hash) %>
<% data.each do |key, value| %>
<%= key.to_s.humanize %>: <%= value %>
<% end %>
<% elsif data.is_a?(Array) %>
<% data.each_with_index do |item, index| %>
<%= index + 1 %>. <%= item %>
<% end %>
<% else %>
<%= data %>
<% end %>

<% end %>
<% else %>
<%= @report_data %>
<% end %>

---
This report was automatically generated by the Data Refinery Platform.
If you have any questions about this report, please contact your system administrator.

<%= @organization.name %> | Data Refinery Platform
You received this email because you are subscribed to reports from this organization.