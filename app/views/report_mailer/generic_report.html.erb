<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= @organization.name %> - <%= @report_type.humanize %> Report</title>
  <style>
    body {
      font-family: Arial, sans-serif;
      line-height: 1.6;
      color: #333;
      max-width: 600px;
      margin: 0 auto;
      padding: 20px;
    }
    .header {
      background: #f8f9fa;
      padding: 20px;
      border-radius: 8px;
      margin-bottom: 20px;
      text-align: center;
    }
    .content {
      padding: 20px 0;
    }
    .data-section {
      background: #f9f9f9;
      padding: 15px;
      margin: 15px 0;
      border-radius: 4px;
      border-left: 4px solid #007bff;
    }
    .footer {
      margin-top: 40px;
      padding-top: 20px;
      border-top: 1px solid #eee;
      font-size: 14px;
      color: #666;
    }
  </style>
</head>
<body>
  <div class="header">
    <h1><%= @organization.name %></h1>
    <p><%= @report_type.humanize %> Report</p>
  </div>

  <div class="content">
    <p>Hello <%= @user.first_name || @user.email %>,</p>
    
    <p>Here is your <%= @report_type.humanize.downcase %> report generated on <%= @generated_at.strftime('%B %d, %Y at %I:%M %p %Z') %>.</p>
    
    <% if @report_data.is_a?(Hash) %>
      <% @report_data.each do |section, data| %>
        <div class="data-section">
          <h3><%= section.to_s.humanize %></h3>
          <% if data.is_a?(Hash) %>
            <% data.each do |key, value| %>
              <p><strong><%= key.to_s.humanize %>:</strong> <%= value %></p>
            <% end %>
          <% elsif data.is_a?(Array) %>
            <ul>
              <% data.each do |item| %>
                <li><%= item %></li>
              <% end %>
            </ul>
          <% else %>
            <p><%= data %></p>
          <% end %>
        </div>
      <% end %>
    <% else %>
      <div class="data-section">
        <p><%= @report_data %></p>
      </div>
    <% end %>
  </div>

  <div class="footer">
    <p>This report was automatically generated by the Data Refinery Platform.</p>
    <p>If you have any questions about this report, please contact your system administrator.</p>
    
    <hr>
    <p style="font-size: 12px; color: #999;">
      <%= @organization.name %> | Data Refinery Platform<br>
      You received this email because you are subscribed to reports from this organization.
    </p>
  </div>
</body>
</html>