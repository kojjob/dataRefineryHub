<div class="min-h-screen bg-gray-50">
  <!-- Header -->
  <div class="bg-white shadow-sm border-b border-gray-200">
    <div class="px-4 sm:px-6 lg:px-8 py-6">
      <div class="flex items-center justify-between">
        <div class="flex items-center">
          <%= link_to pipeline_monitoring_index_path, class: "mr-4 text-gray-500 hover:text-gray-700" do %>
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
            </svg>
          <% end %>
          <div>
            <h1 class="text-2xl font-bold text-gray-900"><%= @execution.pipeline_name %></h1>
            <div class="mt-1 flex items-center text-sm text-gray-500">
              <span>Execution ID: <%= @execution.execution_id %></span>
              <span class="mx-2">•</span>
              <span>Started <%= time_ago_in_words(@execution.started_at) %> ago</span>
              <% if @execution.user %>
                <span class="mx-2">•</span>
                <span>by <%= @execution.user.full_name %></span>
              <% end %>
            </div>
          </div>
        </div>
        <div class="flex items-center space-x-3">
          <% case @execution.status %>
          <% when 'running' %>
            <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-blue-100 text-blue-800">
              <span class="mr-2 flex h-2 w-2 relative">
                <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-blue-400 opacity-75"></span>
                <span class="relative inline-flex rounded-full h-2 w-2 bg-blue-500"></span>
              </span>
              Running
            </span>
          <% when 'completed' %>
            <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-green-100 text-green-800">
              <svg class="mr-2 h-4 w-4" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
              </svg>
              Completed
            </span>
          <% when 'failed' %>
            <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-red-100 text-red-800">
              <svg class="mr-2 h-4 w-4" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" />
              </svg>
              Failed
            </span>
          <% else %>
            <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-gray-100 text-gray-800">
              <%= @execution.status.humanize %>
            </span>
          <% end %>
          
          <% if @execution.status == 'running' %>
            <button type="button" class="inline-flex items-center px-3 py-2 border border-red-300 shadow-sm text-sm leading-4 font-medium rounded-md text-red-700 bg-white hover:bg-red-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500">
              <svg class="h-4 w-4 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 10a1 1 0 011-1h4a1 1 0 011 1v4a1 1 0 01-1 1h-4a1 1 0 01-1-1v-4z" />
              </svg>
              Stop Execution
            </button>
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <!-- Progress Overview -->
  <div class="px-4 sm:px-6 lg:px-8 py-6">
    <div class="bg-white shadow rounded-lg">
      <div class="px-4 py-5 sm:p-6">
        <h3 class="text-lg leading-6 font-medium text-gray-900 mb-4">Execution Progress</h3>
        
        <!-- Overall Progress -->
        <div class="mb-6">
          <div class="flex items-center justify-between mb-2">
            <span class="text-sm font-medium text-gray-700">Overall Progress</span>
            <span class="text-sm font-medium text-gray-900"><%= @execution.progress.to_i %>%</span>
          </div>
          <div class="overflow-hidden h-3 text-xs flex rounded bg-gray-200">
            <div style="width: <%= @execution.progress %>%" class="shadow-none flex flex-col text-center whitespace-nowrap text-white justify-center bg-indigo-600 transition-all duration-500"></div>
          </div>
        </div>

        <!-- Stage Progress -->
        <div class="grid grid-cols-3 gap-4">
          <% ['extraction', 'transformation', 'loading'].each do |stage| %>
            <div class="text-center">
              <div class="relative">
                <% is_current = @execution.current_stage == stage %>
                <% is_completed = ['transformation', 'loading'].include?(stage) && @execution.current_stage == 'loading' %>
                
                <div class="<%= is_completed ? 'bg-green-100 border-green-300' : is_current ? 'bg-blue-100 border-blue-300' : 'bg-gray-100 border-gray-300' %> rounded-lg border-2 p-4 transition-colors duration-300">
                  <% if is_completed %>
                    <svg class="mx-auto h-8 w-8 text-green-600" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                    </svg>
                  <% elsif is_current %>
                    <div class="mx-auto h-8 w-8 flex items-center justify-center">
                      <span class="flex h-6 w-6 relative">
                        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-blue-400 opacity-75"></span>
                        <span class="relative inline-flex rounded-full h-6 w-6 bg-blue-500"></span>
                      </span>
                    </div>
                  <% else %>
                    <div class="mx-auto h-8 w-8 rounded-full bg-gray-300"></div>
                  <% end %>
                  
                  <h4 class="mt-2 text-sm font-medium <%= is_completed ? 'text-green-900' : is_current ? 'text-blue-900' : 'text-gray-900' %>">
                    <%= stage.capitalize %>
                  </h4>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <!-- Execution Details -->
  <div class="px-4 sm:px-6 lg:px-8 pb-6">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
      <!-- Tasks -->
      <div class="bg-white shadow rounded-lg">
        <div class="px-4 py-5 sm:px-6 border-b border-gray-200">
          <h3 class="text-lg leading-6 font-medium text-gray-900">Tasks</h3>
        </div>
        <div class="divide-y divide-gray-200">
          <% @tasks.each do |task| %>
            <div class="px-4 py-3">
              <div class="flex items-center justify-between">
                <div class="flex-1">
                  <p class="text-sm font-medium text-gray-900"><%= task.name %></p>
                  <p class="text-xs text-gray-500"><%= task.task_type.humanize %></p>
                </div>
                <div class="flex items-center space-x-2">
                  <% case task.status %>
                  <% when 'completed' %>
                    <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-green-100 text-green-800">
                      <svg class="mr-1 h-3 w-3" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                      </svg>
                      Done
                    </span>
                  <% when 'running' %>
                    <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-blue-100 text-blue-800">
                      <svg class="mr-1 h-3 w-3 animate-spin" fill="none" viewBox="0 0 24 24">
                        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                      </svg>
                      Running
                    </span>
                  <% when 'failed' %>
                    <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-red-100 text-red-800">
                      Failed
                    </span>
                  <% else %>
                    <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-gray-100 text-gray-800">
                      <%= task.status.humanize %>
                    </span>
                  <% end %>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      </div>

      <!-- Metrics -->
      <div class="bg-white shadow rounded-lg">
        <div class="px-4 py-5 sm:px-6 border-b border-gray-200">
          <h3 class="text-lg leading-6 font-medium text-gray-900">Performance Metrics</h3>
        </div>
        <div class="px-4 py-5 sm:p-6">
          <dl class="grid grid-cols-1 gap-x-4 gap-y-6 sm:grid-cols-2">
            <div>
              <dt class="text-sm font-medium text-gray-500">Duration</dt>
              <dd class="mt-1 text-sm text-gray-900">
                <% if @execution.completed_at %>
                  <%= distance_of_time_in_words(@execution.started_at, @execution.completed_at) %>
                <% else %>
                  <%= distance_of_time_in_words(@execution.started_at, Time.current) %> (ongoing)
                <% end %>
              </dd>
            </div>
            
            <div>
              <dt class="text-sm font-medium text-gray-500">Records Processed</dt>
              <dd class="mt-1 text-sm text-gray-900">
                <%= number_with_delimiter(@execution.result_summary&.dig('rows_loaded') || 0) %>
              </dd>
            </div>
            
            <div>
              <dt class="text-sm font-medium text-gray-500">Processing Rate</dt>
              <dd class="mt-1 text-sm text-gray-900">
                <% if @performance_metrics[:records_per_second] %>
                  <%= number_with_delimiter(@performance_metrics[:records_per_second].round(2)) %> rec/s
                <% else %>
                  N/A
                <% end %>
              </dd>
            </div>
            
            <div>
              <dt class="text-sm font-medium text-gray-500">Execution Mode</dt>
              <dd class="mt-1 text-sm text-gray-900">
                <%= @execution.execution_mode.humanize %>
              </dd>
            </div>
          </dl>
        </div>
      </div>
    </div>
  </div>

  <!-- Logs -->
  <div class="px-4 sm:px-6 lg:px-8 pb-8">
    <div class="bg-white shadow rounded-lg">
      <div class="px-4 py-5 sm:px-6 border-b border-gray-200">
        <h3 class="text-lg leading-6 font-medium text-gray-900">Execution Logs</h3>
      </div>
      <div class="px-4 py-4 sm:px-6 max-h-96 overflow-y-auto">
        <div class="space-y-2 font-mono text-xs">
          <% @execution_logs.each do |log| %>
            <div class="flex">
              <span class="text-gray-500 mr-3"><%= log[:timestamp].strftime('%H:%M:%S.%L') %></span>
              <span class="<%= log[:level] == 'error' ? 'text-red-600' : 'text-gray-900' %>">
                [<%= log[:level].upcase %>] <%= log[:message] %>
              </span>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Auto-refresh for running executions -->
<% if @execution.status == 'running' %>
  <%= turbo_stream_from "pipeline_execution_#{@execution.id}" %>
<% end %>