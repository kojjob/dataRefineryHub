<li>
  <%= link_to path, class: "group flex gap-x-3 rounded-xl p-3 text-sm leading-6 font-medium text-gray-700 hover:text-gray-900 hover:bg-gray-50", "data-action": "click->mobile-menu#close" do %>
    <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-lg bg-gradient-to-br <%= icon_gradient %> text-white">
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="<%= icon_path %>" />
      </svg>
    </div>
    <div>
      <div class="font-semibold"><%= title %></div>
      <div class="text-xs text-gray-500"><%= subtitle %></div>
    </div>
  <% end %>
</li>