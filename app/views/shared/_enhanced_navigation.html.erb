            <h3 class="text-sm font-semibold text-gray-900 mb-3">Quick Actions</h3>
            <div class="space-y-2">
              <%= link_to new_data_source_path, class: "flex items-center gap-3 p-2 text-sm text-gray-700 hover:text-blue-600 hover:bg-blue-50 rounded-lg transition-all duration-200" do %>
                <div class="h-6 w-6 rounded-lg bg-blue-100 flex items-center justify-center">
                  <svg class="h-3 w-3 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
                  </svg>
                </div>
                Add Data Source
              <% end %>
              <%= link_to analytics_path, class: "flex items-center gap-3 p-2 text-sm text-gray-700 hover:text-emerald-600 hover:bg-emerald-50 rounded-lg transition-all duration-200" do %>
                <div class="h-6 w-6 rounded-lg bg-emerald-100 flex items-center justify-center">
                  <svg class="h-3 w-3 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
                  </svg>
                </div>
                View Analytics
              <% end %>
            </div>
          </div>
        </li>

        <!-- Bottom Section - Organization Switcher -->
        <li class="mt-auto">
          <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-3 mx-2 hover:shadow-md transition-all duration-200">
            <div class="flex items-center gap-3">
              <div class="relative">
                <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-gradient-to-br from-gray-100 to-gray-200 text-sm font-bold text-gray-700 border-2 border-white shadow-sm">
                  <% if current_user&.organization&.name.present? %>
                    <%= current_user.organization.name.first.upcase %>
                  <% else %>
                    D
                  <% end %>
                </div>
                <div class="absolute -bottom-1 -right-1 h-3 w-3 bg-blue-500 rounded-full border-2 border-white"></div>
              </div>
              <div class="flex-1 lg:hidden xl:block">
                <div class="text-sm font-semibold text-gray-900 truncate">
                  <%= current_user&.organization&.name || "DataReflow" %>
                </div>
                <div class="text-xs text-gray-500">
                  <%= current_user&.role&.humanize || 'Member' %> • <%= current_organization&.users&.count || 0 %> members
                </div>
              </div>
              <svg class="h-4 w-4 shrink-0 text-gray-400 lg:hidden xl:inline" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z" clip-rule="evenodd" />
              </svg>
            </div>
          </div>
        </li>
      </ul>
    </nav>
  </div>
</div>