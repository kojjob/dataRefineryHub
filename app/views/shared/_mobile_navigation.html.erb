<div class="flex grow flex-col gap-y-5 overflow-y-auto bg-white border-r border-gray-200 px-6 pb-4">
  <!-- Mobile Logo -->
  <div class="flex h-16 shrink-0 items-center">
    <%= link_to dashboard_path, class: "flex items-center space-x-3" do %>
      <div class="flex h-10 w-10 items-center justify-center rounded-2xl bg-gradient-to-r from-purple-600 to-blue-600 shadow-lg">
        <svg class="h-6 w-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
        </svg>
      </div>
      <span class="text-xl font-bold text-gray-900">DataReflow</span>
    <% end %>
  </div>
  
  <!-- Enhanced Mobile Navigation -->
  <nav class="flex flex-1 flex-col">
    <ul role="list" class="flex flex-1 flex-col gap-y-6">
      <!-- Main Section -->
      <li>
        <div class="text-xs font-semibold leading-6 text-gray-400 mb-3">OVERVIEW</div>
        <ul role="list" class="-mx-2 space-y-2">
          <%= render 'shared/mobile_nav_item', 
                     path: dashboard_path, 
                     icon_gradient: 'from-blue-500 to-blue-600',
                     icon_path: 'M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25',
                     title: 'Dashboard',
                     subtitle: 'Overview & metrics' %>
          
          <%= render 'shared/mobile_nav_item', 
                     path: analytics_path, 
                     icon_gradient: 'from-emerald-500 to-green-600',
                     icon_path: 'M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z',
                     title: 'Analytics',
                     subtitle: 'Deep insights' %>
          
          <%= render 'shared/mobile_nav_item', 
                     path: data_sources_path, 
                     icon_gradient: 'from-purple-500 to-purple-600',
                     icon_path: 'M20.25 6.375c0 2.278-3.694 4.125-8.25 4.125S3.75 8.653 3.75 6.375m16.5 0c0-2.278-3.694-4.125-8.25-4.125S3.75 4.097 3.75 6.375m16.5 0v11.25c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125V6.375m16.5 0v3.75m-16.5-3.75v3.75m16.5 0v3.75C20.25 18.653 16.556 20.5 12 20.5s-8.25-1.847-8.25-4.125v-3.75m16.5 0c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125',
                     title: 'Data Sources',
                     subtitle: 'Integrations' %>
        </ul>
      </li>

      <!-- E-commerce Section -->
      <li>
        <div class="text-xs font-semibold leading-6 text-gray-400 mb-3">E-COMMERCE</div>
        <ul role="list" class="-mx-2 space-y-2">
          <%= render 'shared/mobile_nav_item', 
                     path: '#orders', 
                     icon_gradient: 'from-orange-500 to-red-500',
                     icon_path: 'M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z',
                     title: 'Orders',
                     subtitle: 'Order management' %>
          
          <%= render 'shared/mobile_nav_item', 
                     path: '#customers', 
                     icon_gradient: 'from-cyan-500 to-blue-500',
                     icon_path: 'M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z',
                     title: 'Customers',
                     subtitle: 'Customer insights' %>
        </ul>
      </li>

      <!-- Management Section -->
      <li>
        <div class="text-xs font-semibold leading-6 text-gray-400 mb-3">MANAGEMENT</div>
        <ul role="list" class="-mx-2 space-y-2">
          <%= render 'shared/mobile_nav_item', 
                     path: users_path, 
                     icon_gradient: 'from-gray-500 to-gray-600',
                     icon_path: 'M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z',
                     title: 'Team',
                     subtitle: 'User management' %>
          
          <%= render 'shared/mobile_nav_item', 
                     path: organization_path, 
                     icon_gradient: 'from-slate-500 to-slate-600',
                     icon_path: 'M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.324.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 011.37.49l1.296 2.247a1.125 1.125 0 01-.26 1.431l-1.003.827c-.293.24-.438.613-.431.992a6.759 6.759 0 010 .255c-.007.378.138.75.43.99l1.005.828c.424.35.534.954.26 1.43l-1.298 2.247a1.125 1.125 0 01-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.57 6.57 0 01-.22.128c-.331.183-.581.495-.644.869l-.213 1.28c-.09.543-.56.941-1.11.941h-2.594c-.55 0-1.019-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 01-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 01-1.369-.49l-1.297-2.247a1.125 1.125 0 01.26-1.431l1.004-.827c.292-.24.437-.613.43-.992a6.932 6.932 0 010-.255c.007-.378-.138-.75-.43-.99l-1.004-.828a1.125 1.125 0 01-.26-1.43l1.297-2.247a1.125 1.125 0 011.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.087.22-.128.332-.183.582-.495.644-.869l.214-1.281z M15 12a3 3 0 11-6 0 3 3 0 016 0z',
                     title: 'Settings',
                     subtitle: 'Organization' %>
        </ul>
      </li>
    </ul>
  </nav>
</div>