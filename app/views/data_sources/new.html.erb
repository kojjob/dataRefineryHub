<script>
  // Dynamic configuration loading
  document.addEventListener('DOMContentLoaded', function() {
    const configSection = document.getElementById('configuration-section')
    const fileUploadSection = document.getElementById('file-upload-section')
    const apiPreviewSection = document.getElementById('api-preview-section')
    
    function loadConfiguration(sourceType) {
      const template = document.getElementById(`${sourceType}-config-template`)
      if (template && configSection) {
        configSection.innerHTML = template.innerHTML
      }
      
      // Show/hide appropriate preview sections
      if (sourceType === 'file_upload') {
        fileUploadSection?.classList.remove('hidden')
        apiPreviewSection?.classList.add('hidden')
      } else {
        fileUploadSection?.classList.add('hidden')
        apiPreviewSection?.classList.remove('hidden')
      }
      
      // Update connection tester source type
      const connectionTester = document.querySelector('[data-controller*="connection-tester"]')
      if (connectionTester) {
        connectionTester.setAttribute('data-connection-tester-source-type-value', sourceType)
      }
    }
    
    // Listen for source selection events
    document.addEventListener('source-selector:sourceSelected', function(event) {
      loadConfiguration(event.detail.sourceType)
    })
  })
</script>