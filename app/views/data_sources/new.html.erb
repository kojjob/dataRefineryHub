<% content_for :title, "Add New Data Source" %>
<% content_for :breadcrumb do %>
  <nav class="flex" aria-label="Breadcrumb">
    <ol class="inline-flex items-center space-x-1 md:space-x-3">
      <li class="inline-flex items-center">
        <%= link_to root_path, class: "inline-flex items-center text-sm font-medium text-gray-700 hover:text-blue-600" do %>
          <svg class="w-3 h-3 mr-2.5" fill="currentColor" viewBox="0 0 20 20">
            <path d="m19.707 9.293-2-2-7-7a1 1 0 0 0-1.414 0l-7 7-2 2a1 1 0 0 0 1.414 1.414L2 10.414V18a2 2 0 0 0 2 2h3a1 1 0 0 0 1-1v-4a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v4a1 1 0 0 0 1 1h3a2 2 0 0 0 2-2v-7.586l.293.293a1 1 0 0 0 1.414-1.414Z"/>
          </svg>
          Dashboard
        <% end %>
      </li>
      <li>
        <div class="flex items-center">
          <svg class="w-3 h-3 text-gray-400 mx-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
          </svg>
          <%= link_to data_sources_path, class: "ml-1 text-sm font-medium text-gray-700 hover:text-blue-600 md:ml-2" do %>
            Data Sources
          <% end %>
        </div>
      </li>
      <li aria-current="page">
        <div class="flex items-center">
          <svg class="w-3 h-3 text-gray-400 mx-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
          </svg>
          <span class="ml-1 text-sm font-medium text-gray-500 md:ml-2">Add New</span>
        </div>
      </li>
    </ol>
  </nav>
<% end %>

<%# Load data source configurations from DataSourceRegistry service %>
<% 
  # Get configurations from the centralized registry
  data_source_configs = DataSourceRegistry.configurations
  
  # Helper method to get UI styling based on category
  def get_ui_styling(category)
    case category.to_s
    when 'ecommerce'
      { icon_color: 'text-green-600', bg_color: 'bg-green-50', border_color: 'border-green-200' }
    when 'payment'
      { icon_color: 'text-indigo-600', bg_color: 'bg-indigo-50', border_color: 'border-indigo-200' }
    when 'accounting'
      { icon_color: 'text-blue-600', bg_color: 'bg-blue-50', border_color: 'border-blue-200' }
    when 'analytics'
      { icon_color: 'text-orange-500', bg_color: 'bg-orange-50', border_color: 'border-orange-200' }
    when 'file'
      { icon_color: 'text-gray-600', bg_color: 'bg-gray-50', border_color: 'border-gray-200' }
    when 'marketplace'
      { icon_color: 'text-orange-600', bg_color: 'bg-orange-50', border_color: 'border-orange-200' }
    else
      { icon_color: 'text-gray-600', bg_color: 'bg-gray-50', border_color: 'border-gray-200' }
    end
  end
  
  # Merge UI styling with configurations
  data_source_configs.each do |key, config|
    styling = get_ui_styling(config[:category])
    data_source_configs[key] = config.merge(styling)
  end
  
  # Sync frequency options
  sync_frequency_options = [
    { value: 'realtime', label: 'Real-time', description: 'Sync data as it changes (when supported)' },
    { value: 'hourly', label: 'Hourly', description: 'Sync every hour' },
    { value: 'daily', label: 'Daily', description: 'Sync once per day' },
    { value: 'weekly', label: 'Weekly', description: 'Sync once per week' },
    { value: 'monthly', label: 'Monthly', description: 'Sync once per month' }
  ]
  
  # File upload settings
  file_upload_settings = {
    max_size: 52428800, # 50MB
    accepted_types: ['text/csv', 'application/vnd.ms-excel', 'application/vnd.openxmlformats-officedocument.spreadsheetml.sheet', 'application/json', 'text/plain'],
    type_descriptions: {
      'text/csv' => 'CSV files',
      'application/vnd.ms-excel' => 'Excel files (.xls)',
      'application/vnd.openxmlformats-officedocument.spreadsheetml.sheet' => 'Excel files (.xlsx)',
      'application/json' => 'JSON files',
      'text/plain' => 'Text files'
    }
  }
%>

<div class="min-h-screen bg-gray-50 py-8">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="mb-8">
      <h1 class="text-3xl font-bold text-gray-900">Add New Data Source</h1>
      <p class="mt-2 text-lg text-gray-600">Connect your data sources to start analyzing and transforming your data.</p>
    </div>

    <!-- Wizard Container -->
    <div data-controller="data-source-wizard connection-tester" 
         data-connection-tester-csrf-token-value="<%= form_authenticity_token %>"
         data-connection-tester-test-url-value="<%= test_connection_data_sources_path %>"
         class="bg-white shadow-xl rounded-lg overflow-hidden">
      
      <!-- Progress Bar -->
      <div class="bg-gray-50 px-6 py-4 border-b border-gray-200">
        <div class="flex items-center justify-between mb-2">
          <span class="text-sm font-medium text-gray-700">Step <span data-data-source-wizard-target="currentStepNumber">1</span> of 4</span>
          <span class="text-sm text-gray-500" data-data-source-wizard-target="stepTitle">Choose Data Source</span>
        </div>
        <div class="w-full bg-gray-200 rounded-full h-2">
          <div class="bg-indigo-600 h-2 rounded-full transition-all duration-300" 
               data-data-source-wizard-target="progressBar" style="width: 25%"></div>
        </div>
      </div>

      <%= form_with model: @data_source, local: true, html: { 
        class: "space-y-6", 
        data: { 
          "data-source-wizard-target" => "form",
          "connection-tester-target" => "form"
        } 
      } do |form| %>
        
        <!-- Step 1: Data Source Selection -->
        <div data-data-source-wizard-target="step" data-step="1" class="p-6">
          <div class="mb-6">
            <h2 class="text-xl font-semibold text-gray-900 mb-2">Choose Your Data Source</h2>
            <p class="text-gray-600">Select the type of data source you want to connect to your platform.</p>
          </div>

          <!-- Data Source Grid -->
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-8">
            <% data_source_configs.each do |source_type, config| %>
              <% next if source_type == :google_analytics %> <%# Move to coming soon section %>
              <div class="relative <%= config[:status] == 'coming_soon' ? 'cursor-not-allowed opacity-60' : 'cursor-pointer' %> group" 
                   data-controller="source-selector"
                   data-source-type="<%= source_type %>"
                   data-source-status="<%= config[:status] %>"
                   data-action="<%= config[:status] == 'coming_soon' ? 'click->source-selector#handleDisabledSourceClick' : 'click->source-selector#selectSource' %>">
                <input type="radio" 
                       name="data_source[source_type]" 
                       value="<%= source_type %>" 
                       class="sr-only" 
                       id="source_<%= source_type %>"
                       <%= 'disabled' if config[:status] == 'coming_soon' %>>
                <div class="border-2 <%= config[:status] == 'coming_soon' ? 'border-gray-100 bg-gray-50' : 'border-gray-200' %> rounded-lg p-6 <%= config[:status] == 'coming_soon' ? '' : "hover:border-#{config[:border_color].split('-').last} hover:shadow-md" %> transition-all duration-200 <%= config[:status] == 'coming_soon' ? '' : "group-hover:#{config[:bg_color]}" %>">
                  <div class="flex items-center mb-4">
                    <div class="w-12 h-12 <%= config[:bg_color] %> rounded-lg flex items-center justify-center mr-4">
                      <% case source_type %>
                      <% when :shopify %>
                        <svg class="w-6 h-6 <%= config[:icon_color] %>" fill="currentColor" viewBox="0 0 24 24">
                          <path d="M15.8 2.1c-.8-.1-1.4.6-1.4 1.4v.1c0 .8-.7 1.5-1.5 1.5s-1.5-.7-1.5-1.5v-.1c0-.8-.6-1.5-1.4-1.4C8.6 2.2 7.5 3.4 7.5 4.8v14.4c0 1.4 1.1 2.6 2.5 2.8.8.1 1.4-.6 1.4-1.4v-.1c0-.8.7-1.5 1.5-1.5s1.5.7 1.5 1.5v.1c0 .8.6 1.5 1.4 1.4 1.4-.2 2.5-1.4 2.5-2.8V4.8c.1-1.4-1-2.6-2.3-2.7z"/>
                        </svg>
                      <% when :woocommerce %>
                        <svg class="w-6 h-6 <%= config[:icon_color] %>" fill="currentColor" viewBox="0 0 24 24">
                          <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
                        </svg>
                      <% when :amazon_seller_central %>
                        <svg class="w-6 h-6 <%= config[:icon_color] %>" fill="currentColor" viewBox="0 0 24 24">
                          <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                        </svg>
                      <% when :quickbooks %>
                        <svg class="w-6 h-6 <%= config[:icon_color] %>" fill="currentColor" viewBox="0 0 24 24">
                          <path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-5 14H7v-2h7v2zm3-4H7v-2h10v2zm0-4H7V7h10v2z"/>
                        </svg>
                      <% when :stripe %>
                        <svg class="w-6 h-6 <%= config[:icon_color] %>" fill="currentColor" viewBox="0 0 24 24">
                          <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.94-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z"/>
                        </svg>
                      <% when :file_upload %>
                        <svg class="w-6 h-6 <%= config[:icon_color] %>" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12"></path>
                        </svg>
                      <% end %>
                    </div>
                    <div>
                      <h3 class="text-lg font-semibold text-gray-900"><%= config[:name] %></h3>
                      <p class="text-sm text-gray-500">
                        <% case source_type %>
                        <% when :shopify, :woocommerce %>
                          E-commerce platform
                        <% when :amazon_seller_central %>
                          Marketplace platform
                        <% when :quickbooks %>
                          Accounting software
                        <% when :stripe %>
                          Payment processor
                        <% when :file_upload %>
                          Direct file import
                        <% end %>
                      </p>
                    </div>
                  </div>
                  <p class="text-gray-600 text-sm mb-4"><%= config[:description] %></p>
                  <div class="flex items-center justify-between">
                    <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium <%= case config[:status] when 'available' then 'bg-green-100 text-green-800' when 'beta' then 'bg-yellow-100 text-yellow-800' when 'coming_soon' then 'bg-gray-100 text-gray-600' end %>">
                      <%= case config[:status] when 'available' then 'Available' when 'beta' then 'Beta' when 'coming_soon' then 'Coming Soon' end %>
                    </span>
                    <span class="text-xs <%= config[:status] == 'coming_soon' ? 'text-gray-300' : 'text-gray-400' %>">
                      <% if config[:supports_realtime] && config[:status] != 'coming_soon' %>
                        Real-time sync
                      <% elsif source_type == :file_upload %>
                        Manual upload
                      <% elsif config[:status] != 'coming_soon' %>
                        Scheduled sync
                      <% else %>
                        Available soon
                      <% end %>
                    </span>
                  </div>
                </div>
              </div>
            <% end %>
          </div>

          <!-- Additional Sources Coming Soon -->
          <div class="border-t border-gray-200 pt-6">
            <h3 class="text-lg font-medium text-gray-900 mb-4">More Integrations Coming Soon</h3>
            <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
              <div class="text-center p-4 bg-gray-50 rounded-lg">
                <div class="w-8 h-8 bg-orange-100 rounded-lg flex items-center justify-center mx-auto mb-2">
                  <svg class="w-4 h-4 text-orange-500" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                  </svg>
                </div>
                <p class="text-sm font-medium text-gray-700">Google Analytics</p>
              </div>
              <div class="text-center p-4 bg-gray-50 rounded-lg">
                <div class="w-8 h-8 bg-blue-100 rounded-lg flex items-center justify-center mx-auto mb-2">
                  <svg class="w-4 h-4 text-blue-500" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M24 4.557c-.883.392-1.832.656-2.828.775 1.017-.609 1.798-1.574 2.165-2.724-.951.564-2.005.974-3.127 1.195-.897-.957-2.178-1.555-3.594-1.555-3.179 0-5.515 2.966-4.797 6.045-4.091-.205-7.719-2.165-10.148-5.144-1.29 2.213-.669 5.108 1.523 6.574-.806-.026-1.566-.247-2.229-.616-.054 2.281 1.581 4.415 3.949 4.89-.693.188-1.452.232-2.224.084.626 1.956 2.444 3.379 4.6 3.419-2.07 1.623-4.678 2.348-7.29 2.04 2.179 1.397 4.768 2.212 7.548 2.212 9.142 0 14.307-7.721 13.995-14.646.962-.695 1.797-1.562 2.457-2.549z"/>
                  </svg>
                </div>
                <p class="text-sm font-medium text-gray-700">Twitter</p>
              </div>
              <div class="text-center p-4 bg-gray-50 rounded-lg">
                <div class="w-8 h-8 bg-blue-100 rounded-lg flex items-center justify-center mx-auto mb-2">
                  <svg class="w-4 h-4 text-blue-600" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
                  </svg>
                </div>
                <p class="text-sm font-medium text-gray-700">Facebook</p>
              </div>
              <div class="text-center p-4 bg-gray-50 rounded-lg">
                <div class="w-8 h-8 bg-green-100 rounded-lg flex items-center justify-center mx-auto mb-2">
                  <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M23.953 4.57a10 10 0 01-2.825.775 4.958 4.958 0 002.163-2.723c-.951.555-2.005.959-3.127 1.184a4.92 4.92 0 00-8.384 4.482C7.69 8.095 4.067 6.13 1.64 3.162a4.822 4.822 0 00-.666 2.475c0 1.71.87 3.213 2.188 4.096a4.904 4.904 0 01-2.228-.616v.06a4.923 4.923 0 003.946 4.827 4.996 4.996 0 01-2.212.085 4.936 4.936 0 004.604 3.417 9.867 9.867 0 01-6.102 2.105c-.39 0-.779-.023-1.17-.067a13.995 13.995 0 007.557 2.209c9.053 0 13.998-7.496 13.998-13.985 0-.21 0-.42-.015-.63A9.935 9.935 0 0024 4.59z"/>
                  </svg>
                </div>
                <p class="text-sm font-medium text-gray-700">More...</p>
              </div>
            </div>
          </div>

          <!-- Selection Display -->
          <div data-source-selector-target="selection" class="hidden mt-6">
            <div class="bg-blue-50 border border-blue-200 rounded-lg p-4">
              <div class="flex items-center">
                <svg class="w-5 h-5 text-blue-600 mr-2" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
                </svg>
                <span class="text-sm font-medium text-blue-800" data-source-selector-target="selectionText">Selected: </span>
              </div>
            </div>
          </div>
        </div>

        <!-- Step 2: Configuration & Authentication -->
        <div data-data-source-wizard-target="step" data-step="2" class="p-6 hidden">
          <div class="mb-6">
            <h2 class="text-xl font-semibold text-gray-900 mb-2">Configuration & Authentication</h2>
            <p class="text-gray-600">Provide the necessary credentials and settings to connect to your data source.</p>
          </div>

          <!-- Basic Information -->
          <div class="space-y-6 mb-8">
            <div>
              <%= form.label :name, class: "block text-sm font-medium text-gray-700 mb-2" %>
              <%= form.text_field :name, 
                    class: "w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:ring-indigo-500 focus:border-indigo-500",
                    placeholder: "Enter a descriptive name for this data source" %>
            </div>

            <div>
              <%= form.label :description, class: "block text-sm font-medium text-gray-700 mb-2" %>
              <%= form.text_area :description, 
                    rows: 3,
                    class: "w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:ring-indigo-500 focus:border-indigo-500",
                    placeholder: "Optional description of this data source" %>
            </div>

            <div>
              <%= form.label :sync_frequency, class: "block text-sm font-medium text-gray-700 mb-2" %>
              <%= form.select :sync_frequency, 
                    options_for_select(sync_frequency_options.map { |option| [option[:label], option[:value]] }, 'daily'),
                    {},
                    { class: "w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:ring-indigo-500 focus:border-indigo-500" } %>
            </div>
          </div>

          <!-- Dynamic Configuration Section -->
          <div id="configuration-section" class="space-y-6">
            <!-- Configuration fields will be loaded dynamically based on source type -->
          </div>

          <!-- Connection Test Section -->
          <div class="mt-8 p-4 bg-gray-50 rounded-lg">
            <div class="flex items-center justify-between mb-4">
              <h3 class="text-lg font-medium text-gray-900">Test Connection</h3>
              <button type="button" 
                      data-connection-tester-target="testButton"
                      data-action="click->connection-tester#testConnection"
                      class="inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500">
                <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
                </svg>
                Test Connection
              </button>
            </div>
            
            <!-- Connection Status -->
            <div data-connection-tester-target="status" class="hidden"></div>
            
            <!-- Connection Results -->
            <div data-connection-tester-target="result" class="hidden"></div>
          </div>
        </div>

        <!-- Step 3: Data Preview & Mapping -->
        <div data-data-source-wizard-target="step" data-step="3" class="p-6 hidden">
          <div class="mb-6">
            <h2 class="text-xl font-semibold text-gray-900 mb-2">Data Preview & Mapping</h2>
            <p class="text-gray-600">Preview your data and configure how it should be processed.</p>
          </div>

          <!-- File Upload Section (for file_upload source type) -->
          <div id="file-upload-section" class="hidden">
            <div data-controller="file-upload"
                 data-file-upload-max-size-value="<%= file_upload_settings[:max_size] %>"
                 data-file-upload-accepted-types-value='<%= file_upload_settings[:accepted_types].to_json %>'
                 class="space-y-6">
              
              <!-- Enhanced Drop Zone -->
              <div class="border-2 border-gray-300 border-dashed rounded-lg p-8 text-center hover:border-gray-400 transition-colors"
                   data-file-upload-target="dropZone"
                   data-action="dragover->file-upload#dragOver dragenter->file-upload#dragEnter dragleave->file-upload#dragLeave drop->file-upload#drop click->file-upload#openFileDialog">
                <svg class="mx-auto h-12 w-12 text-gray-400" stroke="currentColor" fill="none" viewBox="0 0 48 48">
                  <path d="M28 8H12a4 4 0 00-4 4v20m32-12v8m0 0v8a4 4 0 01-4 4H12a4 4 0 01-4-4v-4m32-4l-3.172-3.172a4 4 0 00-5.656 0L28 28M8 32l9.172-9.172a4 4 0 015.656 0L28 28m0 0l4 4m4-24h8m-4-4v8m-12 4h.02" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
                <div class="mt-4">
                  <p class="text-lg font-medium text-gray-900 drop-text">Drag and drop files here, or click to select</p>
                  <p class="text-sm text-gray-500 mt-2">Supports <%= file_upload_settings[:type_descriptions].values.join(', ') %> up to <%= number_to_human_size(file_upload_settings[:max_size]) %></p>
                  
                  <!-- Sample file download section -->
                  <div class="mt-4 pt-4 border-t border-gray-200">
                    <p class="text-xs text-gray-600 mb-3">Need examples? Download sample files:</p>
                    <div class="flex justify-center space-x-2">
                      <%= link_to download_sample_csv_data_sources_path, 
                                  class: "inline-flex items-center px-2 py-1 border border-gray-300 shadow-sm text-xs font-medium rounded text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-1 focus:ring-offset-1 focus:ring-indigo-500",
                                  onclick: "event.stopPropagation();" do %>
                        <svg class="h-3 w-3 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                        </svg>
                        CSV
                      <% end %>
                      <%= link_to download_sample_excel_data_sources_path, 
                                  class: "inline-flex items-center px-2 py-1 border border-gray-300 shadow-sm text-xs font-medium rounded text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-1 focus:ring-offset-1 focus:ring-indigo-500",
                                  onclick: "event.stopPropagation();" do %>
                        <svg class="h-3 w-3 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                        </svg>
                        Excel
                      <% end %>
                      <%= link_to download_sample_json_data_sources_path, 
                                  class: "inline-flex items-center px-2 py-1 border border-gray-300 shadow-sm text-xs font-medium rounded text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-1 focus:ring-offset-1 focus:ring-indigo-500",
                                  onclick: "event.stopPropagation();" do %>
                        <svg class="h-3 w-3 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                        </svg>
                        JSON
                      <% end %>
                    </div>
                  </div>
                </div>
              </div>

              <!-- Hidden File Input -->
              <input type="file" 
                     multiple 
                     accept="<%= file_upload_settings[:accepted_types].map { |type| type.gsub('application/vnd.ms-excel', '.xls').gsub('application/vnd.openxmlformats-officedocument.spreadsheetml.sheet', '.xlsx').gsub('text/csv', '.csv').gsub('application/json', '.json').gsub('text/plain', '.txt') }.join(',') %>"
                     data-file-upload-target="input"
                     data-action="change->file-upload#handleFiles"
                     class="hidden">

              <!-- File List -->
              <div data-file-upload-target="fileList" class="space-y-2"></div>

              <!-- Upload Progress -->
              <div data-file-upload-target="progressContainer" class="hidden">
                <div class="mb-2">
                  <div class="flex justify-between text-sm font-medium text-gray-700">
                    <span>Processing files...</span>
                    <span>0%</span>
                  </div>
                  <div class="mt-1 w-full bg-gray-200 rounded-full h-2">
                    <div data-file-upload-target="batchProgress" 
                         class="bg-indigo-600 h-2 rounded-full transition-all duration-300" 
                         style="width: 0%"></div>
                  </div>
                </div>
              </div>

              <!-- Upload Status -->
              <div data-file-upload-target="uploadStatus" class="hidden"></div>

              <!-- Data Preview -->
              <div data-file-upload-target="dataPreview" class="space-y-4"></div>

              <!-- Process Files Button -->
              <div class="flex justify-center">
                <button type="button" 
                        data-action="click->file-upload#processFiles"
                        class="inline-flex items-center px-6 py-3 border border-transparent text-base font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500">
                  <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                  </svg>
                  Process Files
                </button>
              </div>
            </div>
          </div>

          <!-- API Data Preview Section (for API source types) -->
          <div id="api-preview-section" class="hidden">
            <div class="bg-gray-50 rounded-lg p-6">
              <h3 class="text-lg font-medium text-gray-900 mb-4">Sample Data Preview</h3>
              <p class="text-gray-600 mb-4">Here's a preview of the data that will be imported from your connected source:</p>
              
              <div class="bg-white border border-gray-200 rounded-md p-4">
                <div class="text-sm text-gray-500 mb-2">Loading sample data...</div>
                <div class="animate-pulse">
                  <div class="h-4 bg-gray-200 rounded w-3/4 mb-2"></div>
                  <div class="h-4 bg-gray-200 rounded w-1/2 mb-2"></div>
                  <div class="h-4 bg-gray-200 rounded w-5/6"></div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Step 4: Final Setup & Sync Options -->
        <div data-data-source-wizard-target="step" data-step="4" class="p-6 hidden">
          <div class="mb-6">
            <h2 class="text-xl font-semibold text-gray-900 mb-2">Review & Finalize</h2>
            <p class="text-gray-600">Review your configuration and complete the setup of your data source.</p>
