<script>
  // Dynamic configuration loading
  document.addEventListener('DOMContentLoaded', function() {
    const configSection = document.getElementById('configuration-section')
    const fileUploadSection = document.getElementById('file-upload-section')
    const apiPreviewSection = document.getElementById('api-preview-section')
    
    // Available source types from Ruby configuration
    const availableSourceTypes = <%= data_source_configs.select { |_, config| config[:implemented] }.keys.to_json.html_safe %>;
    const dataSourceConfigs = <%= data_source_configs.to_json.html_safe %>;
    const fileUploadSettings = <%= file_upload_settings.to_json.html_safe %>;
    
    function loadConfiguration(sourceType) {
      const template = document.getElementById(`${sourceType}-config-template`)
      if (template && configSection && availableSourceTypes.includes(sourceType)) {
        configSection.innerHTML = template.innerHTML
      } else if (configSection) {
        const sourceConfig = dataSourceConfigs[sourceType];
        const sourceName = sourceConfig ? sourceConfig.name : sourceType.replace('_', ' ').replace(/\b\w/g, l => l.toUpperCase());
        configSection.innerHTML = `
          <div class="text-center py-8 text-gray-500">
            <div class="mb-4">
              <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
            </div>
            <h3 class="text-lg font-medium text-gray-900 mb-2">${sourceName}</h3>
            <p class="text-sm">Configuration for ${sourceName} is currently in development. We're working hard to bring you this integration!</p>
            <div class="mt-4">
              <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium bg-yellow-100 text-yellow-800">
                In Development
              </span>
            </div>
          </div>
        `;
      }
      
      // Show/hide appropriate preview sections
      if (sourceType === 'file_upload') {
        fileUploadSection?.classList.remove('hidden')
        apiPreviewSection?.classList.add('hidden')
      } else {
        fileUploadSection?.classList.add('hidden')
        apiPreviewSection?.classList.remove('hidden')
      }
      
      // Update connection tester source type
      const connectionTester = document.querySelector('[data-controller*="connection-tester"]')
      if (connectionTester) {
        connectionTester.setAttribute('data-connection-tester-source-type-value', sourceType)
      }
    }
    
    // Listen for source selection events
    document.addEventListener('source-selector:sourceSelected', function(event) {
      loadConfiguration(event.detail.sourceType)
    })
    
    // File upload handling with dynamic settings
    const fileInput = document.querySelector('input[type="file"]');
    if (fileInput) {
      fileInput.addEventListener('change', function(e) {
        const file = e.target.files[0];
        if (file) {
          // Check file size
          if (file.size > fileUploadSettings.max_size) {
            alert(`File size exceeds maximum allowed size of ${(fileUploadSettings.max_size / (1024 * 1024)).toFixed(1)}MB`);
            this.value = '';
            return;
          }
          
          // Check file type
          const fileType = file.type;
          const fileName = file.name.toLowerCase();
          const isValidType = fileUploadSettings.accepted_types.some(type => {
            if (type.includes('*')) {
              const baseType = type.split('/')[0];
              return fileType.startsWith(baseType);
            }
            return fileType === type;
          });
          
          if (!isValidType) {
            alert(`File type not supported. Please upload: ${Object.values(fileUploadSettings.type_descriptions).join(', ')}`);
            this.value = '';
            return;
          }
        }
      });
    }
  })
</script>