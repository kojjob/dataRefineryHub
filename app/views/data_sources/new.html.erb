<% content_for :title, "Add New Data Source" %>

<div class="min-h-screen bg-gray-50 py-8">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="mb-8">
      <h1 class="text-3xl font-bold text-gray-900">Add New Data Source</h1>
      <p class="mt-2 text-lg text-gray-600">Connect your data sources to start analyzing and transforming your data.</p>
    </div>

    <!-- Wizard Container -->
    <div data-controller="data-source-wizard connection-tester" 
         data-connection-tester-csrf-token-value="<%= form_authenticity_token %>"
         data-connection-tester-test-url-value="<%= test_connection_data_sources_path %>"
         class="bg-white shadow-xl rounded-lg overflow-hidden">
      
      <!-- Progress Bar -->
      <div class="bg-gray-50 px-6 py-4 border-b border-gray-200">
        <div class="flex items-center justify-between mb-2">
          <span class="text-sm font-medium text-gray-700">Step <span data-data-source-wizard-target="currentStepNumber">1</span> of 4</span>
          <span class="text-sm text-gray-500" data-data-source-wizard-target="stepTitle">Choose Data Source</span>
        </div>
        <div class="w-full bg-gray-200 rounded-full h-2">
          <div class="bg-indigo-600 h-2 rounded-full transition-all duration-300" 
               data-data-source-wizard-target="progressBar" style="width: 25%"></div>
        </div>
      </div>

      <%= form_with model: @data_source, local: true, html: { 
        class: "space-y-6", 
        data: { 
          "data-source-wizard-target" => "form",
          "connection-tester-target" => "form"
        } 
      } do |form| %>
        
        <!-- Step 1: Source Type Selection -->
        <div data-data-source-wizard-target="step" data-step="1" class="p-6">
          <div class="mb-6">
            <h2 class="text-xl font-semibold text-gray-900 mb-2">Choose Your Data Source</h2>
            <p class="text-gray-600">Select the platform or service you want to connect to your data pipeline.</p>
          </div>

          <div data-controller="source-selector" 
               data-source-selector-selected-value=""
               data-connection-tester-source-type-value="">
            
            <!-- Search and Filter -->
            <div class="mb-6">
              <div class="relative">
                <input type="text" 
                       data-source-selector-target="searchInput"
                       data-action="input->source-selector#search"
                       placeholder="Search data sources..."
                       class="w-full pl-10 pr-4 py-2 border border-gray-300 rounded-md focus:ring-indigo-500 focus:border-indigo-500">
                <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                  <svg class="h-5 w-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
                  </svg>
                </div>
              </div>
            </div>

            <!-- Category Filters -->
            <div class="mb-6">
              <div class="flex flex-wrap gap-2" data-source-selector-target="categoryFilters">
                <button type="button" 
                        data-action="click->source-selector#filterByCategory"
                        data-category="all"
                        class="px-3 py-1 text-sm font-medium rounded-full bg-indigo-100 text-indigo-800 border border-indigo-200">
                  All Sources
                </button>
                <button type="button" 
                        data-action="click->source-selector#filterByCategory"
                        data-category="ecommerce"
                        class="px-3 py-1 text-sm font-medium rounded-full bg-gray-100 text-gray-700 border border-gray-200 hover:bg-gray-200">
                  E-commerce
                </button>
                <button type="button" 
                        data-action="click->source-selector#filterByCategory"
                        data-category="financial"
                        class="px-3 py-1 text-sm font-medium rounded-full bg-gray-100 text-gray-700 border border-gray-200 hover:bg-gray-200">
                  Financial
                </button>
                <button type="button" 
                        data-action="click->source-selector#filterByCategory"
                        data-category="marketing"
                        class="px-3 py-1 text-sm font-medium rounded-full bg-gray-100 text-gray-700 border border-gray-200 hover:bg-gray-200">
                  Marketing
                </button>
                <button type="button" 
                        data-action="click->source-selector#filterByCategory"
                        data-category="data_import"
                        class="px-3 py-1 text-sm font-medium rounded-full bg-gray-100 text-gray-700 border border-gray-200 hover:bg-gray-200">
                  Data Import
                </button>
              </div>
            </div>

            <!-- Source Type Grid -->
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4" data-source-selector-target="sourceGrid">
              
              <!-- Shopify -->
              <div class="relative border border-gray-200 rounded-lg p-4 hover:border-indigo-300 hover:shadow-md transition-all cursor-pointer"
                   data-source-selector-target="sourceCard"
                   data-category="ecommerce"
                   data-source-type="shopify"
                   data-status="available"
                   data-action="click->source-selector#selectSource">
                <div class="flex items-start space-x-3">
                  <div class="flex-shrink-0">
                    <div class="w-10 h-10 bg-green-100 rounded-lg flex items-center justify-center">
                      <svg class="w-6 h-6 text-green-600" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M14.8 5.2c-.2-.2-.4-.2-.6-.2s-.4.1-.6.2L12 6.8 10.4 5.2c-.2-.2-.4-.2-.6-.2s-.4.1-.6.2c-.3.3-.3.8 0 1.1L10.8 8 9.2 9.6c-.3.3-.3.8 0 1.1.2.2.4.2.6.2s.4-.1.6-.2L12 9.2l1.6 1.6c.2.2.4.2.6.2s.4-.1.6-.2c.3-.3.3-.8 0-1.1L13.2 8l1.6-1.6c.3-.4.3-.9 0-1.2z"/>
                      </svg>
                    </div>
                  </div>
                  <div class="flex-1 min-w-0">
                    <h3 class="text-sm font-medium text-gray-900">Shopify</h3>
                    <p class="text-sm text-gray-500 mt-1">Connect your Shopify store to sync orders, products, and customer data.</p>
                    <div class="mt-2">
                      <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-green-100 text-green-800">
                        Available
                      </span>
                    </div>
                  </div>
                </div>
                <input type="radio" name="data_source[source_type]" value="shopify" class="sr-only">
              </div>

              <!-- WooCommerce -->
              <div class="relative border border-gray-200 rounded-lg p-4 hover:border-indigo-300 hover:shadow-md transition-all cursor-pointer"
                   data-source-selector-target="sourceCard"
                   data-category="ecommerce"
                   data-source-type="woocommerce"
                   data-status="available"
                   data-action="click->source-selector#selectSource">
                <div class="flex items-start space-x-3">
                  <div class="flex-shrink-0">
                    <div class="w-10 h-10 bg-purple-100 rounded-lg flex items-center justify-center">
                      <svg class="w-6 h-6 text-purple-600" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
                      </svg>
                    </div>
                  </div>
                  <div class="flex-1 min-w-0">
                    <h3 class="text-sm font-medium text-gray-900">WooCommerce</h3>
                    <p class="text-sm text-gray-500 mt-1">Sync data from your WooCommerce store including sales and inventory.</p>
                    <div class="mt-2">
                      <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-green-100 text-green-800">
                        Available
                      </span>
                    </div>
                  </div>
                </div>
                <input type="radio" name="data_source[source_type]" value="woocommerce" class="sr-only">
              </div>

              <!-- Amazon Seller Central -->
              <div class="relative border border-gray-200 rounded-lg p-4 hover:border-indigo-300 hover:shadow-md transition-all cursor-pointer"
                   data-source-selector-target="sourceCard"
                   data-category="ecommerce"
                   data-source-type="amazon_seller_central"
                   data-status="available"
                   data-action="click->source-selector#selectSource">
                <div class="flex items-start space-x-3">
                  <div class="flex-shrink-0">
                    <div class="w-10 h-10 bg-orange-100 rounded-lg flex items-center justify-center">
                      <svg class="w-6 h-6 text-orange-600" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                      </svg>
                    </div>
                  </div>
                  <div class="flex-1 min-w-0">
                    <h3 class="text-sm font-medium text-gray-900">Amazon Seller Central</h3>
                    <p class="text-sm text-gray-500 mt-1">Import sales data and inventory from Amazon Seller Central.</p>
                    <div class="mt-2">
                      <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-green-100 text-green-800">
                        Available
                      </span>
                    </div>
                  </div>
                </div>
                <input type="radio" name="data_source[source_type]" value="amazon_seller_central" class="sr-only">
              </div>

              <!-- QuickBooks -->
              <div class="relative border border-gray-200 rounded-lg p-4 hover:border-indigo-300 hover:shadow-md transition-all cursor-pointer"
                   data-source-selector-target="sourceCard"
                   data-category="financial"
                   data-source-type="quickbooks"
                   data-status="available"
                   data-action="click->source-selector#selectSource">
                <div class="flex items-start space-x-3">
                  <div class="flex-shrink-0">
                    <div class="w-10 h-10 bg-blue-100 rounded-lg flex items-center justify-center">
                      <svg class="w-6 h-6 text-blue-600" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.94-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z"/>
                      </svg>
                    </div>
                  </div>
                  <div class="flex-1 min-w-0">
                    <h3 class="text-sm font-medium text-gray-900">QuickBooks</h3>
                    <p class="text-sm text-gray-500 mt-1">Sync financial data from QuickBooks for comprehensive reporting.</p>
                    <div class="mt-2">
                      <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-green-100 text-green-800">
                        Available
                      </span>
                    </div>
                  </div>
                </div>
                <input type="radio" name="data_source[source_type]" value="quickbooks" class="sr-only">
              </div>

              <!-- Stripe -->
              <div class="relative border border-gray-200 rounded-lg p-4 hover:border-indigo-300 hover:shadow-md transition-all cursor-pointer"
                   data-source-selector-target="sourceCard"
                   data-category="financial"
                   data-source-type="stripe"
                   data-status="available"
                   data-action="click->source-selector#selectSource">
                <div class="flex items-start space-x-3">
                  <div class="flex-shrink-0">
                    <div class="w-10 h-10 bg-indigo-100 rounded-lg flex items-center justify-center">
                      <svg class="w-6 h-6 text-indigo-600" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
                      </svg>
                    </div>
                  </div>
                  <div class="flex-1 min-w-0">
                    <h3 class="text-sm font-medium text-gray-900">Stripe</h3>
                    <p class="text-sm text-gray-500 mt-1">Connect Stripe to analyze payment data and transaction trends.</p>
                    <div class="mt-2">
                      <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-green-100 text-green-800">
                        Available
                      </span>
                    </div>
                  </div>
                </div>
                <input type="radio" name="data_source[source_type]" value="stripe" class="sr-only">
              </div>

              <!-- File Upload -->
              <div class="relative border border-gray-200 rounded-lg p-4 hover:border-indigo-300 hover:shadow-md transition-all cursor-pointer"
                   data-source-selector-target="sourceCard"
                   data-category="data_import"
                   data-source-type="file_upload"
                   data-status="available"
                   data-action="click->source-selector#selectSource">
                <div class="flex items-start space-x-3">
                  <div class="flex-shrink-0">
                    <div class="w-10 h-10 bg-gray-100 rounded-lg flex items-center justify-center">
                      <svg class="w-6 h-6 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12"></path>
                      </svg>
                    </div>
                  </div>
                  <div class="flex-1 min-w-0">
                    <h3 class="text-sm font-medium text-gray-900">File Upload</h3>
                    <p class="text-sm text-gray-500 mt-1">Upload CSV, Excel, JSON, or text files to import your data.</p>
                    <div class="mt-2">
                      <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-green-100 text-green-800">
                        Available
                      </span>
                    </div>
                  </div>
                </div>
                <input type="radio" name="data_source[source_type]" value="file_upload" class="sr-only">
              </div>

              <!-- Coming Soon Sources -->
              <div class="relative border border-gray-200 rounded-lg p-4 opacity-60 cursor-not-allowed"
                   data-source-selector-target="sourceCard"
                   data-category="marketing"
                   data-source-type="google_analytics"
                   data-status="coming_soon">
                <div class="flex items-start space-x-3">
                  <div class="flex-shrink-0">
                    <div class="w-10 h-10 bg-red-100 rounded-lg flex items-center justify-center">
                      <svg class="w-6 h-6 text-red-600" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.94-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z"/>
                      </svg>
                    </div>
                  </div>
                  <div class="flex-1 min-w-0">
                    <h3 class="text-sm font-medium text-gray-900">Google Analytics</h3>
                    <p class="text-sm text-gray-500 mt-1">Import website analytics and user behavior data.</p>
                    <div class="mt-2">
                      <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-yellow-100 text-yellow-800">
                        Coming Soon
                      </span>
                    </div>
                  </div>
                </div>
              </div>

            </div>

            <!-- Selection Status -->
            <div class="mt-6 p-4 bg-blue-50 border border-blue-200 rounded-md hidden" data-source-selector-target="selectionStatus">
              <div class="flex items-center">
                <svg class="w-5 h-5 text-blue-600 mr-2" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
                </svg>
                <span class="text-sm font-medium text-blue-800" data-source-selector-target="selectionText">Selected: </span>
              </div>
            </div>
          </div>
        </div>

        <!-- Step 2: Configuration & Authentication -->
        <div data-data-source-wizard-target="step" data-step="2" class="p-6 hidden">
          <div class="mb-6">
            <h2 class="text-xl font-semibold text-gray-900 mb-2">Configuration & Authentication</h2>
            <p class="text-gray-600">Provide the necessary credentials and settings to connect to your data source.</p>
          </div>

          <!-- Basic Information -->
          <div class="space-y-6 mb-8">
            <div>
              <%= form.label :name, class: "block text-sm font-medium text-gray-700 mb-2" %>
              <%= form.text_field :name, 
                    class: "w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:ring-indigo-500 focus:border-indigo-500",
                    placeholder: "Enter a descriptive name for this data source" %>
            </div>

            <div>
              <%= form.label :description, class: "block text-sm font-medium text-gray-700 mb-2" %>
              <%= form.text_area :description, 
                    rows: 3,
                    class: "w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:ring-indigo-500 focus:border-indigo-500",
                    placeholder: "Optional description of this data source" %>
            </div>

            <div>
              <%= form.label :sync_frequency, class: "block text-sm font-medium text-gray-700 mb-2" %>
              <%= form.select :sync_frequency, 
                    options_for_select([
                      ['Real-time', 'real_time'],
                      ['Hourly', 'hourly'],
                      ['Daily', 'daily'],
                      ['Weekly', 'weekly'],
                      ['Monthly', 'monthly']
                    ], 'daily'),
                    {},
                    { class: "w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:ring-indigo-500 focus:border-indigo-500" } %>
            </div>
          </div>

          <!-- Dynamic Configuration Section -->
          <div id="configuration-section" class="space-y-6">
            <!-- Configuration fields will be loaded dynamically based on source type -->
          </div>

          <!-- Connection Test Section -->
          <div class="mt-8 p-4 bg-gray-50 rounded-lg">
            <div class="flex items-center justify-between mb-4">
              <h3 class="text-lg font-medium text-gray-900">Test Connection</h3>
              <button type="button" 
                      data-connection-tester-target="testButton"
                      data-action="click->connection-tester#testConnection"
                      class="inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500">
                <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
                </svg>
                Test Connection
              </button>
            </div>
            
            <!-- Connection Status -->
            <div data-connection-tester-target="status" class="hidden"></div>
            
            <!-- Connection Results -->
            <div data-connection-tester-target="result" class="hidden"></div>
          </div>
        </div>

        <!-- Step 3: Data Preview & Mapping -->
        <div data-data-source-wizard-target="step" data-step="3" class="p-6 hidden">
          <div class="mb-6">
            <h2 class="text-xl font-semibold text-gray-900 mb-2">Data Preview & Mapping</h2>
            <p class="text-gray-600">Preview your data and configure how it should be processed.</p>
          </div>

          <!-- File Upload Section (for file_upload source type) -->
          <div id="file-upload-section" class="hidden">
            <div data-controller="file-upload"
                 data-file-upload-max-size-value="52428800"
                 data-file-upload-accepted-types-value='["text/csv", "application/vnd.ms-excel", "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet", "application/json", "text/plain"]'
                 class="space-y-6">
              
              <!-- Enhanced Drop Zone -->
              <div class="border-2 border-gray-300 border-dashed rounded-lg p-8 text-center hover:border-gray-400 transition-colors"
                   data-file-upload-target="dropZone"
                   data-action="dragover->file-upload#dragOver dragenter->file-upload#dragEnter dragleave->file-upload#dragLeave drop->file-upload#drop click->file-upload#openFileDialog">
                <svg class="mx-auto h-12 w-12 text-gray-400" stroke="currentColor" fill="none" viewBox="0 0 48 48">
                  <path d="M28 8H12a4 4 0 00-4 4v20m32-12v8m0 0v8a4 4 0 01-4 4H12a4 4 0 01-4-4v-4m32-4l-3.172-3.172a4 4 0 00-5.656 0L28 28M8 32l9.172-9.172a4 4 0 015.656 0L28 28m0 0l4 4m4-24h8m-4-4v8m-12 4h.02" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
                <div class="mt-4">
                  <p class="text-lg font-medium text-gray-900 drop-text">Drag and drop files here, or click to select</p>
                  <p class="text-sm text-gray-500 mt-2">Supports CSV, Excel, JSON, and text files up to 50MB</p>
                </div>
              </div>

              <!-- Hidden File Input -->
              <input type="file" 
                     multiple 
                     accept=".csv,.xlsx,.xls,.json,.txt"
                     data-file-upload-target="input"
                     data-action="change->file-upload#handleFiles"
                     class="hidden">

              <!-- File List -->
              <div data-file-upload-target="fileList" class="space-y-2"></div>

              <!-- Upload Progress -->
              <div data-file-upload-target="progressContainer" class="hidden">
                <div class="mb-2">
                  <div class="flex justify-between text-sm font-medium text-gray-700">
                    <span>Processing files...</span>
                    <span>0%</span>
                  </div>
                  <div class="mt-1 w-full bg-gray-200 rounded-full h-2">
                    <div data-file-upload-target="batchProgress" 
                         class="bg-indigo-600 h-2 rounded-full transition-all duration-300" 
                         style="width: 0%"></div>
                  </div>
                </div>
              </div>

              <!-- Upload Status -->
              <div data-file-upload-target="uploadStatus" class="hidden"></div>

              <!-- Data Preview -->
              <div data-file-upload-target="dataPreview" class="space-y-4"></div>

              <!-- Process Files Button -->
              <div class="flex justify-center">
                <button type="button" 
                        data-action="click->file-upload#processFiles"
                        class="inline-flex items-center px-6 py-3 border border-transparent text-base font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500">
                  <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                  </svg>
                  Process Files
                </button>
              </div>
            </div>
          </div>

          <!-- API Data Preview Section (for API source types) -->
          <div id="api-preview-section" class="hidden">
            <div class="bg-gray-50 rounded-lg p-6">
              <h3 class="text-lg font-medium text-gray-900 mb-4">Sample Data Preview</h3>
              <p class="text-gray-600 mb-4">Here's a preview of the data that will be imported from your connected source:</p>
              
              <div class="bg-white border border-gray-200 rounded-md p-4">
                <div class="text-sm text-gray-500 mb-2">Loading sample data...</div>
                <div class="animate-pulse">
                  <div class="h-4 bg-gray-200 rounded w-3/4 mb-2"></div>
                  <div class="h-4 bg-gray-200 rounded w-1/2 mb-2"></div>
                  <div class="h-4 bg-gray-200 rounded w-5/6"></div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Step 4: Final Setup & Sync Options -->
        <div data-data-source-wizard-target="step" data-step="4" class="p-6 hidden">
          <div class="mb-6">
            <h2 class="text-xl font-semibold text-gray-900 mb-2">Review & Finalize</h2>
            <p class="text-gray-600">Review your configuration and complete the setup of your data source.</p>
          </div>

          <!-- Configuration Summary -->
          <div class="bg-gray-50 rounded-lg p-6 mb-6">
            <h3 class="text-lg font-medium text-gray-900 mb-4">Configuration Summary</h3>
            <dl class="grid grid-cols-1 gap-x-4 gap-y-4 sm:grid-cols-2">
              <div>
                <dt class="text-sm font-medium text-gray-500">Data Source Type</dt>
                <dd class="mt-1 text-sm text-gray-900" data-data-source-wizard-target="summarySourceType">-</dd>
              </div>
              <div>
                <dt class="text-sm font-medium text-gray-500">Name</dt>
                <dd class="mt-1 text-sm text-gray-900" data-data-source-wizard-target="summaryName">-</dd>
              </div>
              <div>
                <dt class="text-sm font-medium text-gray-500">Sync Frequency</dt>
                <dd class="mt-1 text-sm text-gray-900" data-data-source-wizard-target="summarySyncFrequency">-</dd>
              </div>
              <div>
                <dt class="text-sm font-medium text-gray-500">Connection Status</dt>
                <dd class="mt-1 text-sm text-gray-900" data-data-source-wizard-target="summaryConnectionStatus">
                  <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-yellow-100 text-yellow-800">
                    Not Tested
                  </span>
                </dd>
              </div>
            </dl>
          </div>

          <!-- Initial Sync Options -->
          <div class="bg-white border border-gray-200 rounded-lg p-6 mb-6">
            <h3 class="text-lg font-medium text-gray-900 mb-4">Initial Sync Options</h3>
            <div class="space-y-4">
              <div class="flex items-center">
                <input type="checkbox" 
                       id="perform_initial_sync" 
                       name="data_source[perform_initial_sync]" 
                       value="1" 
                       checked
                       class="h-4 w-4 text-indigo-600 focus:ring-indigo-500 border-gray-300 rounded">
                <label for="perform_initial_sync" class="ml-2 block text-sm text-gray-900">
                  Perform initial data sync after creation
                </label>
              </div>
              <div class="flex items-center">
                <input type="checkbox" 
                       id="enable_auto_sync" 
                       name="data_source[enable_auto_sync]" 
                       value="1" 
                       checked
                       class="h-4 w-4 text-indigo-600 focus:ring-indigo-500 border-gray-300 rounded">
                <label for="enable_auto_sync" class="ml-2 block text-sm text-gray-900">
                  Enable automatic syncing based on the selected frequency
                </label>
              </div>
            </div>
          </div>
        </div>

        <!-- Navigation Buttons -->
        <div class="bg-gray-50 px-6 py-4 border-t border-gray-200 flex justify-between">
          <button type="button" 
                  data-data-source-wizard-target="prevButton"
                  data-action="click->data-source-wizard#previousStep"
                  class="hidden inline-flex items-center px-4 py-2 border border-gray-300 text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500">
            <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
            </svg>
            Previous
          </button>
          
          <div class="flex space-x-3">
            <button type="button" 
                    data-data-source-wizard-target="nextButton"
                    data-action="click->data-source-wizard#nextStep"
                    class="inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500">
              Next
              <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
              </svg>
            </button>
            
            <button type="submit" 
                    data-data-source-wizard-target="submitButton"
                    data-action="click->data-source-wizard#submitForm"
                    class="hidden inline-flex items-center px-6 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-green-600 hover:bg-green-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500">
              <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
              Create Data Source
            </button>
          </div>
        </div>

      <% end %>
    </div>

    <!-- Error Display -->
    <% if @data_source.errors.any? %>
      <div class="mt-6 bg-red-50 border border-red-200 rounded-md p-4">
        <div class="flex">
          <div class="flex-shrink-0">
            <svg class="h-5 w-5 text-red-400" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L10 10.586l2.707-2.707a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"></path>
            </svg>
          </div>
          <div class="ml-3">
            <h3 class="text-sm font-medium text-red-800">There were errors with your submission:</h3>
            <div class="mt-2 text-sm text-red-700">
              <ul class="list-disc pl-5 space-y-1">
                <% @data_source.errors.full_messages.each do |message| %>
                  <li><%= message %></li>
                <% end %>
              </ul>
            </div>
          </div>
        </div>
      </div>
    <% end %>
  </div>
</div>

<!-- Dynamic Configuration Templates -->
