<!-- Google Analytics 4 Configuration Form -->
<div class="grid grid-cols-1 gap-x-6 gap-y-6">
  <!-- OAuth Authentication Section -->
  <div class="col-span-1">
    <div class="bg-blue-50 dark:bg-blue-900/20 rounded-lg p-6 border border-blue-200 dark:border-blue-800">
      <div class="flex items-start">
        <div class="flex-shrink-0">
          <svg class="w-6 h-6 text-blue-600 dark:text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path>
          </svg>
        </div>
        <div class="ml-4 flex-1">
          <h4 class="text-base font-semibold text-blue-900 dark:text-blue-100 mb-2">
            Secure OAuth Authentication
          </h4>
          <p class="text-sm text-blue-700 dark:text-blue-300 mb-4">
            Google Analytics uses OAuth 2.0 for secure authentication. Connect your Google Analytics 4 (GA4) property to sync traffic data, user behavior, conversions, and advanced analytics metrics.
          </p>

          <!-- Connection Status Display -->
          <% if data_source.persisted? && data_source.configuration.dig('access_token').present? %>
            <div class="mb-4 p-3 bg-green-50 dark:bg-green-900/20 border border-green-200 dark:border-green-800 rounded-lg">
              <div class="flex items-center">
                <svg class="w-5 h-5 text-green-600 dark:text-green-400 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
                <div class="flex-1">
                  <p class="text-sm font-medium text-green-900 dark:text-green-100">
                    Google Analytics Connected
                  </p>
                  <p class="text-xs text-green-700 dark:text-green-300">
                    Property ID: <%= data_source.configuration.dig('property_id') %>
                  </p>
                </div>
              </div>
            </div>

            <%= link_to oauth_authorize_path(provider: 'google_analytics', data_source_id: data_source.id),
                        class: "inline-flex items-center px-4 py-2 bg-orange-600 hover:bg-orange-700 text-white text-sm font-medium rounded-lg transition-colors duration-200" do %>
              <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path>
              </svg>
              Reconnect Google Analytics
            <% end %>
          <% else %>
            <%= link_to oauth_authorize_path(provider: 'google_analytics', data_source_id: data_source.id),
                        class: "inline-flex items-center px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium rounded-lg transition-colors duration-200 shadow-sm" do %>
              <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"></path>
              </svg>
              Connect to Google Analytics
            <% end %>
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <!-- Property ID - Hidden field populated by OAuth -->
  <div class="col-span-1" style="<%= 'display: none;' unless data_source.configuration.dig('property_id').present? %>">
    <label class="block text-sm font-medium leading-6 text-gray-900 dark:text-gray-300 mb-2">
      GA4 Property ID
    </label>
    <div class="relative">
      <input type="text"
             name="data_source[config][property_id]"
             value="<%= data_source.configuration.dig('property_id') %>"
             readonly
             placeholder="Will be populated after OAuth connection"
             class="block w-full rounded-md border-0 py-2.5 px-3 text-gray-900 dark:text-gray-100 shadow-sm ring-1 ring-inset ring-gray-300 dark:ring-gray-600 bg-gray-50 dark:bg-gray-700 placeholder:text-gray-400 focus:ring-2 focus:ring-inset focus:ring-indigo-600 sm:text-sm sm:leading-6">
      <div class="absolute inset-y-0 right-0 flex items-center pr-3 pointer-events-none">
        <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path>
        </svg>
      </div>
    </div>
    <p class="mt-2 text-sm text-gray-500 dark:text-gray-400">
      Your Google Analytics 4 property identifier (automatically populated during OAuth)
    </p>
  </div>

  <!-- Hidden OAuth Token Fields -->
  <input type="hidden" name="data_source[config][access_token]" value="<%= data_source.configuration.dig('access_token') %>" data-oauth-connector-target="accessToken">
  <input type="hidden" name="data_source[config][refresh_token]" value="<%= data_source.configuration.dig('refresh_token') %>" data-oauth-connector-target="refreshToken">
  <input type="hidden" name="data_source[config][token_expires_at]" value="<%= data_source.configuration.dig('token_expires_at') %>" data-oauth-connector-target="expiresAt">

  <!-- Report Types Configuration -->
  <div class="col-span-1">
    <div class="border-t border-gray-200 dark:border-gray-600 pt-6">
      <h4 class="text-base font-semibold text-gray-900 dark:text-white mb-4 flex items-center">
        <svg class="w-5 h-5 mr-2 text-indigo-600 dark:text-indigo-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
        </svg>
        Report Types to Sync
      </h4>

      <div class="space-y-3">
        <% report_types = [
          { value: 'traffic_overview', label: 'Traffic Overview', description: 'Sessions, users, pageviews by date, country, and device', icon: 'M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6' },
          { value: 'user_acquisition', label: 'User Acquisition', description: 'Acquisition metrics by source, medium, and campaign', icon: 'M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z' },
          { value: 'engagement', label: 'Engagement', description: 'Engagement metrics by page path and landing page', icon: 'M14 10h4.764a2 2 0 011.789 2.894l-3.5 7A2 2 0 0115.263 21h-4.017c-.163 0-.326-.02-.485-.06L7 20m7-10V5a2 2 0 00-2-2h-.095c-.5 0-.905.405-.905.905 0 .714-.211 1.412-.608 2.006L7 11v9m7-10h-2M7 20H5a2 2 0 01-2-2v-6a2 2 0 012-2h2.5' },
          { value: 'conversions', label: 'Conversions', description: 'Conversion events, revenue, and ecommerce data', icon: 'M9 8h6m-5 0a3 3 0 110 6H9l3 3m-3-6h6m6 1a9 9 0 11-18 0 9 9 0 0118 0z' }
        ] %>

        <% report_types.each do |type| %>
          <label class="relative flex items-start p-4 border border-gray-200 dark:border-gray-600 rounded-lg cursor-pointer hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors duration-200">
            <div class="flex items-center h-5">
              <input type="checkbox"
                     name="data_source[config][report_types][]"
                     value="<%= type[:value] %>"
                     <%= 'checked' if data_source.configuration.dig('report_types')&.include?(type[:value]) || data_source.new_record? %>
                     class="h-4 w-4 rounded border-gray-300 text-indigo-600 focus:ring-indigo-600">
            </div>
            <div class="ml-3 flex-1">
              <div class="flex items-center">
                <svg class="w-5 h-5 text-gray-400 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="<%= type[:icon] %>"></path>
                </svg>
                <span class="text-sm font-medium text-gray-900 dark:text-white"><%= type[:label] %></span>
              </div>
              <p class="text-xs text-gray-500 dark:text-gray-400 mt-1"><%= type[:description] %></p>
            </div>
          </label>
        <% end %>
      </div>
    </div>
  </div>

  <!-- Date Range Configuration -->
  <div class="col-span-1">
    <label class="block text-sm font-medium leading-6 text-gray-900 dark:text-gray-300 mb-2">
      Default Date Range
    </label>
    <select name="data_source[config][date_range]"
            class="block w-full rounded-md border-0 py-2.5 px-3 text-gray-900 dark:text-gray-100 shadow-sm ring-1 ring-inset ring-gray-300 dark:ring-gray-600 bg-white dark:bg-gray-700 focus:ring-2 focus:ring-inset focus:ring-indigo-600 sm:text-sm">
      <% date_ranges = [
        { value: '7days', label: 'Last 7 days' },
        { value: '30days', label: 'Last 30 days' },
        { value: '90days', label: 'Last 90 days' },
        { value: 'month', label: 'Current month' },
        { value: 'quarter', label: 'Current quarter' },
        { value: 'year', label: 'Current year' }
      ] %>
      <% date_ranges.each do |range| %>
        <option value="<%= range[:value] %>" <%= 'selected' if data_source.configuration.dig('date_range') == range[:value] || (data_source.new_record? && range[:value] == '30days') %>>
          <%= range[:label] %>
        </option>
      <% end %>
    </select>
    <p class="mt-2 text-sm text-gray-500 dark:text-gray-400">
      Default time period for syncing analytics data (can be customized per extraction)
    </p>
  </div>

  <!-- Advanced Options -->
  <div class="col-span-1">
    <details class="group">
      <summary class="flex items-center justify-between cursor-pointer list-none p-4 bg-gray-50 dark:bg-gray-700 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-600 transition-colors duration-200">
        <span class="text-sm font-medium text-gray-900 dark:text-white flex items-center">
          <svg class="w-5 h-5 mr-2 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path>
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
          </svg>
          Advanced Metrics & Dimensions
        </span>
        <svg class="w-5 h-5 text-gray-500 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
        </svg>
      </summary>

      <div class="mt-4 space-y-4 p-4 border border-gray-200 dark:border-gray-600 rounded-lg">
        <!-- Custom Metrics -->
        <div>
          <label class="block text-sm font-medium text-gray-900 dark:text-gray-300 mb-2">
            Additional Metrics (optional)
          </label>
          <textarea name="data_source[config][custom_metrics]"
                    rows="3"
                    placeholder="Enter additional GA4 metric names (one per line)&#10;Example: eventCount&#10;Example: itemRevenue"
                    class="block w-full rounded-md border-0 py-2 px-3 text-gray-900 dark:text-gray-100 shadow-sm ring-1 ring-inset ring-gray-300 dark:ring-gray-600 bg-white dark:bg-gray-700 placeholder:text-gray-400 focus:ring-2 focus:ring-inset focus:ring-indigo-600 sm:text-sm"><%= data_source.configuration.dig('custom_metrics')&.join("\n") %></textarea>
          <p class="mt-1 text-xs text-gray-500 dark:text-gray-400">
            Add custom GA4 metrics beyond the default set (one per line)
          </p>
        </div>

        <!-- Custom Dimensions -->
        <div>
          <label class="block text-sm font-medium text-gray-900 dark:text-gray-300 mb-2">
            Additional Dimensions (optional)
          </label>
          <textarea name="data_source[config][custom_dimensions]"
                    rows="3"
                    placeholder="Enter additional GA4 dimension names (one per line)&#10;Example: browser&#10;Example: operatingSystem"
                    class="block w-full rounded-md border-0 py-2 px-3 text-gray-900 dark:text-gray-100 shadow-sm ring-1 ring-inset ring-gray-300 dark:ring-gray-600 bg-white dark:bg-gray-700 placeholder:text-gray-400 focus:ring-2 focus:ring-inset focus:ring-indigo-600 sm:text-sm"><%= data_source.configuration.dig('custom_dimensions')&.join("\n") %></textarea>
          <p class="mt-1 text-xs text-gray-500 dark:text-gray-400">
            Add custom GA4 dimensions beyond the default set (one per line)
          </p>
        </div>

        <!-- Realtime Data -->
        <div>
          <label class="flex items-center cursor-pointer">
            <input type="checkbox"
                   name="data_source[config][include_realtime]"
                   value="true"
                   <%= 'checked' if data_source.configuration.dig('include_realtime') == true %>
                   class="h-4 w-4 rounded border-gray-300 text-indigo-600 focus:ring-indigo-600">
            <span class="ml-3 text-sm text-gray-900 dark:text-white">Include realtime data</span>
          </label>
          <p class="ml-7 mt-1 text-xs text-gray-500 dark:text-gray-400">
            Fetch current active users and realtime events (updates more frequently)
          </p>
        </div>

        <!-- Sampling Rate -->
        <div>
          <label class="block text-sm font-medium text-gray-900 dark:text-gray-300 mb-2">
            Sampling threshold
          </label>
          <select name="data_source[config][sampling_level]"
                  class="block w-full rounded-md border-0 py-2 px-3 text-gray-900 dark:text-gray-100 shadow-sm ring-1 ring-inset ring-gray-300 dark:ring-gray-600 bg-white dark:bg-gray-700 focus:ring-2 focus:ring-inset focus:ring-indigo-600 sm:text-sm">
            <% sampling_levels = [
              { value: 'DEFAULT', label: 'Default (balanced)' },
              { value: 'SMALL', label: 'Small (faster, may use sampling)' },
              { value: 'LARGE', label: 'Large (slower, higher precision)' }
            ] %>
            <% sampling_levels.each do |level| %>
              <option value="<%= level[:value] %>" <%= 'selected' if data_source.configuration.dig('sampling_level') == level[:value] || (data_source.new_record? && level[:value] == 'DEFAULT') %>>
                <%= level[:label] %>
              </option>
            <% end %>
          </select>
          <p class="mt-1 text-xs text-gray-500 dark:text-gray-400">
            Trade-off between query speed and data precision for large datasets
          </p>
        </div>
      </div>
    </details>
  </div>

  <!-- Help Text -->
  <div class="col-span-1">
    <div class="bg-gray-50 dark:bg-gray-800 rounded-lg p-4 border border-gray-200 dark:border-gray-700">
      <h5 class="text-sm font-medium text-gray-900 dark:text-white mb-2 flex items-center">
        <svg class="w-4 h-4 mr-2 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
        </svg>
        Google Analytics 4 Integration Requirements
      </h5>
      <ul class="text-xs text-gray-600 dark:text-gray-400 space-y-1 list-disc list-inside">
        <li>Google Analytics 4 (GA4) property (not Universal Analytics)</li>
        <li>Editor or Administrator role on the GA4 property</li>
        <li>Google Analytics Data API enabled in Google Cloud Console</li>
        <li>OAuth 2.0 authentication with automatic token refresh</li>
        <li>Rate limit: 25,000 API tokens per day per project</li>
        <li>Max 10,000 rows per API request with automatic pagination</li>
      </ul>
      <div class="mt-3 pt-3 border-t border-gray-200 dark:border-gray-600">
        <a href="https://developers.google.com/analytics/devguides/reporting/data/v1"
           target="_blank"
           rel="noopener noreferrer"
           class="text-xs text-indigo-600 dark:text-indigo-400 hover:text-indigo-500 flex items-center">
          <svg class="w-3 h-3 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
          </svg>
          Google Analytics Data API Documentation
        </a>
      </div>
    </div>
  </div>
</div>
