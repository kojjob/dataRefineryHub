<% content_for :page_title, "Integration Marketplace" %>
<% content_for :page_subtitle, "Connect with 200+ business tools and data sources" %>

<div class="px-df-32 py-df-24">
  <!-- Search Bar -->
  <div class="mb-df-32">
    <div class="flex gap-df-8 max-w-2xl">
      <input type="text" 
             class="form-control flex-1" 
             placeholder="Search integrations..."
             data-controller="search"
             data-action="input->search#filter">
      <%= link_to new_data_source_path, class: "btn btn--primary" do %>
        <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
        </svg>
        Add Integration
      <% end %>
    </div>
  </div>

  <!-- Integration Status Cards -->
  <div class="grid grid-cols-1 md:grid-cols-4 gap-df-20 mb-df-32">
    <%= render Dataflow::MetricCardComponent.new(
      icon: "✅",
      title: "Connected",
      value: @connected_sources.count,
      change: "Active integrations"
    ) %>
    
    <%= render Dataflow::MetricCardComponent.new(
      icon: "🔄",
      title: "Syncing",
      value: @syncing_sources.count,
      change: "Currently processing"
    ) %>
    
    <%= render Dataflow::MetricCardComponent.new(
      icon: "⚠️",
      title: "Errors",
      value: @error_sources.count,
      change: "Need attention",
      change_type: :negative
    ) %>
    
    <%= render Dataflow::MetricCardComponent.new(
      icon: "🔌",
      title: "Disconnected",
      value: @disconnected_sources.count,
      change: "Inactive"
    ) %>
  </div>

  <!-- Connected Integrations -->
  <div class="bg-df-surface rounded-df-lg p-df-24 border border-df-card-border mb-df-32">
    <h2 class="text-df-2xl font-semibold mb-df-20">Your Integrations</h2>
    
    <% if @data_sources.any? %>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-df-20">
        <% @data_sources.each do |data_source| %>
          <div class="bg-df-background rounded-df-lg p-df-20 border border-df-border hover:shadow-df-md transition-shadow">
            <div class="flex items-start justify-between mb-df-16">
              <div class="flex items-center gap-df-12">
                <div class="w-12 h-12 rounded-df-md bg-df-primary text-white flex items-center justify-center text-xl font-semibold">
                  <%= data_source.source_type.first(2).upcase %>
                </div>
                <div>
                  <h3 class="text-df-lg font-semibold"><%= data_source.name %></h3>
                  <p class="text-df-sm text-df-text-secondary"><%= data_source.source_type.humanize %></p>
                </div>
              </div>
              <span class="px-df-12 py-df-4 rounded-df-sm text-df-xs font-medium <%= case data_source.status
                when 'connected' then 'bg-green-100 text-green-800'
                when 'syncing' then 'bg-blue-100 text-blue-800'
                when 'error' then 'bg-red-100 text-red-800'
                else 'bg-gray-100 text-gray-800'
              end %>">
                <%= data_source.status.humanize %>
              </span>
            </div>
            
            <div class="space-y-df-8 mb-df-16">
              <div class="flex justify-between text-df-sm">
                <span class="text-df-text-secondary">Last Sync</span>
                <span class="font-medium">
                  <%= data_source.extraction_jobs.successful.last&.completed_at ? 
                      time_ago_in_words(data_source.extraction_jobs.successful.last.completed_at) + " ago" : 
                      "Never" %>
                </span>
              </div>
              <div class="flex justify-between text-df-sm">
                <span class="text-df-text-secondary">Records</span>
                <span class="font-medium"><%= number_with_delimiter(data_source.raw_data_records.count) %></span>
              </div>
            </div>
            
            <div class="flex gap-df-8">
              <%= link_to "View Details", data_source_path(data_source), class: "btn btn--outline btn--sm flex-1" %>
              <% if data_source.status == 'connected' %>
                <%= button_to "Sync Now", sync_now_data_source_path(data_source), 
                    method: :post, 
                    class: "btn btn--primary btn--sm flex-1",
                    data: { turbo_method: :post } %>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="text-center py-df-32">
        <div class="mx-auto w-24 h-24 bg-df-secondary rounded-full flex items-center justify-center mb-df-16">
          <svg class="w-12 h-12 text-df-text-secondary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4"></path>
          </svg>
        </div>
        <h3 class="text-df-xl font-semibold mb-df-8">No integrations yet</h3>
        <p class="text-df-text-secondary mb-df-20">Connect your first data source to start syncing</p>
        <%= link_to new_data_source_path, class: "btn btn--primary" do %>
          <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
          </svg>
          Add Your First Integration
        <% end %>
      </div>
    <% end %>
  </div>

  <!-- Available Integrations -->
  <div class="bg-df-surface rounded-df-lg p-df-24 border border-df-card-border">
    <h2 class="text-df-2xl font-semibold mb-df-20">Popular Integrations</h2>
    
    <div class="grid grid-cols-1 md:grid-cols-3 gap-df-20">
      <% [
        { title: "CRM & Sales", count: 45, connectors: ["Salesforce", "HubSpot", "Pipedrive", "Zoho CRM"], color: "blue" },
        { title: "Marketing & Analytics", count: 38, connectors: ["Google Analytics", "Facebook Ads", "Mailchimp", "Klaviyo"], color: "purple" },
        { title: "Accounting & Finance", count: 32, connectors: ["QuickBooks", "Xero", "Stripe", "PayPal"], color: "green" },
        { title: "E-commerce", count: 28, connectors: ["Shopify", "WooCommerce", "Amazon", "eBay"], color: "orange" },
        { title: "Support & Service", count: 22, connectors: ["Zendesk", "Intercom", "Freshdesk", "ServiceNow"], color: "red" },
        { title: "Productivity", count: 18, connectors: ["Slack", "Teams", "Asana", "Trello"], color: "indigo" }
      ].each do |category| %>
        <div class="bg-df-background rounded-df-lg p-df-20 border border-df-border hover:shadow-df-md transition-shadow">
          <div class="flex items-center justify-between mb-df-16">
            <h3 class="text-df-xl font-semibold"><%= category[:title] %></h3>
            <span class="text-df-sm text-df-text-secondary"><%= category[:count] %> connectors</span>
          </div>
          <div class="flex flex-wrap gap-df-8 mb-df-16">
            <% category[:connectors].each do |connector| %>
              <span class="px-df-12 py-df-6 bg-<%= category[:color] %>-100 text-<%= category[:color] %>-800 rounded-df-sm text-df-sm font-medium">
                <%= connector %>
              </span>
            <% end %>
          </div>
          <button class="btn btn--outline btn--sm btn--full-width">View All →</button>
        </div>
      <% end %>
    </div>
  </div>
</div>