<% content_for :title, "Data Sources" %>

<!-- Modern Data Sources Container with Real-time Updates -->
<div data-controller="data-sources-realtime" class="min-h-screen bg-gradient-to-br from-slate-50 via-blue-50/30 to-indigo-50/20">
  
  <!-- Enhanced Header Section -->
  <div class="bg-gradient-to-r from-indigo-600 via-blue-600 to-purple-700 relative overflow-hidden">
    <div class="absolute inset-0 bg-black/10"></div>
    <div class="absolute inset-0 bg-gradient-to-r from-indigo-600/90 to-purple-700/90"></div>
    
    <!-- Decorative elements -->
    <div class="absolute top-0 left-0 w-full h-full">
      <div class="absolute top-10 left-10 w-32 h-32 bg-white/10 rounded-full blur-xl"></div>
      <div class="absolute top-32 right-20 w-24 h-24 bg-white/5 rounded-full blur-lg"></div>
      <div class="absolute bottom-20 left-1/4 w-40 h-40 bg-white/5 rounded-full blur-2xl"></div>
    </div>
    
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
      <div class="flex flex-col lg:flex-row items-center justify-between gap-8">
        <div class="flex items-center gap-6">
          <div class="h-20 w-20 rounded-3xl bg-gradient-to-br from-white/20 to-white/10 backdrop-blur-sm border border-white/20 flex items-center justify-center shadow-2xl">
            <svg class="h-10 w-10 text-white" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M20.25 6.375c0 2.278-3.694 4.125-8.25 4.125S3.75 8.653 3.75 6.375m16.5 0c0-2.278-3.694-4.125-8.25-4.125S3.75 4.097 3.75 6.375m16.5 0v11.25c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125V6.375m16.5 0v3.75m-16.5-3.75v3.75m16.5 0v3.75C20.25 18.653 16.556 20.5 12 20.5s-8.25-1.847-8.25-4.125v-3.75m16.5 0c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125" />
            </svg>
          </div>
          <div>
            <h1 class="text-4xl font-black text-white mb-2">Data Sources</h1>
            <p class="text-xl text-white/90">Connect, manage, and monitor your business data integrations</p>
          </div>
        </div>
        
        <div class="flex items-center gap-4">
          <%= link_to new_data_source_path, class: "group inline-flex items-center gap-3 px-8 py-4 bg-white/10 backdrop-blur-sm text-white font-bold rounded-2xl border border-white/20 hover:bg-white/20 transition-all duration-200 shadow-lg hover:shadow-xl transform hover:-translate-y-0.5" do %>
            <svg class="h-6 w-6 group-hover:rotate-90 transition-transform duration-300" fill="currentColor" viewBox="0 0 20 20">
              <path d="M10.75 4.75a.75.75 0 00-1.5 0v4.5h-4.5a.75.75 0 000 1.5h4.5v4.5a.75.75 0 001.5 0v-4.5h4.5a.75.75 0 000-1.5h-4.5v-4.5z" />
            </svg>
            Add Data Source
          <% end %>
          
          <button class="inline-flex items-center gap-3 px-6 py-3 bg-white/5 backdrop-blur-sm text-white/80 font-medium rounded-xl border border-white/10 hover:bg-white/10 hover:text-white transition-all duration-200" onclick="window.location.reload()">
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182m0-4.991v4.99" />
            </svg>
            Refresh
          </button>
        </div>
      </div>
    </div>
  </div>

  <!-- Main Content -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 -mt-8 relative z-10">

    <!-- Enhanced Stats Overview Cards -->
    <div class="grid grid-cols-1 gap-8 sm:grid-cols-2 xl:grid-cols-4 mb-12">
      
      <!-- Connected Sources Card -->
      <div class="group relative overflow-hidden rounded-3xl bg-gradient-to-br from-emerald-50 via-emerald-50/50 to-green-100/30 p-8 shadow-2xl border border-emerald-200/30 hover:shadow-emerald-200/50 hover:shadow-2xl hover:-translate-y-2 transition-all duration-500">
        <div class="absolute top-0 right-0 w-24 h-24 bg-gradient-to-br from-emerald-400/10 to-green-600/10 rounded-full blur-2xl transform translate-x-8 -translate-y-8"></div>
        <div class="absolute inset-0 bg-gradient-to-br from-emerald-500/5 to-green-600/10 opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
        
        <div class="relative">
          <div class="flex items-start justify-between mb-6">
            <div class="flex h-16 w-16 items-center justify-center rounded-2xl bg-gradient-to-br from-emerald-500 via-emerald-600 to-green-600 shadow-2xl shadow-emerald-500/25 group-hover:shadow-emerald-500/40 group-hover:scale-110 transition-all duration-500 ring-4 ring-emerald-100/50">
              <svg class="h-8 w-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.19 8.688a4.5 4.5 0 011.242 7.244l-4.5 4.5a4.5 4.5 0 01-6.364-6.364l1.757-1.757m13.35-.622l1.757-1.757a4.5 4.5 0 00-6.364-6.364l-4.5 4.5a4.5 4.5 0 001.242 7.244" />
              </svg>
            </div>
            <div class="flex items-center gap-2 px-3 py-2 bg-gradient-to-r from-emerald-100 to-green-100 text-emerald-700 text-xs font-bold rounded-2xl border border-emerald-200/50 shadow-lg">
              <div class="h-2 w-2 bg-emerald-500 rounded-full animate-pulse"></div>
              Active
            </div>
          </div>
          <div>
            <p class="text-sm font-bold text-emerald-700 uppercase tracking-wide mb-2">Connected</p>
            <p class="text-4xl font-black text-gray-900 mb-3 bg-gradient-to-r from-gray-900 to-gray-700 bg-clip-text text-transparent" data-data-sources-realtime-target="connectedCount"><%= @connected_sources.count %></p>
            <p class="text-sm text-gray-600 font-medium">Sources actively syncing</p>
          </div>
        </div>
      </div>

      <!-- Syncing Sources Card -->
      <div class="group relative overflow-hidden rounded-3xl bg-gradient-to-br from-blue-50 via-blue-50/50 to-indigo-100/30 p-8 shadow-2xl border border-blue-200/30 hover:shadow-blue-200/50 hover:shadow-2xl hover:-translate-y-2 transition-all duration-500">
        <div class="absolute top-0 right-0 w-24 h-24 bg-gradient-to-br from-blue-400/10 to-indigo-600/10 rounded-full blur-2xl transform translate-x-8 -translate-y-8"></div>
        <div class="absolute inset-0 bg-gradient-to-br from-blue-500/5 to-indigo-600/10 opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
        
        <div class="relative">
          <div class="flex items-start justify-between mb-6">
            <div class="flex h-16 w-16 items-center justify-center rounded-2xl bg-gradient-to-br from-blue-500 via-blue-600 to-indigo-600 shadow-2xl shadow-blue-500/25 group-hover:shadow-blue-500/40 group-hover:scale-110 transition-all duration-500 ring-4 ring-blue-100/50">
              <svg class="h-8 w-8 text-white animate-spin" fill="none" viewBox="0 0 24 24" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182m0-4.991v4.99" />
              </svg>
            </div>
            <div class="flex items-center gap-2 px-3 py-2 bg-gradient-to-r from-blue-100 to-indigo-100 text-blue-700 text-xs font-bold rounded-2xl border border-blue-200/50 shadow-lg">
              <div class="h-2 w-2 bg-blue-500 rounded-full animate-pulse"></div>
              Live
            </div>
          </div>
          <div>
            <p class="text-sm font-bold text-blue-700 uppercase tracking-wide mb-2">Syncing</p>
            <p class="text-4xl font-black text-gray-900 mb-3 bg-gradient-to-r from-gray-900 to-gray-700 bg-clip-text text-transparent" data-data-sources-realtime-target="syncingCount"><%= @syncing_sources.count %></p>
            <p class="text-sm text-gray-600 font-medium">Currently processing data</p>
          </div>
        </div>
      </div>

      <!-- Error Sources Card -->
      <div class="group relative overflow-hidden rounded-3xl bg-gradient-to-br from-red-50 via-red-50/50 to-rose-100/30 p-8 shadow-2xl border border-red-200/30 hover:shadow-red-200/50 hover:shadow-2xl hover:-translate-y-2 transition-all duration-500">
        <div class="absolute top-0 right-0 w-24 h-24 bg-gradient-to-br from-red-400/10 to-rose-600/10 rounded-full blur-2xl transform translate-x-8 -translate-y-8"></div>
        <div class="absolute inset-0 bg-gradient-to-br from-red-500/5 to-rose-600/10 opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
        
        <div class="relative">
          <div class="flex items-start justify-between mb-6">
            <div class="flex h-16 w-16 items-center justify-center rounded-2xl bg-gradient-to-br from-red-500 via-red-600 to-rose-600 shadow-2xl shadow-red-500/25 group-hover:shadow-red-500/40 group-hover:scale-110 transition-all duration-500 ring-4 ring-red-100/50">
              <svg class="h-8 w-8 text-white" fill="none" viewBox="0 0 24 24" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z" />
              </svg>
            </div>
            <div class="flex items-center gap-2 px-3 py-2 bg-gradient-to-r from-red-100 to-rose-100 text-red-700 text-xs font-bold rounded-2xl border border-red-200/50 shadow-lg">
              <div class="h-2 w-2 bg-red-500 rounded-full"></div>
              Alert
            </div>
          </div>
          <div>
            <p class="text-sm font-bold text-red-700 uppercase tracking-wide mb-2">Errors</p>
            <p class="text-4xl font-black text-gray-900 mb-3 bg-gradient-to-r from-gray-900 to-gray-700 bg-clip-text text-transparent" data-data-sources-realtime-target="errorCount"><%= @error_sources.count %></p>
            <p class="text-sm text-gray-600 font-medium">Sources requiring attention</p>
          </div>
        </div>
      </div>

      <!-- Total Sources Card -->
      <div class="group relative overflow-hidden rounded-3xl bg-gradient-to-br from-purple-50 via-purple-50/50 to-violet-100/30 p-8 shadow-2xl border border-purple-200/30 hover:shadow-purple-200/50 hover:shadow-2xl hover:-translate-y-2 transition-all duration-500">
        <div class="absolute top-0 right-0 w-24 h-24 bg-gradient-to-br from-purple-400/10 to-violet-600/10 rounded-full blur-2xl transform translate-x-8 -translate-y-8"></div>
        <div class="absolute inset-0 bg-gradient-to-br from-purple-500/5 to-violet-600/10 opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
        
        <div class="relative">
          <div class="flex items-start justify-between mb-6">
            <div class="flex h-16 w-16 items-center justify-center rounded-2xl bg-gradient-to-br from-purple-500 via-purple-600 to-violet-600 shadow-2xl shadow-purple-500/25 group-hover:shadow-purple-500/40 group-hover:scale-110 transition-all duration-500 ring-4 ring-purple-100/50">
              <svg class="h-8 w-8 text-white" fill="none" viewBox="0 0 24 24" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M20.25 6.375c0 2.278-3.694 4.125-8.25 4.125S3.75 8.653 3.75 6.375m16.5 0c0-2.278-3.694-4.125-8.25-4.125S3.75 4.097 3.75 6.375m16.5 0v11.25c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125V6.375m16.5 0v3.75m-16.5-3.75v3.75m16.5 0v3.75C20.25 18.653 16.556 20.5 12 20.5s-8.25-1.847-8.25-4.125v-3.75m16.5 0c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125" />
              </svg>
            </div>
            <div class="flex items-center gap-2 px-3 py-2 bg-gradient-to-r from-purple-100 to-violet-100 text-purple-700 text-xs font-bold rounded-2xl border border-purple-200/50 shadow-lg">
              <div class="h-2 w-2 bg-purple-500 rounded-full"></div>
              Total
            </div>
          </div>
          <div>
            <p class="text-sm font-bold text-purple-700 uppercase tracking-wide mb-2">Total Sources</p>
            <p class="text-4xl font-black text-gray-900 mb-3 bg-gradient-to-r from-gray-900 to-gray-700 bg-clip-text text-transparent" data-data-sources-realtime-target="totalCount"><%= @data_sources.count %></p>
            <p class="text-sm text-gray-600 font-medium">All configured integrations</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Enhanced Filter and Search Section -->
    <div class="mb-8">
      <div class="bg-gradient-to-br from-white to-gray-50/50 rounded-3xl shadow-2xl border border-gray-100/50 overflow-hidden">
        <div class="bg-gradient-to-r from-gray-50 to-white px-8 py-6 border-b border-gray-200/50">
          <div class="flex items-center gap-4">
            <div class="w-12 h-12 bg-gradient-to-r from-gray-500 to-gray-600 rounded-2xl flex items-center justify-center">
              <svg class="h-6 w-6 text-white" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 3c2.755 0 5.455.232 8.083.678.533.09.917.556.917 1.096v1.044a2.25 2.25 0 01-.659 1.591l-5.432 5.432a2.25 2.25 0 00-.659 1.591v2.927a2.25 2.25 0 01-1.244 2.013L9.75 21v-6.568a2.25 2.25 0 00-.659-1.591L3.659 7.409A2.25 2.25 0 013 5.818V4.774c0-.54.384-1.006.917-1.096A48.32 48.32 0 0112 3z" />
              </svg>
            </div>
            <div>
              <h3 class="text-xl font-black text-gray-900">Filter & Search</h3>
              <p class="text-sm text-gray-600 font-medium">Find and manage your data sources</p>
            </div>
          </div>
        </div>
        
        <div class="p-8">
          <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
            <!-- Search Input -->
            <div class="lg:col-span-2">
              <label class="block text-sm font-bold text-gray-900 mb-3">Search Sources</label>
              <div class="relative">
                <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                  <svg class="h-5 w-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 15.803a7.5 7.5 0 0010.607 0z" />
                  </svg>
                </div>
                <input type="text" placeholder="Search by name, platform, or status..." 
                       class="block w-full rounded-2xl border-0 py-4 pl-12 pr-4 text-gray-900 shadow-lg ring-1 ring-inset ring-gray-200 placeholder:text-gray-400 focus:ring-2 focus:ring-inset focus:ring-indigo-600 sm:text-sm sm:leading-6 bg-white/80 backdrop-blur-sm transition-all duration-200 hover:shadow-xl focus:shadow-xl"
                       data-data-sources-realtime-target="searchInput">
              </div>
            </div>
            
            <!-- Status Filter -->
            <div>
              <label class="block text-sm font-bold text-gray-900 mb-3">Filter by Status</label>
              <select class="block w-full rounded-2xl border-0 py-4 px-4 text-gray-900 shadow-lg ring-1 ring-inset ring-gray-200 focus:ring-2 focus:ring-inset focus:ring-indigo-600 sm:text-sm bg-white/80 backdrop-blur-sm transition-all duration-200 hover:shadow-xl focus:shadow-xl"
                      data-data-sources-realtime-target="statusFilter">
                <option value="">All Statuses</option>
                <option value="connected">Connected</option>
                <option value="syncing">Syncing</option>
                <option value="error">Error</option>
                <option value="disconnected">Disconnected</option>
              </select>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Enhanced Data Sources Grid -->
    <div data-data-sources-realtime-target="sourcesContainer">
      <% if @data_sources.any? %>
        <div class="grid grid-cols-1 gap-8 lg:grid-cols-2 xl:grid-cols-3">
          <% @data_sources.each do |data_source| %>
            <div class="group relative overflow-hidden rounded-3xl bg-gradient-to-br from-white to-gray-50/50 shadow-2xl border border-gray-100/50 hover:shadow-2xl hover:-translate-y-1 transition-all duration-500"
                 data-source-id="<%= data_source.id %>"
                 data-source-name="<%= data_source.name.downcase %>"
                 data-source-platform="<%= data_source.platform %>"
                 data-source-status="<%= data_source.status %>">
              
              <!-- Floating background decoration -->
              <div class="absolute top-0 right-0 w-32 h-32 bg-gradient-to-br <%= platform_gradient_class(data_source.platform) %> opacity-5 rounded-full blur-3xl transform translate-x-16 -translate-y-16"></div>
              <div class="absolute inset-0 bg-gradient-to-br <%= platform_gradient_class(data_source.platform) %> opacity-0 group-hover:opacity-5 transition-opacity duration-500"></div>
              
              <div class="relative p-8">
                <!-- Source Header -->
                <div class="flex items-start justify-between mb-6">
                  <div class="flex items-center gap-4">
                    <div class="relative">
                      <div class="h-16 w-16 rounded-2xl <%= platform_bg_class(data_source.platform) %> flex items-center justify-center shadow-2xl shadow-blue-500/25 group-hover:shadow-blue-500/40 group-hover:scale-110 transition-all duration-500 ring-4 ring-white/50">
                        <%= platform_icon(data_source.platform) %>
                      </div>
                      <div class="absolute -bottom-2 -right-2 w-8 h-8 <%= status_bg_class(data_source.status) %> rounded-full border-4 border-white flex items-center justify-center shadow-lg">
                        <%= status_icon(data_source.status) %>
                      </div>
                    </div>
                  </div>
                  
                  <div class="flex items-center gap-2 px-4 py-2 <%= status_badge_class(data_source.status) %> rounded-2xl border shadow-lg">
                    <div class="w-2 h-2 <%= status_indicator_class(data_source.status) %> rounded-full <%= 'animate-pulse' if data_source.status == 'syncing' %>"></div>
                    <span class="text-xs font-bold uppercase tracking-wide"><%= data_source.status %></span>
                  </div>
                </div>

                <!-- Source Details -->
                <div class="mb-6">
                  <h3 class="text-xl font-black text-gray-900 mb-2 group-hover:text-blue-600 transition-colors">
                    <%= link_to data_source.name, data_source_path(data_source), class: "hover:text-blue-600" %>
                  </h3>
                  <p class="text-sm text-gray-600 font-semibold mb-3 capitalize"><%= data_source.platform.humanize %></p>
                  
                  <!-- Metrics -->
                  <div class="grid grid-cols-2 gap-4">
                    <div class="bg-gray-50 rounded-xl p-3 border border-gray-200/50">
                      <div class="text-xs font-bold text-gray-500 uppercase tracking-wide mb-1">Records</div>
                      <div class="text-lg font-black text-gray-900"><%= number_with_delimiter(data_source.raw_data_records.count) %></div>
                    </div>
                    <div class="bg-gray-50 rounded-xl p-3 border border-gray-200/50">
                      <div class="text-xs font-bold text-gray-500 uppercase tracking-wide mb-1">Last Sync</div>
                      <div class="text-xs font-semibold text-gray-700">
                        <%= data_source.extraction_jobs.completed.last&.completed_at ? 
                            time_ago_in_words(data_source.extraction_jobs.completed.last.completed_at) + " ago" : 
                            "Never" %>
                      </div>
                    </div>
                  </div>
                </div>

                <!-- Action Buttons -->
                <div class="flex flex-wrap gap-3">
                  <% if data_source.status == 'connected' %>
                    <%= link_to sync_now_data_source_path(data_source), method: :post,
                        class: "group inline-flex items-center gap-2 px-4 py-3 bg-gradient-to-r from-blue-600 to-indigo-600 text-white font-bold rounded-xl shadow-lg hover:shadow-xl hover:from-blue-700 hover:to-indigo-700 transition-all duration-200 transform hover:scale-105",
                        data: { confirm: "Trigger manual sync for #{data_source.name}?" } do %>
                      <svg class="h-4 w-4 group-hover:animate-spin" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182m0-4.991v4.99" />
                      </svg>
                      Sync Now
                    <% end %>
                  <% end %>
                  
                  <%= link_to test_connection_data_source_path(data_source), method: :post,
                      class: "inline-flex items-center gap-2 px-4 py-3 bg-white text-gray-700 font-semibold rounded-xl shadow-lg border border-gray-200 hover:bg-gray-50 hover:shadow-xl transition-all duration-200 transform hover:scale-105" do %>
                    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M9.348 14.651a3.75 3.75 0 010-5.303m5.304 0a3.75 3.75 0 010 5.303m-7.425 2.122a6.75 6.75 0 010-9.546m9.546 0a6.75 6.75 0 010 9.546M5.106 18.894c3.808-3.808 9.98-3.808 13.788 0M12 12h.008v.008H12V12z" />
                    </svg>
                    Test
                  <% end %>
                  
                  <%= link_to edit_data_source_path(data_source),
                      class: "inline-flex items-center gap-2 px-4 py-3 bg-white text-gray-700 font-semibold rounded-xl shadow-lg border border-gray-200 hover:bg-gray-50 hover:shadow-xl transition-all duration-200 transform hover:scale-105" do %>
                    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0115.75 21H5.25A2.25 2.25 0 013 18.75V8.25A2.25 2.25 0 015.25 6H10" />
                    </svg>
                    Edit
                  <% end %>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <!-- Enhanced Empty State -->
        <div class="text-center py-20">
          <div class="relative mb-8">
            <div class="mx-auto h-32 w-32 rounded-3xl bg-gradient-to-br from-blue-100 via-indigo-100 to-purple-100 flex items-center justify-center shadow-2xl">
              <svg class="h-16 w-16 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M20.25 6.375c0 2.278-3.694 4.125-8.25 4.125S3.75 8.653 3.75 6.375m16.5 0c0-2.278-3.694-4.125-8.25-4.125S3.75 4.097 3.75 6.375m16.5 0v11.25c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125V6.375m16.5 0v3.75m-16.5-3.75v3.75m16.5 0v3.75C20.25 18.653 16.556 20.5 12 20.5s-8.25-1.847-8.25-4.125v-3.75m16.5 0c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125" />
              </svg>
            </div>
            <div class="absolute top-0 left-1/2 transform -translate-x-1/2 -translate-y-4">
              <div class="h-6 w-6 bg-yellow-400 rounded-full animate-bounce shadow-lg"></div>
            </div>
            <div class="absolute -top-2 -right-2 w-16 h-16 bg-blue-400/10 rounded-full blur-xl"></div>
            <div class="absolute -bottom-4 -left-4 w-20 h-20 bg-purple-400/10 rounded-full blur-2xl"></div>
          </div>
          
          <h3 class="text-3xl font-black text-gray-900 mb-4">No Data Sources Connected</h3>
          <p class="text-lg text-gray-600 mb-8 max-w-2xl mx-auto leading-relaxed">
            Connect your first data source to start building powerful data pipelines and unlock valuable insights from your business data.
          </p>
          
          <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <%= link_to new_data_source_path,
                class: "inline-flex items-center justify-center gap-3 px-8 py-4 bg-gradient-to-r from-blue-600 via-indigo-600 to-purple-600 text-white font-black rounded-2xl shadow-2xl hover:shadow-blue-500/25 transition-all duration-300 transform hover:-translate-y-1 hover:scale-105" do %>
              <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 20 20">
                <path d="M10.75 4.75a.75.75 0 00-1.5 0v4.5h-4.5a.75.75 0 000 1.5h4.5v4.5a.75.75 0 001.5 0v-4.5h4.5a.75.75 0 000-1.5h-4.5v-4.5z" />
              </svg>
              Connect Your First Data Source
            <% end %>
            
            <button class="inline-flex items-center justify-center gap-3 px-6 py-3 bg-white text-gray-700 font-semibold rounded-xl shadow-lg border border-gray-200 hover:bg-gray-50 hover:shadow-xl transition-all duration-200">
              <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.746 0 3.332.477 4.5 1.253v13C19.832 18.477 18.246 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
              </svg>
              View Documentation
            </button>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>