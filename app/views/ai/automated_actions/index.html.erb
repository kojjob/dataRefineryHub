  function updateStatusIndicators() {
    // Update real-time status indicators
    const statusIndicators = document.querySelectorAll('[data-status-indicator]');
    statusIndicators.forEach(indicator => {
      // Simulate real-time updates
      const isActive = Math.random() > 0.1; // 90% chance of being active
      if (isActive) {
        indicator.style.background = 'var(--color-success)';
      } else {
        indicator.style.background = 'var(--color-warning)';
      }
    });
