<script>
  // Analytics Design Interactive Features
  document.addEventListener('DOMContentLoaded', function() {
    // Category filter functionality with analytics design
    const categoryItems = document.querySelectorAll('[data-category-item]');
    categoryItems.forEach(item => {
      item.addEventListener('click', function() {
        // Remove active state from all items
        categoryItems.forEach(i => {
          i.style.background = 'linear-gradient(135deg, rgba(var(--color-primary-rgb), 0.02) 0%, rgba(var(--color-primary-rgb), 0.05) 100%)';
          i.style.borderColor = 'rgba(var(--color-border-rgb), 0.3)';
          i.style.transform = 'translateY(0)';
        });
        
        // Add active state to clicked item
        this.style.background = 'linear-gradient(135deg, rgba(var(--color-primary-rgb), 0.1) 0%, rgba(var(--color-primary-rgb), 0.15) 100%)';
        this.style.borderColor = 'rgba(var(--color-primary-rgb), 0.5)';
        this.style.transform = 'translateY(-2px)';
        this.style.boxShadow = '0 8px 25px rgba(var(--color-primary-rgb), 0.15)';
        
        // Filter actions based on category
        const category = this.dataset.categoryItem;
        filterActionsByCategory(category);
      });
    });

    // Status dropdown functionality
    const statusDropdown = document.querySelector('[data-status-dropdown]');
    if (statusDropdown) {
      statusDropdown.addEventListener('change', function() {
        const selectedStatus = this.value;
        filterActionsByStatus(selectedStatus);
      });
    }

    // Action button functionality (Edit, Pause/Resume, Delete)
    const actionButtons = document.querySelectorAll('[data-action-button]');
    actionButtons.forEach(button => {
      button.addEventListener('click', function(e) {
        e.preventDefault();
        const action = this.dataset.actionButton;
        const actionId = this.dataset.actionId;
        
        switch(action) {
          case 'pause':
          case 'resume':
            toggleActionStatus(this, actionId);
            break;
          case 'edit':
            editAction(actionId);
            break;
          case 'delete':
            deleteAction(actionId);
            break;
        }
      });
    });

    // Quick action buttons
    const quickActionButtons = document.querySelectorAll('[data-quick-action]');
    quickActionButtons.forEach(button => {
      button.addEventListener('click', function() {
        const action = this.dataset.quickAction;
        handleQuickAction(action);
      });
    });

    // Real-time status indicators
    updateStatusIndicators();
    setInterval(updateStatusIndicators, 30000); // Update every 30 seconds
  });

  // Filter functions
  function filterActionsByCategory(category) {
    const actionCards = document.querySelectorAll('[data-action-card]');
    actionCards.forEach(card => {
      const cardCategory = card.dataset.actionCategory;
      if (category === 'all' || cardCategory === category) {
        card.style.display = 'block';
        card.style.opacity = '1';
      } else {
        card.style.display = 'none';
        card.style.opacity = '0.5';
      }
    });
  }

  function filterActionsByStatus(status) {
    const actionCards = document.querySelectorAll('[data-action-card]');
    actionCards.forEach(card => {
      const cardStatus = card.dataset.actionStatus;
      if (status === 'all' || cardStatus === status) {
        card.style.display = 'block';
        card.style.opacity = '1';
      } else {
        card.style.display = 'none';
        card.style.opacity = '0.5';
      }
    });
  }

  // Action handlers
  function toggleActionStatus(button, actionId) {
    const currentAction = button.dataset.actionButton;
    const icon = button.querySelector('svg');
    const text = button.querySelector('span');
    
    if (currentAction === 'pause') {
      // Change to resume
      button.dataset.actionButton = 'resume';
      icon.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.828 14.828a4 4 0 01-5.656 0M9 10h1m4 0h1m-6 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>';
      text.textContent = 'Resume';
      
      // Update action card status
      const actionCard = button.closest('[data-action-card]');
      const statusBadge = actionCard.querySelector('[data-status-badge]');
      statusBadge.textContent = 'Paused';
      statusBadge.style.background = 'rgba(var(--color-warning-rgb), 0.1)';
      statusBadge.style.color = 'var(--color-warning)';
      statusBadge.style.borderColor = 'rgba(var(--color-warning-rgb), 0.2)';
    } else {
      // Change to pause
      button.dataset.actionButton = 'pause';
      icon.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 9v6m4-6v6m7-3a9 9 0 11-18 0 9 9 0 0118 0z"/>';
      text.textContent = 'Pause';
      
      // Update action card status
      const actionCard = button.closest('[data-action-card]');
      const statusBadge = actionCard.querySelector('[data-status-badge]');
      statusBadge.textContent = 'Active';
      statusBadge.style.background = 'rgba(var(--color-success-rgb), 0.1)';
      statusBadge.style.color = 'var(--color-success)';
      statusBadge.style.borderColor = 'rgba(var(--color-success-rgb), 0.2)';
    }
  }

