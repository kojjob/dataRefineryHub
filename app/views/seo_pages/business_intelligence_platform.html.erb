<% seo_meta_tags(@seo_data) %>
<% structured_data(:webapp, @seo_data) %>
<% structured_data(:breadcrumbs, @breadcrumbs + [{ name: "Business Intelligence Platform", url: @seo_data[:canonical_url] }]) %>
<% structured_data(:faq, @faqs) %>

<div class="min-h-screen bg-gradient-to-br from-blue-50 via-white to-indigo-50">
  
  <!-- Hero Section - Above the fold optimization -->
  <section class="relative overflow-hidden bg-gradient-to-r from-blue-600 to-indigo-700 text-white">
    <div class="absolute inset-0 bg-black/20"></div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 lg:py-32">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        
        <!-- Hero Content -->
        <div class="space-y-8">
          <!-- Breadcrumbs for SEO -->
          <nav class="text-blue-200 text-sm" aria-label="Breadcrumb">
            <ol class="flex space-x-2">
              <% @breadcrumbs.each_with_index do |crumb, index| %>
                <li class="flex items-center">
                  <%= link_to crumb[:name], crumb[:url], class: "hover:text-white transition-colors" %>
                  <% unless index == @breadcrumbs.length - 1 %>
                    <span class="mx-2">/</span>
                  <% end %>
                </li>
              <% end %>
              <li class="flex items-center">
                <span class="mx-2">/</span>
                <span class="text-white">Business Intelligence Platform</span>
              </li>
            </ol>
          </nav>

          <div>
            <h1 class="text-5xl lg:text-6xl font-bold leading-tight mb-6">
              <%= @hero_data[:headline] %>
            </h1>
            <p class="text-xl lg:text-2xl text-blue-100 leading-relaxed mb-8">
              <%= @hero_data[:subheadline] %>
            </p>
          </div>

          <!-- Key Features List -->
          <div class="grid sm:grid-cols-2 gap-4">
            <% @hero_data[:features].each do |feature| %>
              <div class="flex items-center space-x-3">
                <svg class="w-5 h-5 text-green-300 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                </svg>
                <span class="text-blue-100"><%= feature %></span>
              </div>
            <% end %>
          </div>

          <!-- CTA Buttons -->
          <div class="flex flex-col sm:flex-row gap-4">
            <%= link_to @hero_data[:cta_text], new_user_registration_path, 
                class: "inline-flex items-center justify-center px-8 py-4 text-lg font-semibold text-blue-700 bg-white rounded-lg hover:bg-blue-50 transition-all duration-200 shadow-lg hover:shadow-xl transform hover:-translate-y-1" %>
            <%= link_to "Watch 2-Min Demo", "#demo-video", 
                class: "inline-flex items-center justify-center px-8 py-4 text-lg font-semibold text-white border-2 border-white/30 rounded-lg hover:bg-white/10 transition-all duration-200" %>
          </div>

          <!-- Trust Signals -->
          <div class="flex items-center space-x-6 text-blue-200">
            <div class="flex items-center space-x-2">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
              <span>14-day free trial</span>
            </div>
            <div class="flex items-center space-x-2">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M2.166 4.999A11.954 11.954 0 0010 1.944 11.954 11.954 0 0017.834 5c.11.65.166 1.32.166 2.001 0 5.225-3.34 9.67-8 11.317C5.34 16.67 2 12.225 2 7c0-.682.057-1.35.166-2.001zm11.541 3.708a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
              </svg>
              <span>No credit card required</span>
            </div>
            <div class="flex items-center space-x-2">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd"/>
              </svg>
              <span>Setup in 15 minutes</span>
            </div>
          </div>
        </div>

        <!-- Hero Visual -->
        <div class="relative">
          <div class="bg-white/10 backdrop-blur-sm rounded-2xl p-8 shadow-2xl">
            <!-- Dashboard Mockup SVG -->
            <div class="dashboard-mockup bg-white rounded-lg shadow-xl p-6">
              <div class="dashboard-header flex items-center justify-between mb-6">
                <div class="flex items-center space-x-3">
                  <div class="w-3 h-3 bg-red-500 rounded-full"></div>
                  <div class="w-3 h-3 bg-yellow-500 rounded-full"></div>
                  <div class="w-3 h-3 bg-green-500 rounded-full"></div>
                </div>
                <div class="text-sm text-gray-600 font-medium">DataReflow Dashboard</div>
              </div>

              <div class="dashboard-content space-y-4">
                <!-- Metrics Row -->
                <div class="grid grid-cols-3 gap-4">
                  <div class="metric-card bg-gradient-to-r from-blue-50 to-blue-100 p-4 rounded-lg">
                    <div class="text-2xl font-bold text-blue-600">$2.4M</div>
                    <div class="text-sm text-gray-600">Revenue</div>
                    <div class="text-xs text-green-600">↗ +23%</div>
                  </div>
                  <div class="metric-card bg-gradient-to-r from-green-50 to-green-100 p-4 rounded-lg">
                    <div class="text-2xl font-bold text-green-600">1,847</div>
                    <div class="text-sm text-gray-600">Customers</div>
                    <div class="text-xs text-green-600">↗ +12%</div>
                  </div>
                  <div class="metric-card bg-gradient-to-r from-purple-50 to-purple-100 p-4 rounded-lg">
                    <div class="text-2xl font-bold text-purple-600">94.2%</div>
                    <div class="text-sm text-gray-600">Satisfaction</div>
                    <div class="text-xs text-green-600">↗ +5%</div>
                  </div>
                </div>

                <!-- Chart Area -->
                <div class="chart-area bg-gray-50 rounded-lg p-4 h-32">
                  <div class="flex items-end justify-between h-full space-x-2">
                    <div class="bg-blue-500 rounded-t" style="height: 60%;"></div>
                    <div class="bg-blue-500 rounded-t" style="height: 80%;"></div>
                    <div class="bg-blue-500 rounded-t" style="height: 45%;"></div>
                    <div class="bg-blue-500 rounded-t" style="height: 90%;"></div>
                    <div class="bg-blue-500 rounded-t" style="height: 70%;"></div>
                    <div class="bg-blue-500 rounded-t" style="height: 85%;"></div>
                    <div class="bg-blue-500 rounded-t" style="height: 95%;"></div>
                    <div class="bg-blue-500 rounded-t" style="height: 75%;"></div>
                  </div>
                </div>

                <!-- Data Table Preview -->
                <div class="table-preview bg-white border rounded-lg overflow-hidden">
                  <div class="bg-gray-50 px-4 py-2 border-b">
                    <div class="text-sm font-medium text-gray-700">Recent Transactions</div>
                  </div>
                  <div class="divide-y">
                    <div class="px-4 py-2 flex justify-between text-sm">
                      <span class="text-gray-600">Order #1234</span>
                      <span class="text-green-600 font-medium">$1,299</span>
                    </div>
                    <div class="px-4 py-2 flex justify-between text-sm">
                      <span class="text-gray-600">Order #1235</span>
                      <span class="text-green-600 font-medium">$899</span>
                    </div>
                    <div class="px-4 py-2 flex justify-between text-sm">
                      <span class="text-gray-600">Order #1236</span>
                      <span class="text-green-600 font-medium">$2,199</span>
                    </div>
                  </div>
                </div>
              </div>
            </div>

            <!-- Add some CSS for the dashboard mockup -->
            <style>
              .dashboard-mockup {
                animation: fadeInUp 0.8s ease-out;
              }

              .metric-card {
                transition: transform 0.2s ease;
              }

              .metric-card:hover {
                transform: translateY(-2px);
              }

              .chart-area > div > div {
                transition: all 0.3s ease;
                opacity: 0.8;
              }

              .chart-area:hover > div > div {
                opacity: 1;
              }

              .customer-logo {
                transition: all 0.3s ease;
              }

              .customer-logo:hover {
                background-color: #e5e7eb;
                transform: scale(1.05);
              }

              @keyframes fadeInUp {
                from {
                  opacity: 0;
                  transform: translateY(30px);
                }
                to {
                  opacity: 1;
                  transform: translateY(0);
                }
              }
            </style>
            
            <!-- Floating metrics cards for visual appeal -->
            <div class="absolute -top-4 -right-4 bg-green-500 text-white px-4 py-2 rounded-lg font-semibold shadow-lg">
              <span class="text-sm">Revenue</span>
              <div class="text-lg">↗️ +24%</div>
            </div>
            <div class="absolute -bottom-4 -left-4 bg-blue-500 text-white px-4 py-2 rounded-lg font-semibold shadow-lg">
              <span class="text-sm">New Customers</span>
              <div class="text-lg">🎯 147</div>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- Social Proof Section -->
  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold text-gray-900 mb-4">Trusted by 2,000+ Growing Businesses</h2>
        <p class="text-xl text-gray-600">Join companies that transformed their decision-making with DataReflow</p>
      </div>

      <!-- Customer Testimonials -->
      <div class="grid md:grid-cols-3 gap-8 mb-16">
        <% @testimonials.each do |testimonial| %>
          <div class="bg-gray-50 rounded-xl p-8 shadow-sm hover:shadow-md transition-shadow">
            <!-- Star Rating -->
            <div class="flex mb-4">
              <% testimonial[:rating].times do %>
                <svg class="w-5 h-5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                </svg>
              <% end %>
            </div>
            
            <blockquote class="text-gray-700 mb-6 text-lg leading-relaxed">
              "<%= testimonial[:text] %>"
            </blockquote>
            
            <div class="flex items-center">
              <div class="w-12 h-12 rounded-full mr-4 bg-gradient-to-br from-blue-500 to-indigo-600 flex items-center justify-center text-white font-bold text-sm">
                <%= testimonial[:author].split.map(&:first).join %>
              </div>
              <div>
                <div class="font-semibold text-gray-900"><%= testimonial[:author] %></div>
                <div class="text-gray-600"><%= testimonial[:title] %></div>
              </div>
            </div>
          </div>
        <% end %>
      </div>

      <!-- Company Logos -->
      <div class="border-t border-gray-200 pt-12">
        <p class="text-center text-gray-500 mb-8">Powering data decisions for companies like:</p>
        <div class="flex justify-center items-center space-x-12 opacity-60">
          <!-- Customer Logo Placeholders -->
          <div class="customer-logo h-12 w-24 bg-gray-200 rounded flex items-center justify-center">
            <span class="text-xs font-semibold text-gray-500">TechCorp</span>
          </div>
          <div class="customer-logo h-12 w-24 bg-gray-200 rounded flex items-center justify-center">
            <span class="text-xs font-semibold text-gray-500">DataFlow</span>
          </div>
          <div class="customer-logo h-12 w-24 bg-gray-200 rounded flex items-center justify-center">
            <span class="text-xs font-semibold text-gray-500">Analytics+</span>
          </div>
          <div class="customer-logo h-12 w-24 bg-gray-200 rounded flex items-center justify-center">
            <span class="text-xs font-semibold text-gray-500">InnovateCo</span>
          </div>
          <div class="customer-logo h-12 w-24 bg-gray-200 rounded flex items-center justify-center">
            <span class="text-xs font-semibold text-gray-500">GrowthLab</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Features Section -->
  <section class="py-20 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-4xl font-bold text-gray-900 mb-6">Complete Business Intelligence Platform</h2>
        <p class="text-xl text-gray-600 max-w-3xl mx-auto">Everything you need to transform raw data into actionable business insights. No technical expertise required.</p>
      </div>

      <div class="grid lg:grid-cols-3 gap-12">
        
        <!-- Feature 1: Data Connections -->
        <div class="text-center group">
          <div class="bg-blue-100 w-20 h-20 rounded-2xl flex items-center justify-center mx-auto mb-6 group-hover:bg-blue-200 transition-colors">
            <svg class="w-10 h-10 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"/>
            </svg>
          </div>
          <h3 class="text-2xl font-bold text-gray-900 mb-4">Connect Any Data Source</h3>
          <p class="text-gray-600 leading-relaxed mb-6">Integrate with 100+ tools including Shopify, Salesforce, Google Analytics, QuickBooks, and custom databases. Real-time sync keeps your data fresh.</p>
          <ul class="text-left space-y-2 text-gray-700">
            <li class="flex items-center">
              <span class="w-2 h-2 bg-blue-500 rounded-full mr-3"></span>
              100+ pre-built connectors
            </li>
            <li class="flex items-center">
              <span class="w-2 h-2 bg-blue-500 rounded-full mr-3"></span>
              Real-time data synchronization
            </li>
            <li class="flex items-center">
              <span class="w-2 h-2 bg-blue-500 rounded-full mr-3"></span>
              Custom API integrations
            </li>
          </ul>
        </div>

        <!-- Feature 2: Dashboards -->
        <div class="text-center group">
          <div class="bg-green-100 w-20 h-20 rounded-2xl flex items-center justify-center mx-auto mb-6 group-hover:bg-green-200 transition-colors">
            <svg class="w-10 h-10 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
            </svg>
          </div>
          <h3 class="text-2xl font-bold text-gray-900 mb-4">Beautiful Interactive Dashboards</h3>
          <p class="text-gray-600 leading-relaxed mb-6">Drag-and-drop dashboard builder creates stunning visualizations. Mobile-responsive design ensures insights are accessible anywhere.</p>
          <ul class="text-left space-y-2 text-gray-700">
            <li class="flex items-center">
              <span class="w-2 h-2 bg-green-500 rounded-full mr-3"></span>
              Visual dashboard builder
            </li>
            <li class="flex items-center">
              <span class="w-2 h-2 bg-green-500 rounded-full mr-3"></span>
              20+ chart types
            </li>
            <li class="flex items-center">
              <span class="w-2 h-2 bg-green-500 rounded-full mr-3"></span>
              Mobile-responsive design
            </li>
          </ul>
        </div>

        <!-- Feature 3: AI Insights -->
        <div class="text-center group">
          <div class="bg-purple-100 w-20 h-20 rounded-2xl flex items-center justify-center mx-auto mb-6 group-hover:bg-purple-200 transition-colors">
            <svg class="w-10 h-10 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
            </svg>
          </div>
          <h3 class="text-2xl font-bold text-gray-900 mb-4">AI-Powered Insights</h3>
          <p class="text-gray-600 leading-relaxed mb-6">Automated insights detect trends, anomalies, and opportunities. Smart alerts notify you of important changes in your business metrics.</p>
          <ul class="text-left space-y-2 text-gray-700">
            <li class="flex items-center">
              <span class="w-2 h-2 bg-purple-500 rounded-full mr-3"></span>
              Automatic trend detection
            </li>
            <li class="flex items-center">
              <span class="w-2 h-2 bg-purple-500 rounded-full mr-3"></span>
              Smart business alerts
            </li>
            <li class="flex items-center">
              <span class="w-2 h-2 bg-purple-500 rounded-full mr-3"></span>
              Predictive analytics
            </li>
          </ul>
        </div>

      </div>
    </div>
  </section>

  <!-- FAQ Section for SEO -->
  <section class="py-20 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-4xl font-bold text-gray-900 mb-6">Frequently Asked Questions</h2>
        <p class="text-xl text-gray-600">Everything you need to know about our business intelligence platform</p>
      </div>

      <div class="space-y-8">
        <% @faqs.each_with_index do |faq, index| %>
          <div class="border border-gray-200 rounded-xl p-8 hover:shadow-md transition-shadow">
            <h3 class="text-xl font-semibold text-gray-900 mb-4"><%= faq[:question] %></h3>
            <p class="text-gray-700 leading-relaxed"><%= faq[:answer] %></p>
          </div>
        <% end %>
      </div>

      <div class="text-center mt-12">
        <p class="text-gray-600 mb-4">Still have questions?</p>
        <%= link_to "Contact Our Team", "#contact", class: "inline-flex items-center text-blue-600 hover:text-blue-700 font-semibold" %>
      </div>
    </div>
  </section>

  <!-- Final CTA Section -->
  <section class="py-20 bg-gradient-to-r from-blue-600 to-indigo-700 text-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-4xl font-bold mb-6">Ready to Transform Your Business with Data?</h2>
      <p class="text-xl text-blue-100 mb-8 leading-relaxed">Join 2,000+ companies using DataReflow to make smarter, data-driven decisions. Start your free trial today.</p>
      
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <%= link_to "Start 14-Day Free Trial", new_user_registration_path, 
            class: "inline-flex items-center justify-center px-8 py-4 text-lg font-semibold text-blue-700 bg-white rounded-lg hover:bg-blue-50 transition-all duration-200 shadow-lg hover:shadow-xl transform hover:-translate-y-1" %>
        <%= link_to "Schedule Demo", "#demo", 
            class: "inline-flex items-center justify-center px-8 py-4 text-lg font-semibold text-white border-2 border-white/30 rounded-lg hover:bg-white/10 transition-all duration-200" %>
      </div>

      <div class="flex items-center justify-center space-x-8 mt-8 text-blue-200 text-sm">
        <span>✓ 14-day free trial</span>
        <span>✓ No credit card required</span>
        <span>✓ Cancel anytime</span>
      </div>
    </div>
  </section>

</div>