<% content_for :title, @user.name %>

<div class="min-h-screen bg-gradient-to-br from-gray-50 to-white">
  <!-- Header -->
  <div class="bg-gradient-to-r from-indigo-600 via-purple-600 to-blue-600 shadow-2xl">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <div class="flex items-center justify-between">
        <div class="flex items-center gap-4">
          <%= link_to users_path, class: "h-10 w-10 bg-white/20 rounded-xl flex items-center justify-center backdrop-blur-sm hover:bg-white/30 transition-all duration-200" do %>
            <svg class="h-5 w-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
            </svg>
          <% end %>
          <div class="h-16 w-16 bg-white/20 rounded-2xl flex items-center justify-center backdrop-blur-sm">
            <span class="text-white font-bold text-xl"><%= @user.name.first.upcase %></span>
          </div>
          <div>
            <h1 class="text-3xl font-bold text-white"><%= @user.name %></h1>
            <p class="text-indigo-100 mt-1"><%= @user.email %></p>
          </div>
        </div>
        
        <% if policy(@user).edit? %>
          <%= link_to edit_user_path(@user), class: "inline-flex items-center gap-2 bg-white/20 hover:bg-white/30 text-white font-semibold py-3 px-6 rounded-2xl transition-all duration-200 backdrop-blur-sm border border-white/20 hover:border-white/30" do %>
            <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
            </svg>
            Edit User
          <% end %>
        <% end %>
      </div>
    </div>
  </div>

  <!-- Content -->
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      <!-- User Information -->
      <div class="lg:col-span-2">
        <div class="bg-gradient-to-br from-white to-gray-50/50 rounded-3xl shadow-xl border border-gray-100/50 p-6">
          <div class="flex items-center gap-3 mb-6">
            <div class="h-10 w-10 bg-gradient-to-br from-indigo-500 to-purple-600 rounded-2xl flex items-center justify-center">
              <svg class="h-5 w-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
              </svg>
            </div>
            <h2 class="text-xl font-bold text-gray-900">User Information</h2>
          </div>
          
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
              <label class="block text-sm font-semibold text-gray-600 mb-2">Full Name</label>
              <p class="text-lg font-medium text-gray-900"><%= @user.name %></p>
            </div>
            
            <div>
              <label class="block text-sm font-semibold text-gray-600 mb-2">Email Address</label>
              <p class="text-lg font-medium text-gray-900"><%= @user.email %></p>
            </div>
            
            <div>
              <label class="block text-sm font-semibold text-gray-600 mb-2">Role</label>
              <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium <%= case @user.role
                when 'admin' then 'bg-purple-100 text-purple-800'
                when 'manager' then 'bg-blue-100 text-blue-800'
                else 'bg-gray-100 text-gray-800'
                end %>">
                <%= @user.role.humanize %>
              </span>
            </div>
            
            <div>
              <label class="block text-sm font-semibold text-gray-600 mb-2">Status</label>
              <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium <%= @user.confirmed_at? ? 'bg-green-100 text-green-800' : 'bg-yellow-100 text-yellow-800' %>">
                <%= @user.confirmed_at? ? 'Active' : 'Pending Confirmation' %>
              </span>
            </div>
            
            <div>
              <label class="block text-sm font-semibold text-gray-600 mb-2">Member Since</label>
              <p class="text-lg font-medium text-gray-900"><%= @user.created_at.strftime("%B %d, %Y") %></p>
            </div>
            
            <div>
              <label class="block text-sm font-semibold text-gray-600 mb-2">Last Sign In</label>
              <p class="text-lg font-medium text-gray-900">
                <%= @user.last_sign_in_at ? @user.last_sign_in_at.strftime("%B %d, %Y at %I:%M %p") : 'Never' %>
              </p>
            </div>
          </div>
        </div>
      </div>

      <!-- Actions & Stats -->
      <div class="space-y-6">
        <!-- Quick Actions -->
        <div class="bg-gradient-to-br from-white to-gray-50/50 rounded-3xl shadow-xl border border-gray-100/50 p-6">
          <div class="flex items-center gap-3 mb-4">
            <div class="h-8 w-8 bg-gradient-to-br from-green-500 to-blue-600 rounded-xl flex items-center justify-center">
              <svg class="h-4 w-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
              </svg>
            </div>
            <h3 class="text-lg font-bold text-gray-900">Quick Actions</h3>
          </div>
          
          <div class="space-y-3">
            <% if policy(@user).edit? %>
              <%= link_to edit_user_path(@user), class: "w-full inline-flex items-center justify-center gap-2 bg-gradient-to-r from-indigo-600 to-purple-600 hover:from-indigo-700 hover:to-purple-700 text-white font-semibold py-3 px-4 rounded-2xl transition-all duration-200 transform hover:scale-105" do %>
                <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                </svg>
                Edit Profile
              <% end %>
            <% end %>
            
            <% if policy(@user).change_role? && @user != current_user %>
              <%= form_with model: @user, url: change_role_user_path(@user), method: :patch, local: true, class: "w-full" do |form| %>
                <%= form.select :role, 
                    options_for_select([
                      ['Member', 'member'],
                      ['Manager', 'manager'],
                      ['Admin', 'admin']
                    ], @user.role),
                    {},
                    { 
                      class: "w-full px-3 py-2 border border-gray-300 rounded-xl text-sm mb-2",
                      onchange: "this.form.submit();"
                    } %>
              <% end %>
            <% end %>
            
            <% if policy(@user).destroy? && @user != current_user %>
              <%= link_to user_path(@user), 
                  method: :delete,
                  confirm: "Are you sure you want to remove #{@user.name} from the organization?",
                  class: "w-full inline-flex items-center justify-center gap-2 bg-white hover:bg-red-50 text-red-600 hover:text-red-700 font-semibold py-3 px-4 rounded-2xl border-2 border-red-200 hover:border-red-300 transition-all duration-200" do %>
                <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                </svg>
                Remove User
              <% end %>
            <% end %>
          </div>
        </div>

        <!-- User Stats -->
        <div class="bg-gradient-to-br from-white to-gray-50/50 rounded-3xl shadow-xl border border-gray-100/50 p-6">
          <div class="flex items-center gap-3 mb-4">
            <div class="h-8 w-8 bg-gradient-to-br from-orange-500 to-red-600 rounded-xl flex items-center justify-center">
              <svg class="h-4 w-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
              </svg>
            </div>
            <h3 class="text-lg font-bold text-gray-900">Activity Stats</h3>
          </div>
          
          <div class="space-y-4">
            <div class="flex items-center justify-between">
              <span class="text-sm font-medium text-gray-600">Sign-in Count</span>
              <span class="text-lg font-bold text-gray-900"><%= @user.sign_in_count || 0 %></span>
            </div>
            
            <div class="flex items-center justify-between">
              <span class="text-sm font-medium text-gray-600">Account Status</span>
              <span class="text-sm font-semibold <%= @user.confirmed_at? ? 'text-green-600' : 'text-yellow-600' %>">
                <%= @user.confirmed_at? ? 'Confirmed' : 'Unconfirmed' %>
              </span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>