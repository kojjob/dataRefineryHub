<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <!-- Back Link -->
  <%= link_to business_templates_path, class: "inline-flex items-center text-indigo-600 hover:text-indigo-500 mb-6" do %>
    <svg class="w-5 h-5 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
    </svg>
    Back to Templates
  <% end %>

  <!-- Template Header -->
  <div class="bg-gradient-to-r from-indigo-500 to-purple-600 rounded-xl p-8 text-white mb-8">
    <div class="text-6xl mb-4"><%= @template[:icon] %></div>
    <h1 class="text-4xl font-bold mb-4"><%= @template[:name] %> Template</h1>
    <p class="text-xl text-indigo-100"><%= @template[:description] %></p>
  </div>

  <!-- Main Content Grid -->
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
    <!-- Left Column - Features & Benefits -->
    <div class="lg:col-span-2 space-y-8">
      <!-- Key Features -->
      <div class="bg-white rounded-lg shadow p-6">
        <h2 class="text-2xl font-bold text-gray-900 mb-4">Key Features</h2>
        <div class="space-y-3">
          <% @template[:features].each do |feature| %>
            <div class="flex items-start">
              <svg class="h-6 w-6 text-green-500 mt-0.5 mr-3 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              <span class="text-gray-700"><%= feature %></span>
            </div>
          <% end %>
        </div>
      </div>

      <!-- Sample Insights -->
      <div class="bg-white rounded-lg shadow p-6">
        <h2 class="text-2xl font-bold text-gray-900 mb-4">Insights You'll Get</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <% @template[:sample_insights].each do |insight| %>
            <div class="flex items-start">
              <div class="flex-shrink-0 h-10 w-10 rounded-full bg-indigo-100 flex items-center justify-center">
                <svg class="h-6 w-6 text-indigo-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
              </div>
              <p class="ml-3 text-gray-700"><%= insight %></p>
            </div>
          <% end %>
        </div>
      </div>

      <!-- What's Included -->
      <div class="bg-white rounded-lg shadow p-6">
        <h2 class="text-2xl font-bold text-gray-900 mb-4">What's Included</h2>
        
        <div class="space-y-6">
          <!-- Dashboards -->
          <div>
            <h3 class="text-lg font-semibold text-gray-800 mb-2 flex items-center">
              <svg class="w-5 h-5 mr-2 text-indigo-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
              </svg>
              Pre-built Dashboards
            </h3>
            <ul class="list-disc list-inside space-y-1 text-gray-600 ml-7">
              <li>Executive Overview Dashboard</li>
              <li>Operations Dashboard</li>
              <li>Financial Performance Dashboard</li>
              <li>Customer Analytics Dashboard</li>
            </ul>
          </div>

          <!-- Reports -->
          <div>
            <h3 class="text-lg font-semibold text-gray-800 mb-2 flex items-center">
              <svg class="w-5 h-5 mr-2 text-indigo-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
              </svg>
              Automated Reports
            </h3>
            <ul class="list-disc list-inside space-y-1 text-gray-600 ml-7">
              <li>Daily Summary (Email/WhatsApp)</li>
              <li>Weekly Performance Report (PDF)</li>
              <li>Monthly Analysis (PowerPoint)</li>
              <li>Real-time Alerts (SMS/WhatsApp)</li>
            </ul>
          </div>

          <!-- AI Features -->
          <div>
            <h3 class="text-lg font-semibold text-gray-800 mb-2 flex items-center">
              <svg class="w-5 h-5 mr-2 text-indigo-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />
              </svg>
              AI-Powered Features
            </h3>
            <ul class="list-disc list-inside space-y-1 text-gray-600 ml-7">
              <li>Predictive Analytics</li>
              <li>Anomaly Detection</li>
              <li>Natural Language Queries</li>
              <li>Smart Recommendations</li>
            </ul>
          </div>
        </div>
      </div>
    </div>

    <!-- Right Column - Integrations & Actions -->
    <div class="space-y-8">
      <!-- Data Sources -->
      <div class="bg-white rounded-lg shadow p-6">
        <h3 class="text-lg font-semibold text-gray-900 mb-4">Included Integrations</h3>
        <div class="space-y-3">
          <% @template[:data_sources].each do |source| %>
            <div class="flex items-center p-3 bg-gray-50 rounded-lg">
              <svg class="w-5 h-5 text-green-500 mr-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
              </svg>
              <span class="text-gray-700"><%= source %></span>
            </div>
          <% end %>
        </div>
      </div>

      <!-- Apply Template -->
      <% if @applied_template.blank? && (current_user.organization_admin? || current_user.organization_owner?) %>
        <div class="bg-indigo-50 rounded-lg p-6">
          <h3 class="text-lg font-semibold text-gray-900 mb-2">Ready to Get Started?</h3>
          <p class="text-gray-600 mb-4">
            This template will automatically configure your account with all the integrations, dashboards, and reports shown.
          </p>
          
          <%= form_with url: apply_business_template_path(@template[:id]), method: :post, local: true do |f| %>
            <div class="mb-4">
              <label class="flex items-center">
                <%= check_box_tag :include_sample_data, '1', true, class: 'h-4 w-4 text-indigo-600 focus:ring-indigo-500 border-gray-300 rounded' %>
                <span class="ml-2 text-sm text-gray-700">Include sample data for testing</span>
              </label>
            </div>
            
            <%= f.submit "Apply #{@template[:name]} Template", 
                data: { turbo_confirm: "This will set up the #{@template[:name]} template. Continue?" },
                class: "w-full px-4 py-3 bg-indigo-600 text-white rounded-md hover:bg-indigo-700 transition-colors duration-200 font-medium" %>
          <% end %>
        </div>
      <% elsif @applied_template == @template[:id] %>
        <div class="bg-green-50 rounded-lg p-6">
          <h3 class="text-lg font-semibold text-green-900 mb-2">Template Active</h3>
          <p class="text-green-700 mb-4">
            This template is currently active for your organization.
          </p>
          <%= link_to "Go to Dashboard", dashboard_path, 
              class: "w-full inline-flex justify-center px-4 py-2 bg-green-600 text-white rounded-md hover:bg-green-700" %>
        </div>
      <% else %>
        <div class="bg-gray-50 rounded-lg p-6">
          <p class="text-gray-600 text-sm">
            Only organization administrators can apply templates.
          </p>
        </div>
      <% end %>

      <!-- Support -->
      <div class="bg-gray-50 rounded-lg p-6">
        <h3 class="text-lg font-semibold text-gray-900 mb-2">Need Help?</h3>
        <p class="text-gray-600 mb-4">
          Our team is here to help you get the most out of your template.
        </p>
        <div class="space-y-2">
          <%= link_to "#", class: "flex items-center text-indigo-600 hover:text-indigo-500" do %>
            <svg class="w-5 h-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
            </svg>
            View Documentation
          <% end %>
          <%= link_to "#", class: "flex items-center text-indigo-600 hover:text-indigo-500" do %>
            <svg class="w-5 h-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
            </svg>
            Contact Support
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>