            </svg>
            AI-Powered Features
          </h3>
          <div class="chart-controls">
            <span class="text-sm" style="color: var(--color-text-secondary);"><%= @template[:ai_features]&.count || 0 %> features</span>
          </div>
        </div>
        <div class="chart-wrapper">
          <div class="space-y-3">
            <% @template[:ai_features].each do |feature| %>
