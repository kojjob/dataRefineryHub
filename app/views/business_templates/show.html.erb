<!-- Premium CSS Animations and Dark Mode Enhancements -->
<style>
  @keyframes pulse {
    0%, 100% {
      opacity: 1;
    }
    50% {
      opacity: 0.5;
    }
  }

  /* Enhanced hover effects for template elements */
  .executive-template-details-header [onmouseover] {
    cursor: pointer;
  }

  /* Dark mode enhancements for glass morphism */
  @media (prefers-color-scheme: dark), [data-color-scheme="dark"] {
    /* Enhanced glass morphism for dark mode */
    .executive-template-details-header,
    .metric-card,
    .chart-container {
      background: linear-gradient(135deg, rgba(var(--color-surface-rgb), 0.9) 0%, rgba(var(--color-primary-rgb), 0.08) 100%) !important;
      border: 1px solid rgba(var(--color-border-rgb), 0.4) !important;
      box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3) !important;
    }

    /* Enhanced text contrast for dark mode */
    .executive-template-details-header h1,
    .metric-card h3,
    .chart-container h3 {
      color: var(--color-text) !important;
      text-shadow: 0 1px 2px rgba(0, 0, 0, 0.3);
    }

    /* Enhanced backdrop blur for dark mode */
    .executive-template-details-header,
    .metric-card,
    .chart-container {
      backdrop-filter: blur(24px) !important;
      -webkit-backdrop-filter: blur(24px) !important;
    }

    /* Enhanced status indicators for dark mode */
    .executive-template-details-header [style*="pulse"] {
      box-shadow: 0 0 8px rgba(var(--color-success-rgb), 0.6) !important;
    }

    /* Enhanced feature cards for dark mode */
    .chart-container .space-y-3 > div {
      background: linear-gradient(135deg, rgba(var(--color-surface-rgb), 0.8) 0%, rgba(var(--color-surface-rgb), 0.95) 100%) !important;
      border: 1px solid rgba(var(--color-border-rgb), 0.4) !important;
    }
  }

  /* Responsive design for template details */
  @media (max-width: 768px) {
    .executive-template-details-header > div {
      flex-direction: column !important;
      gap: var(--space-24) !important;
    }

    .executive-template-details-header h1 {
      font-size: var(--font-size-2xl) !important;
    }

    .metrics-grid {
      grid-template-columns: 1fr !important;
    }

    .charts-section {
      grid-template-columns: 1fr !important;
    }
  }
</style>