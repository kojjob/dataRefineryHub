<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <!-- Header -->
  <div class="text-center mb-12">
    <h1 class="text-4xl font-bold text-gray-900 mb-4">
      Get Started in Minutes with Industry Templates
    </h1>
    <p class="text-xl text-gray-600 max-w-3xl mx-auto">
      Pre-configured dashboards, integrations, and reports designed specifically for your business type. 
      No technical setup required.
    </p>
  </div>

  <% if @applied_template.present? %>
    <!-- Applied Template Notice -->
    <div class="mb-8 bg-green-50 border border-green-200 rounded-lg p-6">
      <div class="flex">
        <div class="flex-shrink-0">
          <svg class="h-5 w-5 text-green-400" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
          </svg>
        </div>
        <div class="ml-3">
          <h3 class="text-sm font-medium text-green-800">
            <%= @applied_template.humanize %> template is active
          </h3>
          <div class="mt-2 text-sm text-green-700">
            <p>Your organization is using the <%= @applied_template.humanize %> business template.</p>
          </div>
          <div class="mt-4">
            <%= link_to "Go to Dashboard", dashboard_path, class: "text-sm font-medium text-green-800 hover:text-green-700" %>
          </div>
        </div>
      </div>
    </div>
  <% end %>

  <!-- Templates Grid -->
  <div class="grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-3">
    <% @templates.each do |template| %>
      <div class="bg-white rounded-xl shadow-lg overflow-hidden hover:shadow-xl transition-shadow duration-300 <%= 'opacity-75' if @applied_template.present? %>">
        <!-- Template Header -->
        <div class="bg-gradient-to-r from-indigo-500 to-purple-600 p-6 text-white">
          <div class="text-5xl mb-3"><%= template[:icon] %></div>
          <h2 class="text-2xl font-bold mb-2"><%= template[:name] %></h2>
          <p class="text-indigo-100"><%= template[:description] %></p>
        </div>

        <!-- Features -->
        <div class="p-6">
          <h3 class="text-sm font-semibold text-gray-700 uppercase tracking-wide mb-3">
            Key Features
          </h3>
          <ul class="space-y-2 mb-6">
            <% template[:features].first(4).each do |feature| %>
              <li class="flex items-start">
                <svg class="h-5 w-5 text-green-500 mt-0.5 mr-2 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <span class="text-sm text-gray-600"><%= feature %></span>
              </li>
            <% end %>
          </ul>

          <!-- Data Sources -->
          <h3 class="text-sm font-semibold text-gray-700 uppercase tracking-wide mb-3">
            Integrations
          </h3>
          <div class="flex flex-wrap gap-2 mb-6">
            <% template[:data_sources].each do |source| %>
              <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800">
                <%= source %>
              </span>
            <% end %>
          </div>

          <!-- Action Buttons -->
          <div class="space-y-3">
            <%= link_to business_template_path(template[:id]), 
                class: "block w-full text-center px-4 py-2 border border-indigo-600 rounded-md text-indigo-600 hover:bg-indigo-50 transition-colors duration-200" do %>
              View Details
            <% end %>
            
            <% if @applied_template.blank? && (current_user.organization_admin? || current_user.organization_owner?) %>
              <%= button_to apply_business_template_path(template[:id]), 
                  method: :post,
                  params: { include_sample_data: true },
                  data: { 
                    turbo_confirm: "This will set up #{template[:name]} template with all integrations and dashboards. Continue?"
                  },
                  class: "w-full px-4 py-2 bg-indigo-600 text-white rounded-md hover:bg-indigo-700 transition-colors duration-200 font-medium" do %>
                Apply Template
              <% end %>
            <% end %>
          </div>
        </div>
      </div>
    <% end %>
  </div>

  <!-- Benefits Section -->
  <div class="mt-16 bg-gray-50 rounded-2xl p-8">
    <h2 class="text-2xl font-bold text-gray-900 text-center mb-8">
      Why Use Industry Templates?
    </h2>
    
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <div class="text-center">
        <div class="inline-flex items-center justify-center w-16 h-16 bg-indigo-100 rounded-full mb-4">
          <svg class="w-8 h-8 text-indigo-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
          </svg>
        </div>
        <h3 class="text-lg font-semibold text-gray-900 mb-2">Instant Setup</h3>
        <p class="text-gray-600">Pre-configured dashboards and reports ready in minutes, not weeks</p>
      </div>
      
      <div class="text-center">
        <div class="inline-flex items-center justify-center w-16 h-16 bg-indigo-100 rounded-full mb-4">
          <svg class="w-8 h-8 text-indigo-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </div>
        <h3 class="text-lg font-semibold text-gray-900 mb-2">Industry Best Practices</h3>
        <p class="text-gray-600">Metrics and KPIs that matter most for your specific business type</p>
      </div>
      
      <div class="text-center">
        <div class="inline-flex items-center justify-center w-16 h-16 bg-indigo-100 rounded-full mb-4">
          <svg class="w-8 h-8 text-indigo-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </div>
        <h3 class="text-lg font-semibold text-gray-900 mb-2">Proven ROI</h3>
        <p class="text-gray-600">Start seeing insights that drive revenue from day one</p>
      </div>
    </div>
  </div>

  <!-- CTA Section -->
  <% if @applied_template.blank? %>
    <div class="mt-12 text-center">
      <p class="text-gray-600 mb-4">
        Not sure which template to choose? Our team can help you select the perfect fit.
      </p>
      <%= link_to "Contact Support", "#", class: "inline-flex items-center px-6 py-3 border border-transparent text-base font-medium rounded-md text-white bg-gray-800 hover:bg-gray-700" %>
    </div>
  <% end %>
</div>