<!-- Final CTA Section -->
<section class="cta">
  <div class="container">
    <div class="cta__content">
      <h2 class="cta__title">Ready to Transform Your Data?</h2>
      <p class="cta__subtitle">Join 2,500+ businesses already using Data Reflow to drive growth</p>
      <div class="cta__actions">
        <%= link_to new_user_registration_path, class: "btn btn--primary btn--lg" do %>
          Start Free Trial
