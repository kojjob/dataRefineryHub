              class: "feature__img" %>
        </div>
        <div class="feature__content">
          <h3 class="feature__title">Industry-Specific Templates</h3>
          <p class="feature__description">Pre-configured solutions for retail, manufacturing, healthcare</p>
          <div class="feature__benefit">
            <span class="status status--success">Achieve ROI within 90 days of implementation</span>
          </div>
        </div>
      </div>

      <div class="feature">
        <div class="feature__image">
          <%= image_tag "https://pplx-res.cloudinary.com/image/upload/v1751974592/pplx_project_search_images/baa03939208b5a8dc02f49a2142cce50709294c8.jpg",
