<% content_for :title, "DataReflow - Transform Your Business Data Into Growth" %>

<div data-controller="landing-animation video-modal">

<!-- Hero Section - AI-Powered Real-Time Analytics -->
<section class="relative min-h-screen flex items-center justify-center bg-gradient-to-br from-blue-50 via-indigo-50 to-purple-50" 
         data-controller="real-time-analytics ai-insights" 
         data-real-time-analytics-endpoint-value="/api/v1/public/hero_stats">
  <!-- Animated background pattern -->
  <div class="absolute inset-0 overflow-hidden">
    <div class="absolute -top-40 -right-40 w-80 h-80 bg-gradient-to-br from-blue-400/20 to-purple-400/20 rounded-full blur-3xl animate-pulse"></div>
    <div class="absolute -bottom-40 -left-40 w-80 h-80 bg-gradient-to-tr from-indigo-400/20 to-pink-400/20 rounded-full blur-3xl animate-pulse delay-1000"></div>
  </div>
  
  <div class="relative z-10 max-w-7xl mx-auto px-6 lg:px-8">
    <div class="text-center mb-8">
      <!-- Logo and Brand -->
      <div class="flex items-center justify-center mb-8">
        <div class="flex h-14 w-14 items-center justify-center rounded-2xl bg-gradient-to-r from-blue-600 to-purple-600 shadow-xl">
          <svg class="h-8 w-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
          </svg>
        </div>
        <span class="ml-4 text-3xl font-bold bg-gradient-to-r from-gray-900 to-gray-700 bg-clip-text text-transparent">DataReflow</span>
      </div>

      <!-- AI Status Badge -->
      <div class="inline-flex items-center px-4 py-2 rounded-full bg-white/80 backdrop-blur-sm border border-green-200 mb-6 shadow-lg">
        <span data-target="real-time-analytics.status" class="inline-block w-2 h-2 bg-green-500 rounded-full mr-2 animate-pulse"></span>
        <span class="text-sm font-medium text-gray-700">AI Engine Online</span>
        <svg class="ml-2 h-4 w-4 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"></path>
        </svg>
      </div>

      <!-- Main Headline -->
      <h1 class="text-6xl md:text-7xl font-bold text-gray-900 mb-6 leading-[1.1] max-w-5xl mx-auto">
        AI-Powered Business Intelligence 
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-600 via-purple-600 to-indigo-600">In Real-Time</span>
      </h1>

      <!-- Subheadline -->
      <p class="text-xl md:text-2xl text-gray-600 mb-10 max-w-3xl mx-auto leading-relaxed">
        Connect 25+ business tools, get instant AI insights, and watch your metrics update live. 
        Transform data chaos into growth opportunities with zero technical expertise.
      </p>
    </div>

    <!-- Live Demo Dashboard Preview -->
    <div class="bg-white/70 backdrop-blur-sm rounded-3xl p-12 shadow-2xl border border-white/50 max-w-5xl mx-auto mb-12">
      <div class="flex items-center justify-between mb-6">
        <h3 class="text-lg font-semibold text-gray-900">Live Business Metrics</h3>
        <div class="flex items-center text-sm text-gray-500">
          <span data-target="real-time-analytics.lastUpdate">Updated 2 seconds ago</span>
          <div class="ml-2 w-2 h-2 bg-green-500 rounded-full animate-pulse"></div>
        </div>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-4 gap-6 mb-6">
        <div class="text-center p-4 bg-gradient-to-br from-green-50 to-emerald-50 rounded-2xl">
          <div class="text-3xl font-bold text-green-600 mb-2" data-target="real-time-analytics.metric" data-metric="revenue" data-format="currency">$127,584</div>
          <div class="text-gray-600 text-sm">Monthly Revenue</div>
          <div class="text-xs text-green-600 mt-1">↗ +12.3%</div>
        </div>
        <div class="text-center p-4 bg-gradient-to-br from-blue-50 to-indigo-50 rounded-2xl">
          <div class="text-3xl font-bold text-blue-600 mb-2" data-target="real-time-analytics.metric" data-metric="orders" data-format="number">1,247</div>
          <div class="text-gray-600 text-sm">Orders This Month</div>
          <div class="text-xs text-blue-600 mt-1">↗ +8.7%</div>
        </div>
        <div class="text-center p-4 bg-gradient-to-br from-purple-50 to-pink-50 rounded-2xl">
          <div class="text-3xl font-bold text-purple-600 mb-2" data-target="real-time-analytics.metric" data-metric="customers" data-format="number">3,421</div>
          <div class="text-gray-600 text-sm">Active Customers</div>
          <div class="text-xs text-purple-600 mt-1">↗ +5.2%</div>
        </div>
        <div class="text-center p-4 bg-gradient-to-br from-orange-50 to-red-50 rounded-2xl">
          <div class="text-3xl font-bold text-orange-600 mb-2" data-target="real-time-analytics.metric" data-metric="conversion" data-format="percentage">4.8</div>
          <div class="text-gray-600 text-sm">Conversion Rate</div>
          <div class="text-xs text-orange-600 mt-1">↗ +0.7%</div>
        </div>
      </div>

      <!-- AI Insights Preview -->
      <div class="bg-gradient-to-r from-blue-50 to-indigo-50 rounded-2xl p-4 border border-blue-200">
        <div class="flex items-center mb-3">
          <svg class="h-5 w-5 text-blue-600 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"></path>
          </svg>
          <span class="font-medium text-blue-900">AI Insight</span>
          <span class="ml-auto text-xs text-blue-600">97% confidence</span>
        </div>
        <p class="text-blue-800 text-sm">
          📈 Your mobile conversion rate is trending up 23% this week. Consider increasing mobile ad spend for maximum ROI.
        </p>
      </div>
    </div>

    <!-- CTA Buttons -->
    <div class="flex sm:flex-row gap-4 justify-center items-center mb-10">
      <%= link_to new_user_registration_path, class: "group inline-flex items-center px-8 py-4 bg-teal-600 text-white hover:bg-teal-700 font-semibold rounded-xl shadow-xl hover:shadow-2xl transform hover:-translate-y-1 transition-all duration-300" do %>
        Start Free Trial
        <svg class="ml-2 h-5 w-5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
        </svg>
      <% end %>
      
      <button data-controller="video-modal" 
              data-action="click->video-modal#open" 
              data-video-url="https://player.vimeo.com/video/ai-dashboard-demo"
              class="group inline-flex items-center px-8 py-4 bg-white/80 backdrop-blur-sm border-2 border-gray-200 text-gray-700 font-semibold rounded-xl shadow-lg hover:shadow-xl transform hover:-translate-y-1 transition-all duration-300">
        <svg class="mr-2 h-5 w-5 text-blue-600" fill="currentColor" viewBox="0 0 20 20">
          <path d="M6.3 2.841A1.5 1.5 0 004 4.11V15.89a1.5 1.5 0 002.3 1.269l9.344-5.89a1.5 1.5 0 000-2.538L6.3 2.84z"/>
        </svg>
        Watch AI Demo
        <span class="ml-2 text-sm text-gray-500">(2 min)</span>
      </button>
    </div>

    <!-- Trust Indicators -->
    <div class="flex flex-wrap justify-center items-center gap-8 text-sm text-gray-600">
      <div class="flex items-center bg-white/60 backdrop-blur-sm px-3 py-2 rounded-lg">
        <svg class="h-4 w-4 text-green-500 mr-2" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
        </svg>
        No Credit Card Required
      </div>
      <div class="flex items-center bg-white/60 backdrop-blur-sm px-3 py-2 rounded-lg">
        <svg class="h-4 w-4 text-green-500 mr-2" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
        </svg>
        14-Day Free Trial
      </div>
      <div class="flex items-center bg-white/60 backdrop-blur-sm px-3 py-2 rounded-lg">
        <svg class="h-4 w-4 text-green-500 mr-2" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
        </svg>
        AI Setup in 5 Minutes
      </div>
    </div>
  </div>
</section>

<!-- Trusted By Section - Fly.io Style -->
<section class="py-20 bg-gray-50">
  <div class="max-w-6xl mx-auto px-6 lg:px-8">
    <div class="text-center mb-12">
      <h2 class="text-lg font-semibold text-gray-900 mb-8">Trusted by teams at</h2>
    </div>
    
    <div class="grid grid-cols-2 md:grid-cols-5 gap-8 items-center justify-items-center">
      <div class="text-gray-400 font-semibold text-lg">Shopify</div>
      <div class="text-gray-400 font-semibold text-lg">QuickBooks</div>
      <div class="text-gray-400 font-semibold text-lg">HubSpot</div>
      <div class="text-gray-400 font-semibold text-lg">Mailchimp</div>
      <div class="text-gray-400 font-semibold text-lg">Stripe</div>
      <div class="text-gray-400 font-semibold text-lg">Salesforce</div>
      <div class="text-gray-400 font-semibold text-lg">Xero</div>
      <div class="text-gray-400 font-semibold text-lg">WooCommerce</div>
      <div class="text-gray-400 font-semibold text-lg">Zapier</div>
      <div class="text-gray-400 font-semibold text-lg">Airtable</div>
    </div>
  </div>
</section>

<!-- Stats Section - Simplified -->
<section class="py-20 bg-white">
  <div class="max-w-6xl mx-auto px-6 lg:px-8">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
      <div class="text-center">
        <div class="text-3xl md:text-4xl font-bold text-gray-900 mb-2"><%= @stats[:businesses_served] %></div>
        <div class="text-gray-600">Businesses Served</div>
      </div>
      <div class="text-center">
        <div class="text-3xl md:text-4xl font-bold text-gray-900 mb-2"><%= @stats[:data_processed] %></div>
        <div class="text-gray-600">Records Processed</div>
      </div>
      <div class="text-center">
        <div class="text-3xl md:text-4xl font-bold text-gray-900 mb-2"><%= @stats[:integrations] %></div>
        <div class="text-gray-600">Integrations</div>
      </div>
      <div class="text-center">
        <div class="text-3xl md:text-4xl font-bold text-gray-900 mb-2"><%= @stats[:uptime] %></div>
        <div class="text-gray-600">Uptime SLA</div>
      </div>
    </div>
  </div>
</section>

<!-- Features Section - AI & Real-Time Capabilities -->
<section id="features" class="py-24 bg-white">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="text-center mb-20">
      <h2 class="text-4xl md:text-5xl font-bold text-gray-900 mb-6">
        Everything You Need to <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-600 to-purple-600">Scale Your Business</span>
      </h2>
      <p class="text-xl text-gray-600 max-w-3xl mx-auto container">
        Stop drowning in disconnected data. DataReflow's AI engine transforms chaos into clarity with real-time insights and intelligent automation.
      </p>
    </div>

    <!-- Primary Features Grid -->
    <div class="grid md:grid-cols-3 gap-8 mb-16">
      <!-- Feature 1: Real-Time AI Insights -->
      <div class="group p-8 bg-gradient-to-br from-blue-50 to-indigo-50 rounded-3xl border border-blue-100 hover:shadow-xl transition-all duration-300">
        <div class="w-16 h-16 bg-gradient-to-r from-blue-600 to-indigo-600 rounded-2xl flex items-center justify-center mx-auto mb-6 group-hover:scale-110 transition-transform">
          <svg class="h-8 w-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"></path>
          </svg>
        </div>
        <h3 class="text-xl font-bold text-gray-900 mb-4 text-center">Real-Time AI Insights</h3>
        <p class="text-gray-600 leading-relaxed text-center mb-4">
          Our AI continuously analyzes your data to surface actionable insights. Get automatic alerts for opportunities, risks, and anomalies with confidence scores.
        </p>
        <div class="bg-white/80 rounded-lg p-3 text-xs text-blue-800">
          <strong>Live Example:</strong> "Revenue up 23% this week due to mobile traffic surge. Increase mobile ad spend for 34% ROI boost."
        </div>
      </div>

      <!-- Feature 2: Natural Language Queries -->
      <div class="group p-8 bg-gradient-to-br from-green-50 to-emerald-50 rounded-3xl border border-green-100 hover:shadow-xl transition-all duration-300" data-controller="natural-language-query">
        <div class="w-16 h-16 bg-gradient-to-r from-green-600 to-emerald-600 rounded-2xl flex items-center justify-center mx-auto mb-6 group-hover:scale-110 transition-transform">
          <svg class="h-8 w-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path>
          </svg>
        </div>
        <h3 class="text-xl font-bold text-gray-900 mb-4 text-center">Ask Questions in Plain English</h3>
        <p class="text-gray-600 leading-relaxed text-center mb-4">
          No more complex queries or SQL. Just ask "What products drive the most profit?" or "Which customers are likely to churn?" 
        </p>
        <div class="bg-white rounded-lg p-3 border border-gray-200">
          <input data-target="natural-language-query.input" 
                 type="text" 
                 placeholder="Which customers bought the most last month?"
                 class="w-full text-sm border-0 focus:ring-0 p-0 placeholder-gray-400"
                 readonly>
          <div class="flex justify-end mt-2">
            <button class="text-xs text-green-600 hover:text-green-700 font-medium">Try Demo →</button>
          </div>
        </div>
      </div>

      <!-- Feature 3: Live Metric Monitoring -->
      <div class="group p-8 bg-gradient-to-br from-purple-50 to-pink-50 rounded-3xl border border-purple-100 hover:shadow-xl transition-all duration-300" data-controller="real-time-analytics" data-real-time-analytics-endpoint-value="/api/v1/public/demo_metrics">
        <div class="w-16 h-16 bg-gradient-to-r from-purple-600 to-pink-600 rounded-2xl flex items-center justify-center mx-auto mb-6 group-hover:scale-110 transition-transform">
          <svg class="h-8 w-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path>
          </svg>
        </div>
        <h3 class="text-xl font-bold text-gray-900 mb-4 text-center">Live Metric Monitoring</h3>
        <p class="text-gray-600 leading-relaxed text-center mb-4">
          Watch your KPIs update in real-time with animated transitions. Set custom thresholds and get instant notifications when metrics change.
        </p>
        <div class="bg-white rounded-lg p-3 space-y-2">
          <div class="flex justify-between items-center">
            <span class="text-xs text-gray-600">Revenue Today</span>
            <span data-target="real-time-analytics.metric" data-metric="daily_revenue" data-format="currency" class="text-sm font-bold text-green-600">$8,247</span>
          </div>
          <div class="flex justify-between items-center">
            <span class="text-xs text-gray-600">Active Users</span>
            <span data-target="real-time-analytics.metric" data-metric="active_users" data-format="number" class="text-sm font-bold text-blue-600">2,341</span>
          </div>
          <div class="text-center">
            <span data-target="real-time-analytics.status" class="inline-block w-2 h-2 bg-green-500 rounded-full animate-pulse"></span>
            <span class="text-xs text-gray-500 ml-1">Live Updates</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Secondary Features Grid -->
    <div class="grid md:grid-cols-4 gap-6">
      <!-- 25+ Integrations -->
      <div class="text-center p-6 bg-gray-50 rounded-2xl hover:bg-white hover:shadow-lg transition-all duration-300">
        <div class="w-12 h-12 bg-orange-100 rounded-xl flex items-center justify-center mx-auto mb-4">
          <svg class="h-6 w-6 text-orange-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
          </svg>
        </div>
        <h4 class="font-bold text-gray-900 mb-2">25+ Integrations</h4>
        <p class="text-sm text-gray-600">Connect Shopify, QuickBooks, Google Analytics, and more in 5 minutes</p>
      </div>

      <!-- Industry Templates -->
      <div class="text-center p-6 bg-gray-50 rounded-2xl hover:bg-white hover:shadow-lg transition-all duration-300">
        <div class="w-12 h-12 bg-teal-100 rounded-xl flex items-center justify-center mx-auto mb-4">
          <svg class="h-6 w-6 text-teal-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path>
          </svg>
        </div>
        <h4 class="font-bold text-gray-900 mb-2">Industry Templates</h4>
        <p class="text-sm text-gray-600">Pre-built dashboards for e-commerce, SaaS, retail, and professional services</p>
      </div>

      <!-- Automated Pipelines -->
      <div class="text-center p-6 bg-gray-50 rounded-2xl hover:bg-white hover:shadow-lg transition-all duration-300">
        <div class="w-12 h-12 bg-indigo-100 rounded-xl flex items-center justify-center mx-auto mb-4">
          <svg class="h-6 w-6 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path>
          </svg>
        </div>
        <h4 class="font-bold text-gray-900 mb-2">Automated Pipelines</h4>
        <p class="text-sm text-gray-600">Self-healing data pipelines that handle failures and ensure data quality</p>
      </div>

      <!-- Enterprise Security -->
      <div class="text-center p-6 bg-gray-50 rounded-2xl hover:bg-white hover:shadow-lg transition-all duration-300">
        <div class="w-12 h-12 bg-red-100 rounded-xl flex items-center justify-center mx-auto mb-4">
          <svg class="h-6 w-6 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path>
          </svg>
        </div>
        <h4 class="font-bold text-gray-900 mb-2">Enterprise Security</h4>
        <p class="text-sm text-gray-600">SOC 2 compliant with end-to-end encryption and audit logs</p>
      </div>
    </div>

    <!-- Interactive Demo Showcase -->
    <div class="mt-32">
      <div class="text-center mb-12">
        <h3 class="text-3xl font-bold text-gray-900 mb-4">Experience DataReflow Live</h3>
        <p class="text-xl text-gray-600 max-w-3xl mx-auto container">
          Explore our platform with interactive demos, video walkthroughs, and live data visualizations
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-8">
        <!-- Interactive Dashboard Preview -->
        <div class="bg-white rounded-2xl p-6 shadow-lg hover:shadow-xl transition-all duration-300 border border-gray-100">
          <div class="w-12 h-12 bg-blue-100 rounded-xl flex items-center justify-center mb-4">
            <svg class="h-6 w-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
            </svg>
          </div>
          <h4 class="text-lg font-semibold text-gray-900 mb-3">Interactive Dashboard</h4>
          <p class="text-gray-600 mb-4 text-sm">
            Explore a live dashboard with real-time metrics, AI insights, and customizable widgets
          </p>
          <button data-controller="ai-landing-demo"
                  data-action="click->ai-landing-demo#showLiveDemo"
                  class="w-full px-4 py-2 bg-blue-600 text-white font-medium rounded-lg hover:bg-blue-700 transition-colors">
            Launch Dashboard Demo
          </button>
        </div>

        <!-- Video Walkthrough -->
        <div class="bg-white rounded-2xl p-6 shadow-lg hover:shadow-xl transition-all duration-300 border border-gray-100">
          <div class="w-12 h-12 bg-purple-100 rounded-xl flex items-center justify-center mb-4">
            <svg class="h-6 w-6 text-purple-600" fill="currentColor" viewBox="0 0 20 20">
