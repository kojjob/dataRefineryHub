          </div>
        </div>
      </div>

      <div class="feature">
        <div class="feature__image">
          <%= image_tag "https://pplx-res.cloudinary.com/image/upload/v1751974615/pplx_project_search_images/fada88565a328489e24ec6a72e46749c408f4059.jpg",
