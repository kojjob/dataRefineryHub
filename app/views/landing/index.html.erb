<% content_for :title, "Data Reflow - Enterprise-Grade Data Analytics for SMEs" %>

<div class="landing-page" data-controller="landing-animation video-modal professional-landing">

<!-- Hero Section -->
<section class="hero" id="hero">
  <div class="container">
    <div class="hero__content">
      <div class="hero__text">
        <h1 class="hero__title">Transform Raw Data into <span class="hero__highlight">Actionable Insights</span></h1>
        <p class="hero__subtitle">Enterprise-grade data analytics platform designed for SMEs. Reduce costs by 30%, increase efficiency by 40%, and achieve ROI within 90 days.</p>
        <div class="hero__actions">
          <%= link_to new_user_registration_path, class: "btn btn--primary btn--lg" do %>
            Start Free Trial
          <% end %>
          <button data-controller="video-modal"
                  data-action="click->video-modal#open"
                  data-video-url="https://player.vimeo.com/video/ai-dashboard-demo"
                  class="btn btn--outline btn--lg">Watch Demo</button>
        </div>
        <div class="hero__metrics">
          <div class="metric"
               data-controller="counter"
               data-counter-end-value="2500"
               data-counter-suffix-value="+"
               data-counter-duration-value="2500">
            <div class="metric__number" data-counter-target="number">0+</div>
            <div class="metric__label">Happy Customers</div>
          </div>
          <div class="metric"
               data-controller="counter"
               data-counter-end-value="200"
               data-counter-suffix-value="+"
               data-counter-duration-value="2000">
            <div class="metric__number" data-counter-target="number">0+</div>
            <div class="metric__label">Data Connectors</div>
          </div>
          <div class="metric"
               data-controller="counter"
               data-counter-end-value="99.9"
               data-counter-suffix-value="%"
               data-counter-duration-value="2200">
            <div class="metric__number" data-counter-target="number">0%</div>
            <div class="metric__label">Uptime</div>
          </div>
        </div>
      </div>
      <div class="hero__image">
        <%= image_tag "https://images.unsplash.com/photo-1676277757250-fa58fabe53d9?q=80&w=2075&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D",
            alt: "Business professionals discussing data analysis in a modern office",
            class: "hero__img" %>
      </div>
    </div>
  </div>
</section>

<!-- Customer Testimonials -->
<section class="testimonials" id="testimonials">
  <div class="container">
    <div class="section__header">
      <h2 class="section__title">Trusted by Industry Leaders</h2>
      <p class="section__subtitle">See how Data Reflow transforms businesses across industries</p>
    </div>
    <div class="testimonials__grid">
      <div class="testimonial card">
        <div class="testimonial__content">
          <div class="testimonial__quote">"Data Reflow helped us achieve 30% downtime reduction and £180,000 annual savings through predictive maintenance insights."</div>
          <div class="testimonial__metrics">
            <span class="status status--success">30% downtime reduction</span>
            <span class="status status--success">£180K savings</span>
          </div>
        </div>
        <div class="testimonial__author">
          <%= image_tag "https://pplx-res.cloudinary.com/image/upload/v1748926307/pplx_project_search_images/e2e6cf4d59964e317f722ecd462b509e51c55777.jpg",
              alt: "Sarah Mitchell",
              class: "testimonial__avatar" %>
          <div class="testimonial__info">
            <div class="testimonial__name">Sarah Mitchell</div>
            <div class="testimonial__title">Operations Director</div>
            <div class="testimonial__company">Precision Manufacturing Ltd</div>
          </div>
        </div>
      </div>

      <div class="testimonial card">
        <div class="testimonial__content">
          <div class="testimonial__quote">"Our inventory costs dropped 15% while sales increased 20% using Data Reflow's demand forecasting."</div>
          <div class="testimonial__metrics">
            <span class="status status--success">20% sales increase</span>
            <span class="status status--success">15% cost reduction</span>
          </div>
        </div>
        <div class="testimonial__author">
          <%= image_tag "https://pplx-res.cloudinary.com/image/upload/v1749474153/pplx_project_search_images/dc2bf7bf0e716e71b4003a216e89b6d552f94772.jpg",
              alt: "Marcus Thompson",
              class: "testimonial__avatar" %>
          <div class="testimonial__info">
            <div class="testimonial__name">Marcus Thompson</div>
            <div class="testimonial__title">CEO</div>
            <div class="testimonial__company">Thompson Retail Group</div>
          </div>
        </div>
      </div>

      <div class="testimonial card">
        <div class="testimonial__content">
          <div class="testimonial__quote">"Patient satisfaction improved 35% and operational efficiency increased 25% since implementing Data Reflow."</div>
          <div class="testimonial__metrics">
            <span class="status status--success">35% satisfaction improvement</span>
            <span class="status status--success">25% efficiency increase</span>
          </div>
        </div>
        <div class="testimonial__author">
          <%= image_tag "https://pplx-res.cloudinary.com/image/upload/v1750232273/pplx_project_search_images/292ad165b035215b0bb16757a46013612f8151d0.jpg",
              alt: "Dr. Emily Chen",
              class: "testimonial__avatar" %>
          <div class="testimonial__info">
            <div class="testimonial__name">Dr. Emily Chen</div>
            <div class="testimonial__title">Practice Manager</div>
            <div class="testimonial__company">City Health Partners</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ROI Infographic -->
<section class="roi-section" id="roi">
  <div class="container">
    <div class="roi__content">
      <div class="roi__text">
        <h2 class="roi__title">Proven ROI Within 90 Days</h2>
        <p class="roi__description">Our platform delivers measurable results that impact your bottom line immediately.</p>
        <div class="roi__stats">
          <div class="roi__stat"
               data-controller="counter"
               data-counter-end-value="700"
               data-counter-suffix-value="+"
               data-counter-separator-value=","
               data-counter-duration-value="2800">
            <div class="roi__number" data-counter-target="number">0+</div>
            <div class="roi__label">Hours Saved Annually</div>
          </div>
          <div class="roi__stat"
               data-controller="counter"
               data-counter-end-value="40"
               data-counter-suffix-value="%"
               data-counter-duration-value="2200">
            <div class="roi__number" data-counter-target="number">0%</div>
            <div class="roi__label">Efficiency Improvement</div>
          </div>
          <div class="roi__stat"
               data-controller="counter"
               data-counter-end-value="96"
               data-counter-suffix-value="%"
               data-counter-duration-value="2400">
            <div class="roi__number" data-counter-target="number">0%</div>
            <div class="roi__label">Prediction Accuracy</div>
          </div>
        </div>
      </div>
      <div class="roi__image">
        <%= image_tag "https://pplx-res.cloudinary.com/image/upload/v1748585409/pplx_project_search_images/452c2e234e28453101d2335434038dd4840494b1.jpg",
            alt: "ROI infographic showing marketing metrics",
            class: "roi__img" %>
      </div>
    </div>
  </div>
</section>

<!-- Dashboard Showcase -->
<section class="dashboard-showcase">
  <div class="container">
    <div class="section__header">
      <h2 class="section__title">Powerful Analytics at Your Fingertips</h2>
      <p class="section__subtitle">Comprehensive dashboards that transform complex data into clear, actionable insights</p>
    </div>
    <div class="dashboard__grid">
      <div class="dashboard__item">
        <%= image_tag "https://pplx-res.cloudinary.com/image/upload/v1748543733/pplx_project_search_images/5902d45e9097b4a100b1f6d2b6716ee6cff37267.jpg",
            alt: "Financial analytics dashboard",
            class: "dashboard__image" %>
        <div class="dashboard__content">
          <h3 class="dashboard__title">Financial Analytics</h3>
          <p class="dashboard__description">Track EBITDA, profit margins, and key financial KPIs in real-time</p>
        </div>
      </div>
      <div class="dashboard__item">
        <%= image_tag "https://pplx-res.cloudinary.com/image/upload/v1749118280/pplx_project_search_images/b252f304f04f8d42d0bee5d084cb2ed5a25c5c9c.jpg",
            alt: "HR workforce diversity dashboard",
            class: "dashboard__image" %>
        <div class="dashboard__content">
          <h3 class="dashboard__title">Workforce Analytics</h3>
          <p class="dashboard__description">Monitor diversity, performance, and organizational metrics</p>
        </div>
      </div>
      <div class="dashboard__item">
        <%= image_tag "https://pplx-res.cloudinary.com/image/upload/v1748571687/pplx_project_search_images/7f972c26b162f83776a783e7307748da3949bc63.jpg",
            alt: "Modern data analytics dashboard",
            class: "dashboard__image" %>
        <div class="dashboard__content">
          <h3 class="dashboard__title">Executive Dashboard</h3>
          <p class="dashboard__description">Comprehensive overview with interactive visualizations</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Features Section -->
