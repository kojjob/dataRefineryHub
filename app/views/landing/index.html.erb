<% content_for :title, "DataReflow - Autonomous AI Business Intelligence That Predicts and Prevents" %>

<div class="premium-landing" data-controller="ai-landing-demo interactive-dashboard live-metrics" data-ai-landing-demo-personalization-value="<%= @personalization.to_json.html_safe %>">

<!-- Premium AI-Powered Hero Section -->
<section class="relative min-h-screen flex items-center justify-center overflow-hidden" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
  <!-- Premium Animated Background Elements -->
  <div class="absolute inset-0">
    <!-- Floating geometric shapes -->
    <div class="absolute top-20 left-10 w-64 h-64 bg-gradient-to-r from-white/10 to-white/5 rounded-full mix-blend-overlay filter blur-xl premium-animate-float" style="animation-delay: 0s;"></div>
    <div class="absolute top-40 right-10 w-72 h-72 bg-gradient-to-r from-white/15 to-white/8 rounded-full mix-blend-overlay filter blur-xl premium-animate-float" style="animation-delay: 1s;"></div>
    <div class="absolute bottom-20 left-1/3 w-80 h-80 bg-gradient-to-r from-white/12 to-white/6 rounded-full mix-blend-overlay filter blur-xl premium-animate-float" style="animation-delay: 2s;"></div>

    <!-- Premium grid pattern overlay -->
    <div class="absolute inset-0 opacity-10">
      <svg width="100%" height="100%" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <pattern id="premium-grid" width="40" height="40" patternUnits="userSpaceOnUse">
            <path d="M 40 0 L 0 0 0 40" fill="none" stroke="white" stroke-width="1"/>
          </pattern>
        </defs>
        <rect width="100%" height="100%" fill="url(#premium-grid)" />
      </svg>
    </div>
  </div>

  <div class="relative z-10 premium-container">
    <div class="premium-grid premium-grid-lg-2 items-center gap-16">
      <!-- Premium Content Column -->
      <div class="text-center lg:text-left max-w-none lg:max-w-2xl">
        <!-- Premium AI Badge -->
        <div class="inline-flex items-center px-6 py-3 bg-white/20 backdrop-filter backdrop-blur-lg border border-white/30 rounded-full text-sm font-semibold text-white mb-8 premium-animate-pulse">
          <svg class="h-5 w-5 mr-3 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"></path>
          </svg>
          Powered by Autonomous AI
        </div>

        <!-- Premium Main Headline -->
        <h1 class="premium-heading-1 text-white mb-8 leading-tight">
          Business Intelligence
          <br>
          <span class="premium-gradient-text" style="background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">
            That Thinks Ahead
          </span>
        </h1>

        <!-- Premium Dynamic Subheadline -->
        <p class="premium-body-large text-white/90 mb-10 leading-relaxed max-w-2xl mx-auto lg:mx-0" data-ai-landing-demo-target="dynamicSubheadline">
          <%= case @personalization[:likely_business_type]
              when "ecommerce"
                "AI agent monitors your store 24/7, predicts revenue drops, and alerts you to opportunities before your competitors notice."
              when "saas"
                "Autonomous intelligence that predicts churn, identifies expansion opportunities, and optimizes your entire customer journey."
              when "agency"
                "AI-powered insights that help you deliver better client results and identify new revenue streams across all campaigns."
              else
                "The first truly autonomous business intelligence platform. AI monitors your business, predicts outcomes, and prevents problems before they happen."
              end %>
        </p>

        <!-- Premium Value Proposition Points -->
        <div class="flex flex-wrap gap-8 mb-12">
          <div class="flex items-center text-white/90">
            <div class="h-3 w-3 bg-gradient-to-r from-green-400 to-emerald-400 rounded-full mr-4 premium-animate-pulse"></div>
            <span class="font-semibold text-lg">Predicts Issues 2+ Weeks Early</span>
          </div>
          <div class="flex items-center text-white/90">
            <div class="h-3 w-3 bg-gradient-to-r from-blue-400 to-cyan-400 rounded-full mr-4 premium-animate-pulse" style="animation-delay: 0.5s;"></div>
            <span class="font-semibold text-lg">94.7% Prediction Accuracy</span>
          </div>
          <div class="flex items-center text-white/90">
            <div class="h-3 w-3 bg-gradient-to-r from-purple-400 to-pink-400 rounded-full mr-4 premium-animate-pulse" style="animation-delay: 1s;"></div>
            <span class="font-semibold text-lg">Setup in 15 Minutes</span>
          </div>
        </div>

        <!-- Premium Dynamic CTA -->
        <div class="flex flex-col sm:flex-row gap-6 items-center lg:items-start mb-12">
          <%= link_to new_user_registration_path,
              class: "premium-btn premium-btn-primary premium-btn-large group",
              data: { action: "click->ai-landing-demo#trackCTA" } do %>
            <span data-ai-landing-demo-target="primaryCTA"><%= @personalization[:primary_cta] %></span>
            <svg class="ml-3 h-5 w-5 group-hover:translate-x-1 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
            </svg>
          <% end %>

          <button class="premium-btn premium-btn-secondary premium-btn-large group"
                  style="background: rgba(255, 255, 255, 0.15); backdrop-filter: blur(10px); border: 2px solid rgba(255, 255, 255, 0.3); color: white;"
                  data-action="click->ai-landing-demo#showLiveDemo">
            <svg class="mr-3 h-5 w-5 group-hover:scale-110 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.828 14.828a4 4 0 01-5.656 0M9 10h1m4 0h1m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
            </svg>
            Watch AI in Action
          </button>
        </div>

        <!-- Premium Trust Indicators -->
        <div class="flex flex-wrap items-center gap-8 text-white/80">
          <div class="flex items-center">
            <div class="h-5 w-5 bg-gradient-to-r from-green-400 to-emerald-400 rounded-full mr-3 flex items-center justify-center">
              <svg class="h-3 w-3 text-white" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
              </svg>
            </div>
            <span class="font-medium">No Credit Card Required</span>
          </div>
          <div class="flex items-center">
            <div class="h-5 w-5 bg-gradient-to-r from-blue-400 to-cyan-400 rounded-full mr-3 flex items-center justify-center">
              <svg class="h-3 w-3 text-white" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
              </svg>
            </div>
            <span class="font-medium">14-Day Free Trial</span>
          </div>
          <div class="flex items-center">
            <div class="h-5 w-5 bg-gradient-to-r from-purple-400 to-pink-400 rounded-full mr-3 flex items-center justify-center">
              <svg class="h-3 w-3 text-white" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
              </svg>
            </div>
            <span class="font-medium">Enterprise-Grade Security</span>
          </div>
        </div>
      </div>

      <!-- Premium Interactive Demo Column -->
      <div class="relative premium-animate-float">
        <!-- Premium Live Metrics Dashboard Preview -->
        <div class="premium-card premium-card-glass p-8 transform hover:scale-105 transition-all duration-500"
             style="background: rgba(255, 255, 255, 0.15); backdrop-filter: blur(20px); border: 1px solid rgba(255, 255, 255, 0.2);"
             data-ai-landing-demo-target="liveDemo">

          <!-- Premium Demo Header -->
          <div class="flex items-center justify-between mb-8">
            <div class="flex items-center gap-4">
              <div class="h-4 w-4 bg-gradient-to-r from-green-400 to-emerald-400 rounded-full premium-animate-pulse"></div>
              <span class="text-lg font-semibold text-white">Live AI Monitoring</span>
            </div>
            <span class="text-sm text-white/70 bg-white/10 px-3 py-1 rounded-full" data-live-metrics-target="timestamp">Just now</span>
          </div>

          <!-- Premium Live Metrics Grid -->
          <div class="premium-grid premium-grid-md-2 gap-6 mb-8">
            <div class="premium-card p-6" style="background: rgba(16, 185, 129, 0.15); backdrop-filter: blur(10px); border: 1px solid rgba(16, 185, 129, 0.3);">
              <div class="flex items-center justify-between mb-4">
                <span class="text-sm font-semibold text-white">Revenue/Hour</span>
                <div class="h-8 w-8 bg-gradient-to-r from-green-400 to-emerald-400 rounded-lg flex items-center justify-center">
                  <svg class="h-4 w-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1"></path>
                  </svg>
                </div>
              </div>
              <div class="text-3xl font-bold text-white mb-2" data-live-metrics-target="revenue">$<%= @demo_data[:real_time_metrics][:revenue_rate] %></div>
              <div class="text-sm text-white/80 flex items-center">
                <svg class="h-4 w-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path>
                </svg>
                +12.3% vs last hour
              </div>
            </div>

            <div class="premium-card p-6" style="background: rgba(59, 130, 246, 0.15); backdrop-filter: blur(10px); border: 1px solid rgba(59, 130, 246, 0.3);">
              <div class="flex items-center justify-between mb-4">
                <span class="text-sm font-semibold text-white">Active Users</span>
                <div class="h-8 w-8 bg-gradient-to-r from-blue-400 to-cyan-400 rounded-lg flex items-center justify-center">
                  <svg class="h-4 w-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197m13.5-9a2.5 2.5 0 11-5 0 2.5 2.5 0 015 0z"></path>
                  </svg>
                </div>
              </div>
              <div class="text-3xl font-bold text-white mb-2" data-live-metrics-target="users"><%= @demo_data[:real_time_metrics][:customer_activity] %></div>
              <div class="text-sm text-white/80 flex items-center">
                <svg class="h-4 w-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path>
                </svg>
                +8.5% trend
              </div>
            </div>
          </div>

          <!-- Premium AI Insights -->
          <div class="premium-card p-6" style="background: rgba(139, 92, 246, 0.15); backdrop-filter: blur(10px); border: 1px solid rgba(139, 92, 246, 0.3);">
            <div class="flex items-center gap-4 mb-4">
              <div class="h-3 w-3 bg-gradient-to-r from-purple-400 to-pink-400 rounded-full premium-animate-pulse"></div>
              <span class="text-lg font-semibold text-white">AI Insight</span>
              <span class="text-xs bg-gradient-to-r from-yellow-400 to-orange-400 text-gray-900 px-3 py-1 rounded-full font-bold">Live</span>
            </div>
            <p class="text-white/90 mb-4 leading-relaxed" data-ai-landing-demo-target="liveInsight">
              <%= @demo_data[:recent_insights].first[:description] %>
            </p>
            <div class="flex items-center justify-between">
              <span class="text-sm text-white/70">Confidence: <span class="font-semibold text-white"><%= @demo_data[:recent_insights].first[:confidence] %>%</span></span>
              <span class="text-sm font-semibold text-white bg-white/10 px-3 py-1 rounded-full"><%= @demo_data[:recent_insights].first[:impact] %></span>
            </div>
          </div>
        </div>

        <!-- Premium Floating Elements -->
        <div class="absolute -top-6 -right-6 bg-gradient-to-r from-yellow-400 to-orange-400 text-gray-900 px-4 py-2 rounded-full text-sm font-bold premium-animate-pulse shadow-xl">
          Live Data!
        </div>

        <div class="absolute -bottom-6 -left-6 bg-gradient-to-r from-green-400 to-blue-500 text-white px-6 py-3 rounded-full text-sm font-semibold shadow-xl premium-animate-float">
          AI Working 24/7
        </div>
      </div>
    </div>
  </div>

  <!-- Premium Scroll Indicator -->
  <div class="absolute bottom-12 left-1/2 transform -translate-x-1/2 premium-animate-float">
    <div class="bg-white/20 backdrop-filter backdrop-blur-lg rounded-full p-3 border border-white/30">
      <svg class="h-6 w-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
      </svg>
    </div>
  </div>
</section>

<!-- Premium AI Stats Showcase -->
<section class="premium-section bg-white">
  <div class="premium-container">
    <div class="premium-text-center premium-mb-16">
      <h2 class="premium-heading-3 text-gray-900 premium-mb-4">Trusted by businesses processing</h2>
      <div class="w-24 h-1 bg-gradient-to-r from-purple-500 to-blue-500 mx-auto rounded-full"></div>
    </div>

    <div class="premium-grid premium-grid-md-3 premium-grid-lg-6 gap-8 items-center">
      <div class="premium-text-center group">
        <div class="premium-heading-2 premium-gradient-text premium-mb-2 group-hover:scale-110 transition-transform duration-300"><%= @stats[:ai_insights_generated] %></div>
        <div class="premium-body-small text-gray-600 font-semibold">AI Insights Generated</div>
      </div>
      <div class="premium-text-center group">
        <div class="premium-heading-2 premium-mb-2 group-hover:scale-110 transition-transform duration-300" style="background: linear-gradient(135deg, #10b981, #34d399); -webkit-background-clip: text; -webkit-text-fill-color: transparent;"><%= @stats[:anomalies_detected] %></div>
        <div class="premium-body-small text-gray-600 font-semibold">Anomalies Detected</div>
      </div>
      <div class="premium-text-center group">
        <div class="premium-heading-2 premium-mb-2 group-hover:scale-110 transition-transform duration-300" style="background: linear-gradient(135deg, #8b5cf6, #a855f7); -webkit-background-clip: text; -webkit-text-fill-color: transparent;"><%= @stats[:businesses_served] %></div>
        <div class="premium-body-small text-gray-600 font-semibold">Businesses Served</div>
      </div>
      <div class="premium-text-center group">
        <div class="premium-heading-2 premium-mb-2 group-hover:scale-110 transition-transform duration-300" style="background: linear-gradient(135deg, #3b82f6, #1d4ed8); -webkit-background-clip: text; -webkit-text-fill-color: transparent;"><%= @stats[:predictions_accuracy] %></div>
        <div class="premium-body-small text-gray-600 font-semibold">Prediction Accuracy</div>
      </div>
      <div class="premium-text-center group">
        <div class="premium-heading-2 premium-mb-2 group-hover:scale-110 transition-transform duration-300" style="background: linear-gradient(135deg, #ef4444, #f87171); -webkit-background-clip: text; -webkit-text-fill-color: transparent;"><%= @stats[:data_processed] %></div>
        <div class="premium-body-small text-gray-600 font-semibold">Records Processed</div>
      </div>
      <div class="premium-text-center group">
        <div class="premium-heading-2 text-gray-900 premium-mb-2 group-hover:scale-110 transition-transform duration-300"><%= @stats[:uptime] %></div>
        <div class="premium-body-small text-gray-600 font-semibold">Uptime SLA</div>
      </div>
    </div>
  </div>
</section>

<!-- Premium AI Features Showcase -->
<section id="features" class="premium-section" style="background: linear-gradient(135deg, #f8fafc 0%, #e2e8f0 100%);">
  <div class="premium-container">
    <div class="premium-text-center premium-mb-20">
      <h2 class="premium-heading-1 text-gray-900 premium-mb-8">
        Meet Your <span class="premium-gradient-text">AI Business Partner</span>
      </h2>
      <p class="premium-body-large text-gray-600 max-w-4xl mx-auto leading-relaxed">
        Unlike traditional BI tools that show you what happened, our AI agents predict what will happen and take action to optimize your business.
      </p>
      <div class="w-32 h-1 bg-gradient-to-r from-purple-500 to-blue-500 mx-auto rounded-full mt-8"></div>
    </div>

    <div class="premium-grid premium-grid-lg-3 gap-10">
      <% @ai_features.each_with_index do |feature, index| %>
        <div class="group premium-card premium-card-glass relative overflow-hidden transform hover:-translate-y-6 transition-all duration-500"
             style="background: rgba(255, 255, 255, 0.8); backdrop-filter: blur(20px); border: 1px solid rgba(255, 255, 255, 0.3);"
             data-ai-landing-demo-target="featureCard">

          <!-- Premium Feature Icon -->
          <div class="w-20 h-20 bg-gradient-to-r from-purple-500 to-blue-500 rounded-3xl flex items-center justify-center premium-mb-8 group-hover:scale-110 group-hover:rotate-6 transition-all duration-500 shadow-xl">
            <% case feature[:icon] %>
            <% when "ai-brain" %>
              <svg class="h-10 w-10 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"></path>
              </svg>
            <% when "anomaly-detection" %>
              <svg class="h-10 w-10 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
              </svg>
            <% when "data-intelligence" %>
              <svg class="h-10 w-10 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
              </svg>
            <% end %>
          </div>

          <h3 class="premium-heading-3 text-gray-900 premium-mb-6"><%= feature[:title] %></h3>
          <p class="premium-body text-gray-600 premium-mb-8 leading-relaxed"><%= feature[:description] %></p>

          <!-- Premium Benefits -->
          <div class="space-y-4 premium-mb-8">
            <% feature[:benefits].each do |benefit| %>
              <div class="flex items-center premium-body text-gray-700">
                <div class="h-5 w-5 bg-gradient-to-r from-green-400 to-emerald-400 rounded-full mr-4 flex items-center justify-center">
                  <svg class="h-3 w-3 text-white" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
                  </svg>
                </div>
                <span class="font-medium"><%= benefit %></span>
              </div>
            <% end %>
          </div>

          <!-- Premium Demo Button -->
          <% if feature[:demo_available] %>
            <button class="premium-btn premium-btn-primary w-full group-hover:scale-105 transition-all duration-500"
                    data-action="click->ai-landing-demo#showFeatureDemo"
                    data-feature="<%= feature[:title].parameterize %>">
              <span class="flex items-center justify-center">
                <svg class="h-5 w-5 mr-3 group-hover:rotate-12 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.828 14.828a4 4 0 01-5.656 0M9 10h1m4 0h1m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                </svg>
                See Live Demo
              </span>
            </button>
          <% end %>

          <!-- Premium Floating Badge -->
          <div class="absolute -top-4 -right-4 bg-gradient-to-r from-yellow-400 to-orange-500 text-white px-4 py-2 rounded-full text-sm font-bold shadow-xl premium-animate-pulse">
            LIVE
          </div>
        </div>
      <% end %>
    </div>
  </div>
</section>

<!-- Premium Real-Time Analytics Showcase -->
<section class="premium-section relative overflow-hidden" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
  <!-- Premium Background Elements -->
  <div class="absolute inset-0">
    <div class="absolute top-20 right-20 w-96 h-96 bg-white/5 rounded-full mix-blend-overlay filter blur-3xl premium-animate-float"></div>
    <div class="absolute bottom-20 left-20 w-80 h-80 bg-white/8 rounded-full mix-blend-overlay filter blur-2xl premium-animate-float" style="animation-delay: 1s;"></div>
  </div>

  <div class="premium-container relative z-10">
    <div class="premium-grid premium-grid-lg-2 gap-20 items-center">
      <!-- Premium Content -->
      <div>
        <h2 class="premium-heading-1 text-white premium-mb-8">
          Watch Your Business
          <span class="premium-gradient-text" style="background: linear-gradient(135deg, #10b981 0%, #34d399 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">
            In Real Time
          </span>
        </h2>
        <p class="premium-body-large text-white/90 premium-mb-12 leading-relaxed">
          Our AI monitors every aspect of your business continuously, detecting anomalies, predicting trends, and alerting you to opportunities the moment they appear.
        </p>

        <div class="space-y-8 premium-mb-12">
          <div class="flex items-start gap-6 group">
