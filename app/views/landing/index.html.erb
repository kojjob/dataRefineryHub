<% content_for :title, "DataReflow - Transform Your Business Data Into Growth" %>

<div data-controller="landing-animation video-modal">

<!-- Hero Section with Animated Background -->
<section class="relative min-h-screen flex items-center justify-center overflow-hidden bg-gradient-to-br from-purple-900 via-blue-900 to-indigo-900">
  <!-- Animated Background Elements -->
  <div class="absolute inset-0">
    <div class="absolute top-20 left-20 w-96 h-96 bg-purple-500 bg-opacity-10 rounded-full blur-3xl animate-pulse"></div>
    <div class="absolute bottom-20 right-20 w-80 h-80 bg-blue-500 bg-opacity-10 rounded-full blur-3xl animate-pulse delay-1000"></div>
    <div class="absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 w-64 h-64 bg-indigo-500 bg-opacity-10 rounded-full blur-2xl animate-bounce delay-500"></div>
  </div>
  
  <!-- Floating Data Visualization Elements -->
  <div class="absolute inset-0 overflow-hidden">
    <svg class="absolute top-10 right-10 w-32 h-32 text-purple-300 opacity-20 animate-spin" style="animation-duration: 20s;" fill="currentColor" viewBox="0 0 24 24">
      <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
    </svg>
    <svg class="absolute bottom-20 left-10 w-24 h-24 text-blue-300 opacity-20 animate-bounce" fill="currentColor" viewBox="0 0 24 24">
      <path d="M9 17H7v-7h2v7zm4 0h-2V7h2v10zm4 0h-2v-4h2v4zm2 2H5V5h14v14z"/>
    </svg>
  </div>

  <div class="relative z-10 max-w-7xl mx-auto px-6 lg:px-8 text-center">
    <!-- Logo and Brand -->
    <div class="flex items-center justify-center mb-8">
      <div class="flex h-16 w-16 items-center justify-center rounded-3xl bg-white bg-opacity-10 backdrop-blur-sm border border-white border-opacity-20 shadow-2xl">
        <svg class="h-10 w-10 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
        </svg>
      </div>
      <span class="ml-4 text-4xl font-bold text-white">DataReflow</span>
    </div>

    <!-- Main Headline -->
    <h1 class="text-5xl md:text-7xl font-bold text-white mb-6 leading-tight">
      Transform Your
      <span class="text-transparent bg-clip-text bg-gradient-to-r from-yellow-300 via-pink-300 to-purple-300">
        Business Data
      </span>
      Into Growth
    </h1>

    <!-- Subheadline -->
    <p class="text-xl md:text-2xl text-blue-100 mb-8 max-w-4xl mx-auto leading-relaxed">
      Connect all your business tools in minutes. Get real-time insights that actually drive decisions. 
      Join 10,000+ SMBs growing faster with DataReflow.
    </p>

    <!-- CTA Buttons -->
    <div class="flex flex-col sm:flex-row gap-4 justify-center items-center mb-12">
      <%= link_to new_user_registration_path, class: "group relative px-8 py-4 bg-gradient-to-r from-purple-600 to-pink-600 hover:from-purple-700 hover:to-pink-700 text-white font-semibold rounded-xl shadow-lg hover:shadow-xl transform hover:-translate-y-1 transition-all duration-300" do %>
        <span class="flex items-center">
          Start Free Trial
          <svg class="ml-2 h-5 w-5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
          </svg>
        </span>
      <% end %>
      
      <button data-action="click->video-modal#open" class="px-8 py-4 border-2 border-white border-opacity-30 text-white font-semibold rounded-xl backdrop-blur-sm hover:bg-white hover:bg-opacity-10 transition-all duration-300">
        Watch Demo
      </button>
    </div>

    <!-- Trust Indicators -->
    <div class="flex flex-wrap justify-center items-center gap-8 text-blue-200">
      <div class="flex items-center">
        <svg class="h-5 w-5 text-green-400 mr-2" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
        </svg>
        No Credit Card Required
      </div>
      <div class="flex items-center">
        <svg class="h-5 w-5 text-green-400 mr-2" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
        </svg>
        14-Day Free Trial
      </div>
      <div class="flex items-center">
        <svg class="h-5 w-5 text-green-400 mr-2" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
        </svg>
        Setup in 15 Minutes
      </div>
    </div>
  </div>

  <!-- Scroll Indicator -->
  <div class="absolute bottom-8 left-1/2 transform -translate-x-1/2 animate-bounce">
    <svg class="h-6 w-6 text-white opacity-60" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
    </svg>
  </div>
</section>

<!-- Stats Section -->
<section class="py-20 bg-white">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
      <div class="text-center" data-landing-animation-target="counter">
        <div class="text-4xl md:text-5xl font-bold text-purple-600 mb-2"><%= @stats[:businesses_served] %></div>
        <div class="text-gray-600 font-medium">Businesses Served</div>
      </div>
      <div class="text-center" data-landing-animation-target="counter">
        <div class="text-4xl md:text-5xl font-bold text-blue-600 mb-2"><%= @stats[:data_processed] %></div>
        <div class="text-gray-600 font-medium">Records Processed</div>
      </div>
      <div class="text-center" data-landing-animation-target="counter">
        <div class="text-4xl md:text-5xl font-bold text-green-600 mb-2"><%= @stats[:integrations] %></div>
        <div class="text-gray-600 font-medium">Integrations</div>
      </div>
      <div class="text-center" data-landing-animation-target="counter">
        <div class="text-4xl md:text-5xl font-bold text-orange-600 mb-2"><%= @stats[:uptime] %></div>
        <div class="text-gray-600 font-medium">Uptime SLA</div>
      </div>
    </div>
  </div>
</section>

<!-- Features Section -->
<section id="features" class="py-20 bg-gray-50">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="text-center mb-16">
      <h2 class="text-4xl md:text-5xl font-bold text-gray-900 mb-6">
        Everything You Need to 
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-purple-600 to-blue-600">Scale Your Business</span>
      </h2>
      <p class="text-xl text-gray-600 max-w-3xl mx-auto">
        Stop drowning in disconnected data. DataReflow brings all your business metrics into one intelligent dashboard.
      </p>
    </div>

    <div class="grid md:grid-cols-3 gap-8">
      <!-- Feature 1: Real-time Integration -->
      <div class="group p-8 bg-white rounded-2xl shadow-lg hover:shadow-2xl transition-all duration-300 transform hover:-translate-y-2" data-landing-animation-target="feature">
        <div class="w-16 h-16 bg-gradient-to-r from-purple-500 to-pink-500 rounded-2xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform duration-300">
          <svg class="h-8 w-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
          </svg>
        </div>
        <h3 class="text-2xl font-bold text-gray-900 mb-4">Lightning-Fast Setup</h3>
        <p class="text-gray-600 mb-6">Connect Shopify, QuickBooks, Google Analytics, and 20+ other tools in minutes, not weeks. Our smart connectors handle the heavy lifting.</p>
        <div class="space-y-2">
          <div class="flex items-center text-green-600">
            <svg class="h-4 w-4 mr-2" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
            </svg>
            One-click integrations
          </div>
          <div class="flex items-center text-green-600">
            <svg class="h-4 w-4 mr-2" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
            </svg>
            Auto-sync every 5 minutes
          </div>
          <div class="flex items-center text-green-600">
            <svg class="h-4 w-4 mr-2" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
            </svg>
            Zero code required
          </div>
        </div>
      </div>

      <!-- Feature 2: Smart Analytics -->
      <div class="group p-8 bg-white rounded-2xl shadow-lg hover:shadow-2xl transition-all duration-300 transform hover:-translate-y-2" data-landing-animation-target="feature">
        <div class="w-16 h-16 bg-gradient-to-r from-blue-500 to-cyan-500 rounded-2xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform duration-300">
          <svg class="h-8 w-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
          </svg>
        </div>
        <h3 class="text-2xl font-bold text-gray-900 mb-4">AI-Powered Insights</h3>
        <p class="text-gray-600 mb-6">Get automated alerts when revenue drops, inventory runs low, or customer satisfaction dips. Our AI spots trends you'd miss.</p>
        <div class="space-y-2">
          <div class="flex items-center text-green-600">
            <svg class="h-4 w-4 mr-2" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
            </svg>
            Predictive analytics
          </div>
          <div class="flex items-center text-green-600">
            <svg class="h-4 w-4 mr-2" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
            </svg>
            Smart anomaly detection
          </div>
          <div class="flex items-center text-green-600">
            <svg class="h-4 w-4 mr-2" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
            </svg>
            Automated reports
          </div>
        </div>
      </div>

      <!-- Feature 3: Unified Dashboard -->
      <div class="group p-8 bg-white rounded-2xl shadow-lg hover:shadow-2xl transition-all duration-300 transform hover:-translate-y-2" data-landing-animation-target="feature">
        <div class="w-16 h-16 bg-gradient-to-r from-green-500 to-emerald-500 rounded-2xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform duration-300">
          <svg class="h-8 w-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 5a1 1 0 011-1h14a1 1 0 011 1v2a1 1 0 01-1 1H5a1 1 0 01-1-1V5zM4 13a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H5a1 1 0 01-1-1v-6zM16 13a1 1 0 011-1h2a1 1 0 011 1v6a1 1 0 01-1 1h-2a1 1 0 01-1-1v-6z"></path>
          </svg>
        </div>
        <h3 class="text-2xl font-bold text-gray-900 mb-4">Unified Command Center</h3>
        <p class="text-gray-600 mb-6">See revenue, customers, inventory, and marketing performance in one beautiful dashboard. No more jumping between 15 different tools.</p>
        <div class="space-y-2">
          <div class="flex items-center text-green-600">
            <svg class="h-4 w-4 mr-2" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
            </svg>
            Real-time updates
          </div>
          <div class="flex items-center text-green-600">
            <svg class="h-4 w-4 mr-2" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
            </svg>
            Custom widgets
          </div>
          <div class="flex items-center text-green-600">
            <svg class="h-4 w-4 mr-2" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
            </svg>
            Mobile optimized
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Data Flow Diagram Section -->
<section class="py-20 bg-white">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="text-center mb-16">
      <h2 class="text-4xl md:text-5xl font-bold text-gray-900 mb-6">
        How DataReflow 
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-purple-600 to-blue-600">Connects Everything</span>
      </h2>
      <p class="text-xl text-gray-600 max-w-3xl mx-auto">
        See how your scattered business data flows seamlessly into actionable insights
      </p>
    </div>

    <!-- Data Flow Visualization -->
    <div class="relative">
      <!-- Source Systems -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 mb-12">
        <div class="group text-center">
          <div class="w-20 h-20 bg-gradient-to-r from-orange-400 to-red-500 rounded-2xl flex items-center justify-center mx-auto mb-4 group-hover:scale-110 transition-transform duration-300">
            <svg class="h-10 w-10 text-white" fill="currentColor" viewBox="0 0 24 24">
              <path d="M7 4V2C7 1.45 7.45 1 8 1H16C16.55 1 17 1.45 17 2V4H20C20.55 4 21 4.45 21 5S20.55 6 20 6H19V19C19 20.1 18.1 21 17 21H7C5.9 21 5 20.1 5 19V6H4C3.45 6 3 5.55 3 5S3.45 4 4 4H7ZM9 3V4H15V3H9ZM7 6V19H17V6H7Z"/>
            </svg>
