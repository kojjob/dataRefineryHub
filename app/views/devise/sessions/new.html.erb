<% content_for :title, "Sign In - Data Reflow" %>

<div class="auth-page">
  <!-- Premium Background -->
  <div class="auth-page__background"></div>

  <!-- Main Content -->
  <div class="auth-page__container">
    <div class="auth-page__content">

      <!-- Left Side - Branding -->
      <div class="auth-page__branding">
        <!-- Logo -->
        <div class="auth-page__logo">
          <div class="auth-page__logo-icon">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
            </svg>
          </div>
          <div class="auth-page__logo-text">
            <h1 class="auth-page__brand-name">Data Reflow</h1>
            <p class="auth-page__brand-tagline">Enterprise Data Platform</p>
          </div>
        </div>

        <!-- Welcome Message -->
        <div class="auth-page__welcome">
          <h2 class="auth-page__welcome-title">
            Welcome back to your
            <span class="auth-page__welcome-highlight">data hub</span>
          </h2>
          <p class="auth-page__welcome-subtitle">
            Transform your business with real-time insights and AI-powered analytics.
          </p>
        </div>

        <!-- Features -->
        <div class="auth-page__features">
          <div class="auth-page__feature">
            <div class="auth-page__feature-icon auth-page__feature-icon--success">
              <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path>
              </svg>
            </div>
            <div class="auth-page__feature-content">
              <div class="auth-page__feature-title">Real-time Analytics</div>
              <div class="auth-page__feature-description">Live dashboards updated every minute</div>
            </div>
          </div>

          <div class="auth-page__feature">
            <div class="auth-page__feature-icon auth-page__feature-icon--primary">
              <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
              </svg>
            </div>
            <div class="auth-page__feature-content">
              <div class="auth-page__feature-title">AI-Powered Insights</div>
              <div class="auth-page__feature-description">Smart recommendations from your data</div>
            </div>
          </div>

          <div class="auth-page__feature">
            <div class="auth-page__feature-icon auth-page__feature-icon--secondary">
              <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path>
              </svg>
            </div>
            <div class="auth-page__feature-content">
              <div class="auth-page__feature-title">Enterprise Security</div>
              <div class="auth-page__feature-description">SOC2 compliant with 256-bit encryption</div>
            </div>
          </div>
        </div>

        <!-- Stats -->
        <div class="auth-page__stats">
          <div class="auth-page__stat">
            <div class="auth-page__stat-number">99.9%</div>
            <div class="auth-page__stat-label">Uptime SLA</div>
          </div>
          <div class="auth-page__stat">
            <div class="auth-page__stat-number">25+</div>
            <div class="auth-page__stat-label">Integrations</div>
          </div>
          <div class="auth-page__stat">
            <div class="auth-page__stat-number">24/7</div>
            <div class="auth-page__stat-label">Support</div>
          </div>
        </div>
      </div>

      <!-- Right Side - Sign In Form -->
      <div class="auth-page__form-container">
        <div class="auth-page__form-card">
          <!-- Form Header -->
          <div class="auth-page__form-header">
            <h3 class="auth-page__form-title">Sign in to your account</h3>
            <p class="auth-page__form-subtitle">
              Or
              <%= link_to "start your free trial", new_user_registration_path,
                  class: "auth-page__form-link" %>
            </p>
          </div>

          <!-- Form -->
          <%= form_for(resource, as: resource_name, url: session_path(resource_name), local: true, html: { class: "auth-page__form" }) do |f| %>
            <%= render "devise/shared/error_messages", resource: resource %>
            
            <!-- Email Field -->
            <div class="auth-page__field">
              <%= f.label :email, "Email address", class: "auth-page__label" %>
              <div class="auth-page__input-wrapper">
                <div class="auth-page__input-icon">
                  <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 12a4 4 0 10-8 0 4 4 0 008 0zm0 0v1.5a2.5 2.5 0 005 0V12a9 9 0 10-9 9m4.5-1.206a8.959 8.959 0 01-4.5 1.207"></path>
                  </svg>
                </div>
                <%= f.email_field :email,
                    autofocus: true,
                    autocomplete: "email",
                    class: "auth-page__input",
                    placeholder: "you@example.com" %>
              </div>
            </div>

            <!-- Password Field -->
            <div class="auth-page__field">
              <%= f.label :password, "Password", class: "auth-page__label" %>
              <div class="auth-page__input-wrapper">
                <div class="auth-page__input-icon">
                  <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path>
                  </svg>
                </div>
                <%= f.password_field :password,
                    autocomplete: "current-password",
                    class: "auth-page__input",
                    placeholder: "Enter your password" %>
              </div>
            </div>

            <!-- Remember Me & Forgot Password -->
            <div class="auth-page__form-options">
              <% if devise_mapping.rememberable? %>
                <div class="auth-page__checkbox">
                  <%= f.check_box :remember_me, class: "auth-page__checkbox-input" %>
                  <%= f.label :remember_me, class: "auth-page__checkbox-label" %>
                </div>
              <% end %>

              <%= link_to "Forgot password?", new_password_path(resource_name),
                  class: "auth-page__form-link auth-page__form-link--small" %>
            </div>

            <!-- Submit Button -->
            <div class="auth-page__submit">
              <%= f.submit "Sign in", class: "btn btn--primary btn--lg auth-page__submit-btn" %>
            </div>
          <% end %>

          <!-- Security Badge -->
          <div class="auth-page__security">
            <div class="auth-page__security-badge">
              <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path>
              </svg>
              Secured by 256-bit SSL encryption
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>