<% content_for :title, "Reset Password - Data Reflow" %>

<div class="auth-page">
  <!-- Premium Background -->
  <div class="auth-page__background"></div>

  <!-- Main Content -->
  <div class="auth-page__container">
    <div class="auth-page__password-reset">
      <div class="auth-page__form-card auth-page__form-card--centered">
        <!-- Icon -->
        <div class="auth-page__password-icon">
          <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z"></path>
          </svg>
        </div>

        <!-- Header -->
        <div class="auth-page__form-header">
          <h2 class="auth-page__form-title">Forgot your password?</h2>
          <p class="auth-page__form-subtitle">
            No worries! We'll send you reset instructions.
          </p>
        </div>

        <!-- Form -->
        <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post, class: "auth-page__form" }) do |f| %>
          <%= render "devise/shared/error_messages", resource: resource %>

          <!-- Email Field -->
          <div class="auth-page__field">
            <%= f.label :email, "Email address", class: "auth-page__label" %>
            <div class="auth-page__input-wrapper">
              <div class="auth-page__input-icon">
                <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 12a4 4 0 10-8 0 4 4 0 008 0zm0 0v1.5a2.5 2.5 0 005 0V12a9 9 0 10-9 9m4.5-1.206a8.959 8.959 0 01-4.5 1.207"></path>
                </svg>
              </div>
              <%= f.email_field :email,
                  autofocus: true,
                  autocomplete: "email",
                  class: "auth-page__input",
                  placeholder: "Enter your email address" %>
            </div>
            <p class="auth-page__field-help">
              We'll send a password reset link to this email address.
            </p>
          </div>

          <!-- Submit Button -->
          <div class="auth-page__submit">
            <%= f.submit "Send reset instructions", class: "btn btn--primary btn--lg auth-page__submit-btn" %>
          </div>
        <% end %>

        <!-- Back to Sign In -->
        <div class="auth-page__back-link">
          <p class="auth-page__back-text">
            Remember your password?
            <%= link_to "Back to sign in", new_user_session_path,
                class: "auth-page__form-link" %>
          </p>
        </div>

        <!-- Help Section -->
        <div class="auth-page__help-section">
          <div class="auth-page__help-card">
            <div class="auth-page__help-content">
              <div class="auth-page__help-icon">
                <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
              </div>
              <div class="auth-page__help-text">
                <h3 class="auth-page__help-title">Need help?</h3>
                <p class="auth-page__help-description">
                  If you're having trouble accessing your account,
                  <%= link_to "contact support", "#", class: "auth-page__help-link" %>
                  for assistance.
                </p>
              </div>
            </div>
          </div>
        </div>

        <!-- Security Badge -->
        <div class="auth-page__security">
          <div class="auth-page__security-badge">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path>
            </svg>
            Password reset links expire after 24 hours
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
