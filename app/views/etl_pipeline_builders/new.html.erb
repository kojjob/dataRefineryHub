<!-- Executive Pipeline Builder with Premium Design System -->
<div style="
  min-height: 100vh;
  background: linear-gradient(135deg, rgba(var(--color-surface-rgb), 0.95) 0%, rgba(13, 148, 136, 0.02) 100%);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
">
  <!-- Premium Executive Header -->
  <div style="
    background: linear-gradient(135deg, #0d9488 0%, #0f766e 100%);
    border-bottom: 1px solid rgba(var(--color-border-rgb), 0.2);
    box-shadow: 0 8px 32px rgba(13, 148, 136, 0.3);
    position: relative;
    overflow: hidden;
  ">
    <!-- Background Pattern -->
    <div style="
      position: absolute;
      top: 0;
      right: 0;
      width: 300px;
      height: 200px;
      background: radial-gradient(circle, rgba(255, 255, 255, 0.1) 0%, transparent 70%);
      border-radius: 50%;
      transform: translate(30%, -30%);
    "></div>

    <div style="
      padding: var(--space-24) var(--space-32);
      position: relative;
      z-index: 1;
    ">
      <div style="
        display: flex;
        align-items: center;
        gap: var(--space-20);
      ">
        <%= link_to etl_pipeline_builders_path, style: "
          display: inline-flex;
          align-items: center;
          justify-content: center;
          width: 48px;
          height: 48px;
          background: rgba(255, 255, 255, 0.2);
          border: 1px solid rgba(255, 255, 255, 0.3);
          border-radius: var(--radius-xl);
          color: white;
          text-decoration: none;
          transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
          backdrop-filter: blur(10px);
        ", onmouseover: "this.style.background='rgba(255, 255, 255, 0.3)'; this.style.transform='scale(1.05)'", onmouseout: "this.style.background='rgba(255, 255, 255, 0.2)'; this.style.transform='scale(1)'" do %>
          <svg style="width: 24px; height: 24px;" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18"/>
          </svg>
        <% end %>

        <div>
          <h1 style="
            font-size: var(--font-size-4xl);
            font-weight: var(--font-weight-bold);
            color: white;
            margin: 0 0 var(--space-8) 0;
            line-height: var(--line-height-tight);
            display: flex;
            align-items: center;
            gap: var(--space-16);
          ">
            <div style="
              width: 64px;
              height: 64px;
              background: rgba(255, 255, 255, 0.2);
              border-radius: var(--radius-xl);
              display: flex;
              align-items: center;
              justify-content: center;
              backdrop-filter: blur(10px);
            ">
              <svg style="width: 32px; height: 32px; color: white;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
              </svg>
            </div>
            Create New Pipeline
          </h1>
          <p style="
            font-size: var(--font-size-lg);
            color: rgba(255, 255, 255, 0.9);
            margin: 0;
            font-weight: var(--font-weight-medium);
          ">Build sophisticated ETL pipelines with our intuitive visual designer</p>
        </div>
      </div>
    </div>
  </div>

  <%= form_with model: @pipeline, url: etl_pipeline_builders_path, local: false,
                data: {
                  controller: "pipeline-builder",
                  "pipeline-builder-current-step-value": 1,
                  "pipeline-builder-total-steps-value": 5
                } do |form| %>

    <!-- Executive Pipeline Configuration Container -->
    <div style="
      padding: var(--space-32);
      max-width: 1200px;
      margin: 0 auto;
    ">
      <!-- Premium Step Navigation -->
      <nav aria-label="Pipeline Creation Progress" style="margin-bottom: var(--space-48);">
        <div style="
          background: linear-gradient(135deg, rgba(var(--color-surface-rgb), 0.95) 0%, rgba(13, 148, 136, 0.02) 100%);
          border: 1px solid rgba(var(--color-border-rgb), 0.2);
          border-radius: var(--radius-xl);
          padding: var(--space-32);
          backdrop-filter: blur(20px);
          -webkit-backdrop-filter: blur(20px);
          box-shadow: 0 8px 32px rgba(0, 0, 0, 0.08);
        ">
          <ol style="
            display: flex;
            align-items: center;
            justify-content: space-between;
            position: relative;
          ">
            <!-- Step 1: Basic Info -->
            <li data-pipeline-builder-target="step1Nav" style="
              display: flex;
              flex-direction: column;
              align-items: center;
              position: relative;
              z-index: 2;
            ">
              <div style="
                width: 56px;
                height: 56px;
                background: linear-gradient(135deg, #0d9488 0%, #0f766e 100%);
                border: 3px solid white;
                border-radius: 50%;
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: var(--font-size-lg);
                font-weight: var(--font-weight-bold);
                color: white;
                box-shadow: 0 4px 12px rgba(13, 148, 136, 0.3);
                margin-bottom: var(--space-12);
              ">1</div>
              <span style="
                font-size: var(--font-size-sm);
                font-weight: var(--font-weight-bold);
                color: var(--color-text);
                text-align: center;
              ">Basic Info</span>
            </li>

            <!-- Progress Line 1-2 -->
            <div style="
              position: absolute;
              top: 28px;
              left: 20%;
              right: 80%;
              height: 3px;
              background: rgba(var(--color-border-rgb), 0.3);
              z-index: 1;
            "></div>

            <!-- Step 2: Source -->
            <li data-pipeline-builder-target="step2Nav" style="
              display: flex;
              flex-direction: column;
              align-items: center;
              position: relative;
              z-index: 2;
            ">
              <div style="
                width: 56px;
                height: 56px;
                background: rgba(var(--color-border-rgb), 0.3);
                border: 3px solid white;
                border-radius: 50%;
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: var(--font-size-lg);
                font-weight: var(--font-weight-bold);
                color: var(--color-text-secondary);
                margin-bottom: var(--space-12);
                transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
              ">2</div>
              <span style="
                font-size: var(--font-size-sm);
                font-weight: var(--font-weight-medium);
                color: var(--color-text-secondary);
                text-align: center;
              ">Source</span>
            </li>

            <!-- Progress Line 2-3 -->
            <div style="
              position: absolute;
              top: 28px;
              left: 40%;
              right: 60%;
              height: 3px;
              background: rgba(var(--color-border-rgb), 0.3);
              z-index: 1;
            "></div>

            <!-- Step 3: Transformations -->
            <li data-pipeline-builder-target="step3Nav" style="
              display: flex;
              flex-direction: column;
              align-items: center;
              position: relative;
              z-index: 2;
            ">
              <div style="
                width: 56px;
                height: 56px;
                background: rgba(var(--color-border-rgb), 0.3);
                border: 3px solid white;
                border-radius: 50%;
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: var(--font-size-lg);
                font-weight: var(--font-weight-bold);
                color: var(--color-text-secondary);
                margin-bottom: var(--space-12);
                transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
              ">3</div>
              <span style="
                font-size: var(--font-size-sm);
                font-weight: var(--font-weight-medium);
                color: var(--color-text-secondary);
                text-align: center;
              ">Transformations</span>
            </li>

            <!-- Progress Line 3-4 -->
            <div style="
              position: absolute;
              top: 28px;
              left: 60%;
              right: 40%;
              height: 3px;
              background: rgba(var(--color-border-rgb), 0.3);
              z-index: 1;
            "></div>

            <!-- Step 4: Destination -->
            <li data-pipeline-builder-target="step4Nav" style="
              display: flex;
              flex-direction: column;
              align-items: center;
              position: relative;
              z-index: 2;
            ">
              <div style="
                width: 56px;
                height: 56px;
                background: rgba(var(--color-border-rgb), 0.3);
                border: 3px solid white;
                border-radius: 50%;
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: var(--font-size-lg);
                font-weight: var(--font-weight-bold);
                color: var(--color-text-secondary);
                margin-bottom: var(--space-12);
                transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
              ">4</div>
              <span style="
                font-size: var(--font-size-sm);
                font-weight: var(--font-weight-medium);
                color: var(--color-text-secondary);
                text-align: center;
              ">Destination</span>
            </li>

            <!-- Progress Line 4-5 -->
            <div style="
              position: absolute;
              top: 28px;
              left: 80%;
              right: 20%;
              height: 3px;
              background: rgba(var(--color-border-rgb), 0.3);
              z-index: 1;
            "></div>

            <!-- Step 5: Schedule -->
            <li data-pipeline-builder-target="step5Nav" style="
              display: flex;
              flex-direction: column;
              align-items: center;
              position: relative;
              z-index: 2;
            ">
              <div style="
                width: 56px;
                height: 56px;
                background: rgba(var(--color-border-rgb), 0.3);
                border: 3px solid white;
                border-radius: 50%;
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: var(--font-size-lg);
                font-weight: var(--font-weight-bold);
                color: var(--color-text-secondary);
                margin-bottom: var(--space-12);
                transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
              ">5</div>
              <span style="
                font-size: var(--font-size-sm);
                font-weight: var(--font-weight-medium);
                color: var(--color-text-secondary);
                text-align: center;
              ">Schedule</span>
            </li>
          </ol>
        </div>
      </nav>

      <!-- Step 1: Premium Basic Information -->
      <div data-pipeline-builder-target="step1" style="margin-top: var(--space-32);">
        <div style="
          background: linear-gradient(135deg, rgba(var(--color-surface-rgb), 0.95) 0%, rgba(13, 148, 136, 0.02) 100%);
          border: 1px solid rgba(var(--color-border-rgb), 0.2);
          border-radius: var(--radius-xl);
          backdrop-filter: blur(20px);
          -webkit-backdrop-filter: blur(20px);
          box-shadow: 0 8px 32px rgba(0, 0, 0, 0.08);
          overflow: hidden;
        ">
          <!-- Premium Step Header -->
          <div style="
            background: linear-gradient(135deg, rgba(13, 148, 136, 0.1) 0%, rgba(13, 148, 136, 0.05) 100%);
            border-bottom: 1px solid rgba(var(--color-border-rgb), 0.2);
            padding: var(--space-24) var(--space-32);
          ">
            <h2 style="
              font-size: var(--font-size-2xl);
              font-weight: var(--font-weight-bold);
              color: var(--color-text);
              margin: 0 0 var(--space-8) 0;
              display: flex;
              align-items: center;
              gap: var(--space-12);
            ">
              <div style="
                width: 40px;
                height: 40px;
                background: linear-gradient(135deg, #0d9488 0%, #0f766e 100%);
                border-radius: var(--radius-lg);
                display: flex;
                align-items: center;
                justify-content: center;
                box-shadow: 0 4px 12px rgba(13, 148, 136, 0.3);
              ">
                <svg style="width: 20px; height: 20px; color: white;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
              </div>
              Basic Information
            </h2>
            <p style="
              font-size: var(--font-size-sm);
              color: var(--color-text-secondary);
              margin: 0;
            ">Define the core properties and type of your data pipeline</p>
          </div>

          <!-- Premium Form Fields -->
          <div style="padding: var(--space-32); display: flex; flex-direction: column; gap: var(--space-32);">
            <!-- Pipeline Name Field -->
            <div>
              <%= form.label :name, style: "
                display: block;
                font-size: var(--font-size-sm);
                font-weight: var(--font-weight-bold);
                color: var(--color-text);
                margin-bottom: var(--space-8);
              " do %>
                Pipeline Name
                <span style="color: #ef4444;">*</span>
              <% end %>
              <%= form.text_field :name,
                    style: "
                      display: block;
                      width: 100%;
                      padding: var(--space-12) var(--space-16);
                      background: rgba(var(--color-surface-rgb), 0.8);
                      border: 1px solid rgba(var(--color-border-rgb), 0.3);
                      border-radius: var(--radius-lg);
                      color: var(--color-text);
                      font-size: var(--font-size-sm);
                      transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
                      backdrop-filter: blur(10px);
                    ",
                    placeholder: "e.g., Daily Customer Data Sync",
                    required: true,
                    "aria-describedby": "name-help",
                    data: { action: "input->pipeline-builder#validateField" },
                    onfocus: "this.style.borderColor='rgba(13, 148, 136, 0.5)'; this.style.boxShadow='0 0 0 3px rgba(13, 148, 136, 0.1)'",
                    onblur: "this.style.borderColor='rgba(var(--color-border-rgb), 0.3)'; this.style.boxShadow='none'" %>
              <p id="name-help" style="
                font-size: var(--font-size-xs);
                color: var(--color-text-secondary);
                margin: var(--space-4) 0 0 0;
              ">Choose a descriptive name that clearly identifies this pipeline's purpose</p>
            </div>

            <!-- Pipeline Description Field -->
            <div>
              <%= form.label :description, style: "
                display: block;
                font-size: var(--font-size-sm);
                font-weight: var(--font-weight-bold);
                color: var(--color-text);
                margin-bottom: var(--space-8);
              " do %>
                Description
              <% end %>
              <%= form.text_area :description,
                    rows: 4,
                    style: "
                      display: block;
                      width: 100%;
                      padding: var(--space-12) var(--space-16);
                      background: rgba(var(--color-surface-rgb), 0.8);
                      border: 1px solid rgba(var(--color-border-rgb), 0.3);
                      border-radius: var(--radius-lg);
                      color: var(--color-text);
                      font-size: var(--font-size-sm);
                      transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
                      backdrop-filter: blur(10px);
                      resize: vertical;
                      min-height: 100px;
                    ",
                    placeholder: "Describe what this pipeline does, its data sources, transformations, and business purpose...",
                    "aria-describedby": "description-help",
                    onfocus: "this.style.borderColor='rgba(13, 148, 136, 0.5)'; this.style.boxShadow='0 0 0 3px rgba(13, 148, 136, 0.1)'",
                    onblur: "this.style.borderColor='rgba(var(--color-border-rgb), 0.3)'; this.style.boxShadow='none'" %>
              <p id="description-help" style="
                font-size: var(--font-size-xs);
                color: var(--color-text-secondary);
                margin: var(--space-4) 0 0 0;
              ">Provide a detailed description to help team members understand this pipeline's purpose</p>
            </div>

            <!-- Pipeline Type Selection -->
            <div>
              <%= form.label :pipeline_type, "Pipeline Type", style: "
                display: block;
                font-size: var(--font-size-sm);
                font-weight: var(--font-weight-bold);
                color: var(--color-text);
                margin-bottom: var(--space-16);
              " do %>
                Pipeline Type
                <span style="color: #ef4444;">*</span>
              <% end %>
              <div style="
                display: grid;
                grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
                gap: var(--space-16);
              ">
                <!-- ETL Pipeline Type -->
                <label style="
                  position: relative;
                  display: flex;
                  cursor: pointer;
                  background: linear-gradient(135deg, rgba(var(--color-surface-rgb), 0.8) 0%, rgba(13, 148, 136, 0.02) 100%);
                  border: 1px solid rgba(var(--color-border-rgb), 0.3);
                  border-radius: var(--radius-lg);
                  padding: var(--space-20);
                  backdrop-filter: blur(10px);
                  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
                  overflow: hidden;
                " onmouseover="this.style.borderColor='rgba(13, 148, 136, 0.4)'; this.style.transform='translateY(-2px)'; this.style.boxShadow='0 8px 24px rgba(0, 0, 0, 0.1)'" onmouseout="this.style.borderColor='rgba(var(--color-border-rgb), 0.3)'; this.style.transform='translateY(0)'; this.style.boxShadow='none'">
                  <%= form.radio_button :pipeline_type, 'etl',
                        style: "position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px; overflow: hidden; clip: rect(0, 0, 0, 0); white-space: nowrap; border: 0;",
                        data: { action: "change->pipeline-builder#updatePipelineType" },
                        "aria-describedby": "etl-description" %>
                  <div style="display: flex; flex: 1; flex-direction: column; gap: var(--space-12);">
                    <div style="display: flex; align-items: center; justify-content: space-between;">
                      <div style="
                        display: flex;
                        align-items: center;
                        gap: var(--space-12);
                      ">
                        <div style="
                          width: 48px;
                          height: 48px;
                          background: linear-gradient(135deg, #0d9488 0%, #0f766e 100%);
                          border-radius: var(--radius-lg);
                          display: flex;
                          align-items: center;
                          justify-content: center;
                          box-shadow: 0 4px 12px rgba(13, 148, 136, 0.3);
                        ">
                          <svg style="width: 24px; height: 24px; color: white;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4"/>
                          </svg>
                        </div>
                        <div>
                          <span style="
                            display: block;
                            font-size: var(--font-size-lg);
                            font-weight: var(--font-weight-bold);
                            color: var(--color-text);
                          ">ETL</span>
                          <span style="
                            display: block;
                            font-size: var(--font-size-sm);
                            color: var(--color-text-secondary);
                            margin-top: var(--space-2);
                          ">Extract, Transform, then Load</span>
                        </div>
                      </div>
                      <div style="
                        width: 20px;
                        height: 20px;
                        border: 2px solid rgba(var(--color-border-rgb), 0.3);
                        border-radius: 50%;
                        display: flex;
                        align-items: center;
                        justify-content: center;
                        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
                      " data-pipeline-builder-target="etlCheckbox">
                        <div style="
                          width: 8px;
                          height: 8px;
                          background: #0d9488;
                          border-radius: 50%;
                          opacity: 0;
                          transition: opacity 0.3s cubic-bezier(0.4, 0, 0.2, 1);
                        "></div>
                      </div>
                    </div>
                    <p id="etl-description" style="
                      font-size: var(--font-size-xs);
                      color: var(--color-text-secondary);
                      margin: 0;
                      line-height: var(--line-height-relaxed);
                    ">Traditional approach: Extract data from sources, transform it in memory, then load to destination. Best for complex transformations and data quality checks.</p>
                  </div>
                </label>

                <!-- ELT Pipeline Type -->
                <label style="
                  position: relative;
                  display: flex;
                  cursor: pointer;
                  background: linear-gradient(135deg, rgba(var(--color-surface-rgb), 0.8) 0%, rgba(96, 165, 250, 0.02) 100%);
                  border: 1px solid rgba(var(--color-border-rgb), 0.3);
                  border-radius: var(--radius-lg);
                  padding: var(--space-20);
                  backdrop-filter: blur(10px);
                  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
                  overflow: hidden;
                " onmouseover="this.style.borderColor='rgba(96, 165, 250, 0.4)'; this.style.transform='translateY(-2px)'; this.style.boxShadow='0 8px 24px rgba(0, 0, 0, 0.1)'" onmouseout="this.style.borderColor='rgba(var(--color-border-rgb), 0.3)'; this.style.transform='translateY(0)'; this.style.boxShadow='none'">
                  <%= form.radio_button :pipeline_type, 'elt',
                        style: "position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px; overflow: hidden; clip: rect(0, 0, 0, 0); white-space: nowrap; border: 0;",
                        data: { action: "change->pipeline-builder#updatePipelineType" },
                        "aria-describedby": "elt-description" %>
                  <div style="display: flex; flex: 1; flex-direction: column; gap: var(--space-12);">
                    <div style="display: flex; align-items: center; justify-content: space-between;">
                      <div style="
                        display: flex;
                        align-items: center;
                        gap: var(--space-12);
                      ">
                        <div style="
                          width: 48px;
                          height: 48px;
                          background: linear-gradient(135deg, #60a5fa 0%, #3b82f6 100%);
                          border-radius: var(--radius-lg);
                          display: flex;
                          align-items: center;
                          justify-content: center;
                          box-shadow: 0 4px 12px rgba(96, 165, 250, 0.3);
                        ">
                          <svg style="width: 24px; height: 24px; color: white;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
                          </svg>
                        </div>
                        <div>
                          <span style="
                            display: block;
                            font-size: var(--font-size-lg);
                            font-weight: var(--font-weight-bold);
                            color: var(--color-text);
                          ">ELT</span>
                          <span style="
                            display: block;
                            font-size: var(--font-size-sm);
                            color: var(--color-text-secondary);
                            margin-top: var(--space-2);
                          ">Extract, Load, then Transform</span>
                        </div>
                      </div>
                      <div style="
                        width: 20px;
                        height: 20px;
                        border: 2px solid rgba(var(--color-border-rgb), 0.3);
                        border-radius: 50%;
                        display: flex;
                        align-items: center;
                        justify-content: center;
                        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
                      " data-pipeline-builder-target="eltCheckbox">
                        <div style="
                          width: 8px;
                          height: 8px;
                          background: #60a5fa;
                          border-radius: 50%;
                          opacity: 0;
                          transition: opacity 0.3s cubic-bezier(0.4, 0, 0.2, 1);
                        "></div>
                      </div>
                    </div>
                    <p id="elt-description" style="
                      font-size: var(--font-size-xs);
                      color: var(--color-text-secondary);
                      margin: 0;
                      line-height: var(--line-height-relaxed);
                    ">Modern cloud approach: Extract and load raw data first, then transform in the destination. Ideal for big data and cloud data warehouses.</p>
                  </div>
                </label>

                <!-- Streaming Pipeline Type -->
                <label style="
                  position: relative;
