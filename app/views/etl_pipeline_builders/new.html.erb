                      <span class="mt-1 text-xs text-gray-500">Rename columns</span>
                    </div>
                  </button>

                  <button type="button" data-action="click->pipeline-builder#selectTransformationType" data-transform-type="type_conversion" class="relative rounded-lg border border-gray-200 bg-white p-4 shadow-sm hover:shadow-md hover:border-indigo-300 focus:outline-none focus:ring-2 focus:ring-indigo-500 transition-all">
                    <div class="flex flex-col items-center">
                      <div class="h-10 w-10 rounded-full bg-green-100 flex items-center justify-center">
