                  <button type="button" data-action="click->pipeline-builder#selectTransformationType" data-transform-type="rename_field" class="relative rounded-lg border border-gray-200 bg-white p-4 shadow-sm hover:shadow-md hover:border-indigo-300 focus:outline-none focus:ring-2 focus:ring-indigo-500 transition-all">
