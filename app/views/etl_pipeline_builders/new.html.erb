                          background: linear-gradient(135deg, rgba(var(--color-surface-rgb), 0.8) 0%, rgba(245, 158, 11, 0.02) 100%);
                          border: 1px solid rgba(var(--color-border-rgb), 0.3);
                          border-radius: var(--radius-lg);
                          padding: var(--space-20);
