                        </div>
                      </div>
                    </div>
                    <p style="font-size: var(--font-size-xs); color: var(--color-text-secondary); margin: 0; line-height: var(--line-height-relaxed);">
                      HTTP integration: REST, GraphQL, webhooks. Authentication support with automatic retry logic and rate limiting.
                    </p>
                  </div>
                </button>

                <!-- Cloud Storage Source -->
                <button type="button" 
                        data-action="click->pipeline-builder#selectSourceType" 
                        data-source-type="cloud_storage"
                        style="
