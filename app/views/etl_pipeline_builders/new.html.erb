                          align-items: center;
                          justify-content: center;
                          box-shadow: 0 4px 12px rgba(147, 51, 234, 0.3);
                        ">
                          <svg style="width: 24px; height: 24px; color: white;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M9 19l3 3m0 0l3-3m-3 3V10"/>
                          </svg>
                        </div>
                        <div>
                          <span style="display: block; font-size: var(--font-size-lg); font-weight: var(--font-weight-bold); color: var(--color-text);">Cloud Storage</span>
                          <span style="display: block; font-size: var(--font-size-sm); color: var(--color-text-secondary); margin-top: var(--space-2);">S3, GCS, Azure Blob</span>
                        </div>
                      </div>
                    </div>
                    <p style="font-size: var(--font-size-xs); color: var(--color-text-secondary); margin: 0; line-height: var(--line-height-relaxed);">
                      Cloud storage: AWS S3, Google Cloud Storage, Azure Blob. Automatic file discovery with pattern matching and compression support.
                    </p>
                  </div>
                </button>

                <!-- File Upload Source - PREMIUM ENHANCED -->
