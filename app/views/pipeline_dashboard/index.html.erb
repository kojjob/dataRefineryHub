<% content_for :page_title, "ETL Pipeline Builder" %>
<% content_for :page_subtitle, "Visual workflow designer with real-time monitoring" %>

<div class="px-df-32 py-df-24">
  <!-- Pipeline Statistics -->
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-6 gap-df-20 mb-df-32">
    <%= render Dataflow::MetricCardComponent.new(
      icon: "📊",
      title: "Total Pipelines",
      value: @statistics[:total_pipelines],
      change: "All time"
    ) %>
    
    <%= render Dataflow::MetricCardComponent.new(
      icon: "🏃",
      title: "Running",
      value: @statistics[:running_pipelines],
      change: "Active now"
    ) %>
    
    <%= render Dataflow::MetricCardComponent.new(
      icon: "✅",
      title: "Successful",
      value: @statistics[:successful_pipelines],
      change: "Last 24h",
      change_type: :positive
    ) %>
    
    <%= render Dataflow::MetricCardComponent.new(
      icon: "❌",
      title: "Failed",
      value: @statistics[:failed_pipelines],
      change: "Last 24h",
      change_type: :negative
    ) %>
    
    <%= render Dataflow::MetricCardComponent.new(
      icon: "⏱️",
      title: "Avg Duration",
      value: @statistics[:average_duration],
      change: "Per pipeline"
    ) %>
    
    <%= render Dataflow::MetricCardComponent.new(
      icon: "📈",
      title: "Success Rate",
      value: "#{@statistics[:success_rate]}%",
      change: "Last 24h",
      change_type: @statistics[:success_rate] >= 90 ? :positive : :negative
    ) %>
  </div>

  <!-- Pipeline Builder Interface -->
  <div class="bg-df-surface rounded-df-lg p-df-24 border border-df-card-border mb-df-32">
    <div class="flex items-center justify-between mb-df-20">
      <h2 class="text-df-2xl font-semibold">Pipeline Builder</h2>
      <button class="btn btn--primary">
        <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
        </svg>
        Create New Pipeline
      </button>
    </div>
    
    <div class="bg-df-background rounded-df-lg p-df-32 border-2 border-dashed border-df-border">
      <div class="flex items-center justify-center space-x-df-32">
        <div class="text-center">
          <div class="w-24 h-24 bg-df-primary rounded-df-lg flex items-center justify-center text-white text-3xl mb-df-8">📥</div>
          <p class="font-medium">Data Source</p>
          <p class="text-df-sm text-df-text-secondary">Select input</p>
        </div>
        <svg class="w-12 h-12 text-df-text-secondary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
        </svg>
        <div class="text-center">
          <div class="w-24 h-24 bg-df-warning rounded-df-lg flex items-center justify-center text-white text-3xl mb-df-8">⚙️</div>
          <p class="font-medium">Transform</p>
          <p class="text-df-sm text-df-text-secondary">Process data</p>
        </div>
        <svg class="w-12 h-12 text-df-text-secondary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
        </svg>
        <div class="text-center">
          <div class="w-24 h-24 bg-df-success rounded-df-lg flex items-center justify-center text-white text-3xl mb-df-8">📤</div>
          <p class="font-medium">Destination</p>
          <p class="text-df-sm text-df-text-secondary">Output target</p>
        </div>
      </div>
    </div>
  </div>

  <!-- Active Pipelines -->
  <div class="bg-df-surface rounded-df-lg p-df-24 border border-df-card-border mb-df-32">
    <h2 class="text-df-2xl font-semibold mb-df-20">Active Pipelines</h2>
    
    <% if @pipeline_executions.any? %>
      <div class="space-y-df-16">
        <% @pipeline_executions.each do |pipeline| %>
          <div class="bg-df-background rounded-df-lg p-df-20 border border-df-border">
            <div class="flex items-center justify-between mb-df-12">
              <div class="flex items-center gap-df-12">
                <div class="w-10 h-10 rounded-df-md flex items-center justify-center <%= case pipeline.status
                  when 'running' then 'bg-blue-100 text-blue-600'
                  when 'completed' then 'bg-green-100 text-green-600'
                  when 'failed' then 'bg-red-100 text-red-600'
                  else 'bg-gray-100 text-gray-600'
                end %>">
                  <%= case pipeline.status
                    when 'running' then '🔄'
                    when 'completed' then '✅'
                    when 'failed' then '❌'
                    else '⏸️'
                  end %>
                </div>
                <div>
                  <h3 class="text-df-lg font-semibold"><%= pipeline.pipeline_name %></h3>
                  <p class="text-df-sm text-df-text-secondary">
                    Started <%= time_ago_in_words(pipeline.started_at) %> ago
                    <% if pipeline.data_source %>
                      • <%= pipeline.data_source.name %>
                    <% end %>
                  </p>
                </div>
              </div>
              
              <div class="flex items-center gap-df-16">
                <% if pipeline.status == 'running' %>
                  <div class="text-right">
                    <p class="text-df-sm text-df-text-secondary">Progress</p>
                    <p class="text-df-lg font-semibold"><%= pipeline.progress_percentage || 0 %>%</p>
                  </div>
                <% end %>
                
                <%= link_to "View Details", pipeline_dashboard_path(pipeline), class: "btn btn--outline btn--sm" %>
              </div>
            </div>
            
            <% if pipeline.status == 'running' %>
              <div class="w-full bg-df-secondary rounded-full h-2">
                <div class="bg-df-primary h-2 rounded-full transition-all duration-300" style="width: <%= pipeline.progress_percentage || 0 %>%"></div>
              </div>
            <% end %>
          </div>
        <% end %>
      </div>
      
      <div class="mt-df-20">
        <%= paginate @pipeline_executions %>
      </div>
    <% else %>
      <div class="text-center py-df-32">
        <div class="mx-auto w-24 h-24 bg-df-secondary rounded-full flex items-center justify-center mb-df-16">
          <svg class="w-12 h-12 text-df-text-secondary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2M7 19h10a2 2 0 002-2V7a2 2 0 00-2-2H7a2 2 0 00-2 2v10a2 2 0 002 2zM9 9h6v6H9V9z"></path>
          </svg>
        </div>
        <h3 class="text-df-xl font-semibold mb-df-8">No active pipelines</h3>
        <p class="text-df-text-secondary mb-df-20">Create your first pipeline to start processing data</p>
        <button class="btn btn--primary">Create Pipeline</button>
      </div>
    <% end %>
  </div>

  <!-- Manual Interventions -->
  <% if @manual_interventions.any? %>
    <div class="bg-df-surface rounded-df-lg p-df-24 border border-df-card-border">
      <h2 class="text-df-2xl font-semibold mb-df-20 flex items-center">
        <span class="mr-2">⚠️</span> Manual Interventions Required
      </h2>
      
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-df-16">
        <% @manual_interventions.each do |task| %>
          <%= render Dataflow::InsightCardComponent.new(
            type: "Action Required",
            confidence: 100,
            message: "#{task.name} - #{task.description || 'Manual approval needed'}",
            action_text: "Take Action",
            severity: :high
          ) %>
        <% end %>
      </div>
    </div>
  <% end %>
</div>