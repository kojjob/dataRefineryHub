<% content_for :title, "Organization Settings" %>

<div class="px-4 sm:px-6 lg:px-8">
  <div class="sm:flex sm:items-center">
    <div class="sm:flex-auto">
      <h1 class="text-2xl font-semibold leading-6 text-gray-900">Organization Settings</h1>
      <p class="mt-2 text-sm text-gray-700">Manage your organization details, team, and billing information.</p>
    </div>
    <div class="mt-4 sm:ml-16 sm:mt-0 sm:flex-none">
      <%= link_to edit_organization_path, class: "block rounded-md bg-indigo-600 px-3 py-2 text-center text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600" do %>
        Edit Organization
      <% end %>
    </div>
  </div>

  <div class="mt-8 flow-root">
    <div class="grid grid-cols-1 gap-6 lg:grid-cols-3">
      
      <!-- Organization Details Card -->
      <div class="lg:col-span-2">
        <div class="bg-white shadow-sm ring-1 ring-gray-900/5 rounded-xl">
          <div class="px-6 py-4 border-b border-gray-200">
            <h3 class="text-base font-semibold leading-6 text-gray-900">Organization Details</h3>
          </div>
          <div class="px-6 py-6">
            <dl class="grid grid-cols-1 gap-x-6 gap-y-6 sm:grid-cols-2">
              <div>
                <dt class="text-sm font-medium text-gray-500">Organization Name</dt>
                <dd class="mt-1 text-sm text-gray-900"><%= @organization.name %></dd>
              </div>
              <div>
                <dt class="text-sm font-medium text-gray-500">Plan</dt>
                <dd class="mt-1">
                  <span class="inline-flex items-center rounded-md bg-green-50 px-2 py-1 text-xs font-medium text-green-700 ring-1 ring-inset ring-green-600/20">
                    <%= @organization.plan.humanize %>
                  </span>
                </dd>
              </div>
              <div>
                <dt class="text-sm font-medium text-gray-500">Status</dt>
                <dd class="mt-1">
                  <span class="inline-flex items-center rounded-md bg-<%= @organization.active? ? 'green' : 'yellow' %>-50 px-2 py-1 text-xs font-medium text-<%= @organization.active? ? 'green' : 'yellow' %>-700 ring-1 ring-inset ring-<%= @organization.active? ? 'green' : 'yellow' %>-600/20">
                    <%= @organization.status.humanize %>
                  </span>
                </dd>
              </div>
              <div>
                <dt class="text-sm font-medium text-gray-500">Created</dt>
                <dd class="mt-1 text-sm text-gray-900"><%= @organization.created_at.strftime("%B %d, %Y") %></dd>
              </div>
              <div>
                <dt class="text-sm font-medium text-gray-500">Team Members</dt>
                <dd class="mt-1 text-sm text-gray-900"><%= @users.count %> / <%= @organization.max_users == Float::INFINITY ? "Unlimited" : @organization.max_users %></dd>
              </div>
              <div>
                <dt class="text-sm font-medium text-gray-500">Data Sources</dt>
                <dd class="mt-1 text-sm text-gray-900"><%= @data_sources.count %> / <%= @organization.max_data_sources == Float::INFINITY ? "Unlimited" : @organization.max_data_sources %></dd>
              </div>
            </dl>
          </div>
        </div>
      </div>

      <!-- Quick Stats Card -->
      <div class="space-y-6">
        <!-- Plan Limits Card -->
        <div class="bg-white shadow-sm ring-1 ring-gray-900/5 rounded-xl">
          <div class="px-6 py-4 border-b border-gray-200">
            <h3 class="text-base font-semibold leading-6 text-gray-900">Plan Limits</h3>
          </div>
          <div class="px-6 py-6">
            <dl class="space-y-4">
              <div>
                <dt class="text-sm font-medium text-gray-500">Monthly Data Limit</dt>
                <dd class="mt-1 text-sm text-gray-900">
                  <%= @organization.monthly_data_limit == Float::INFINITY ? "Unlimited" : number_with_delimiter(@organization.monthly_data_limit) %> records
                </dd>
              </div>
              <div>
                <dt class="text-sm font-medium text-gray-500">API Requests</dt>
                <dd class="mt-1 text-sm text-gray-900">
                  <%= @organization.monthly_api_requests_limit == Float::INFINITY ? "Unlimited" : number_with_delimiter(@organization.monthly_api_requests_limit) %> / month
                </dd>
              </div>
            </dl>
          </div>
        </div>

        <!-- Quick Actions Card -->
        <div class="bg-white shadow-sm ring-1 ring-gray-900/5 rounded-xl">
          <div class="px-6 py-4 border-b border-gray-200">
            <h3 class="text-base font-semibold leading-6 text-gray-900">Quick Actions</h3>
          </div>
          <div class="px-6 py-6">
            <div class="space-y-3">
              <%= link_to usage_stats_organization_path, class: "flex items-center gap-3 p-3 text-sm text-gray-700 hover:text-indigo-600 hover:bg-gray-50 rounded-lg transition-colors" do %>
                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z" />
                </svg>
                Usage Statistics
              <% end %>
              
              <%= link_to billing_organization_path, class: "flex items-center gap-3 p-3 text-sm text-gray-700 hover:text-indigo-600 hover:bg-gray-50 rounded-lg transition-colors" do %>
                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 8.25h19.5M2.25 9h19.5m-16.5 5.25h6m-6 2.25h3m-3.75 3h15a2.25 2.25 0 002.25-2.25V6.75A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25v10.5A2.25 2.25 0 004.5 19.5z" />
                </svg>
                Billing & Invoices
              <% end %>
              
              <%= link_to audit_logs_organization_path, class: "flex items-center gap-3 p-3 text-sm text-gray-700 hover:text-indigo-600 hover:bg-gray-50 rounded-lg transition-colors" do %>
                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 002.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 00-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 00.75-.75 2.25 2.25 0 00-.1-.664m-5.8 0A2.251 2.251 0 0113.5 2.25H15c1.012 0 1.867.668 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25zM6.75 12h.008v.008H6.75V12zm0 3h.008v.008H6.75V15zm0 3h.008v.008H6.75V18z" />
                </svg>
                Audit Logs
              <% end %>
              
              <%= link_to users_path, class: "flex items-center gap-3 p-3 text-sm text-gray-700 hover:text-indigo-600 hover:bg-gray-50 rounded-lg transition-colors" do %>
                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z" />
                </svg>
                Manage Team
              <% end %>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Data Sources Section -->
    <div class="mt-8">
      <div class="bg-white shadow-sm ring-1 ring-gray-900/5 rounded-xl">
        <div class="px-6 py-4 border-b border-gray-200 flex items-center justify-between">
          <h3 class="text-base font-semibold leading-6 text-gray-900">Connected Data Sources</h3>
          <%= link_to data_sources_path, class: "text-sm font-medium text-indigo-600 hover:text-indigo-500" do %>
            View all →
          <% end %>
        </div>
        <div class="px-6 py-6">
          <% if @data_sources.any? %>
            <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
              <% @data_sources.limit(6).each do |data_source| %>
                <div class="flex items-center gap-4 p-4 border border-gray-200 rounded-lg">
                  <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-indigo-600">
                    <span class="text-sm font-bold text-white">
                      <%= data_source.source_type.first.upcase %>
                    </span>
                  </div>
                  <div class="flex-1 min-w-0">
                    <p class="text-sm font-medium text-gray-900 truncate">
                      <%= data_source.name %>
                    </p>
                    <p class="text-sm text-gray-500">
                      <%= data_source.source_type.humanize %>
                    </p>
                  </div>
                  <div class="h-2 w-2 bg-<%= data_source.connected? ? 'green' : 'gray' %>-500 rounded-full"></div>
                </div>
              <% end %>
            </div>
          <% else %>
            <div class="text-center py-8">
              <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M20.25 6.375c0 2.278-3.694 4.125-8.25 4.125S3.75 8.653 3.75 6.375m16.5 0c0-2.278-3.694-4.125-8.25-4.125S3.75 4.097 3.75 6.375m16.5 0v11.25c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125V6.375m16.5 0v3.75m-16.5-3.75v3.75m16.5 0v3.75C20.25 18.653 16.556 20.5 12 20.5s-8.25-1.847-8.25-4.125v-3.75m16.5 0c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125" />
              </svg>
              <h3 class="mt-2 text-sm font-semibold text-gray-900">No data sources</h3>
              <p class="mt-1 text-sm text-gray-500">Get started by connecting your first data source.</p>
              <div class="mt-6">
                <%= link_to data_sources_path, class: "inline-flex items-center rounded-md bg-indigo-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600" do %>
                  <svg class="-ml-0.5 mr-1.5 h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
                    <path d="M10.75 4.75a.75.75 0 00-1.5 0v4.5h-4.5a.75.75 0 000 1.5h4.5v4.5a.75.75 0 001.5 0v-4.5h4.5a.75.75 0 000-1.5h-4.5v-4.5z" />
                  </svg>
                  Add Data Source
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>