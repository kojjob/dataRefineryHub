<!DOCTYPE html>
<html lang="en" class="h-full bg-gray-50">
  <head>
    <title><%= content_for(:title) || "DataReflow Platform" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="description" content="Transform your business data into actionable insights with our enterprise-grade data refinery platform.">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    
    <!-- Tailwind CSS -->
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "enhanced_flash_messages", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "dataflow_theme", "data-turbo-track": "reload" %>
    
    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    
    <!-- Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/heroicons@2.0.18/24/outline/style.css">
    
    <%= javascript_importmap_tags %>
    
    <style>
      body { font-family: 'Inter', sans-serif; }
    </style>
  </head>

  <body class="h-full bg-gray-50" data-controller="application">
    <!-- Enhanced Flash Messages Container -->
    <div id="flash-messages-container"></div>
    
    <% if user_signed_in? %>
      <!-- Dashboard Layout -->
      <div class="min-h-full" data-controller="mobile-menu">
        
        <!-- Mobile menu overlay -->
        <div class="relative z-50 lg:hidden hidden" data-mobile-menu-target="overlay" data-action="click->mobile-menu#closeOnOverlay">
          <div class="fixed inset-0 bg-gray-900/80 opacity-0 transition-opacity duration-300"></div>
          
          <!-- Mobile menu sidebar -->
          <div class="fixed inset-y-0 left-0 z-50 w-full max-w-xs bg-white transform -translate-x-full transition-transform duration-300" data-mobile-menu-target="sidebar">
            <div class="flex grow flex-col gap-y-5 overflow-y-auto bg-white border-r border-gray-200 px-6 pb-4">
              <!-- Mobile Logo -->
              <div class="flex h-16 shrink-0 items-center">
                <%= link_to dashboard_path, class: "flex items-center space-x-3" do %>
                  <div class="flex h-10 w-10 items-center justify-center rounded-2xl bg-gradient-to-r from-purple-600 to-blue-600 shadow-lg">
                    <svg class="h-6 w-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
                    </svg>
                  </div>
                  <span class="text-xl font-bold text-gray-900">DataReflow</span>
                <% end %>
              </div>
              
              <!-- Mobile Navigation (same as desktop but condensed) -->
              <nav class="flex flex-1 flex-col">
                <ul role="list" class="flex flex-1 flex-col gap-y-7">
                  <li>
                    <ul role="list" class="-mx-2 space-y-1">
                      <li>
                        <%= link_to dashboard_path, class: nav_link_classes('dashboard'), "data-action": "click->mobile-menu#close" do %>
                          <svg class="h-6 w-6 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25" />
                          </svg>
                          Dashboard
                        <% end %>
                      </li>
                      <li>
                        <%= link_to '#', class: nav_link_classes('data_sources'), "data-action": "click->mobile-menu#close" do %>
                          <svg class="h-6 w-6 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M20.25 6.375c0 2.278-3.694 4.125-8.25 4.125S3.75 8.653 3.75 6.375m16.5 0c0-2.278-3.694-4.125-8.25-4.125S3.75 4.097 3.75 6.375m16.5 0v11.25c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125V6.375m16.5 0v3.75m-16.5-3.75v3.75m16.5 0v3.75C20.25 18.653 16.556 20.5 12 20.5s-8.25-1.847-8.25-4.125v-3.75m16.5 0c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125" />
                          </svg>
                          Data Sources
                        <% end %>
                      </li>
                    </ul>
                  </li>
                </ul>
              </nav>
            </div>
          </div>
        </div>
        
        <!-- Desktop Sidebar -->
        <%= render 'shared/navigation' %>
        
        <!-- Main Content Area -->
        <div class="lg:pl-20 xl:pl-72">
          <!-- Top Navigation -->
          <%= render 'shared/enhanced_navbar' %>
          
          <!-- Main Content -->
          <main class="py-10">
            <div class="px-4 sm:px-6 lg:px-8">
              <!-- Flash Messages -->
              <%= render 'shared/flash_messages' %>
              
              <!-- Page Content -->
              <%= yield %>
            </div>
          </main>
          
          <!-- Footer -->
          <%= render 'shared/footer' %>
        </div>
      </div>
    <% else %>
      <!-- Landing/Authentication Layout -->
      <div class="min-h-full bg-gradient-to-br from-purple-900 via-blue-900 to-indigo-900">
        <!-- Landing Navigation -->
        <%= render 'shared/landing_navbar' %>
        
        <!-- Flash Messages -->
        <div class="relative z-40">
          <%= render 'shared/flash_messages' %>
        </div>
        
        <!-- Page Content -->
        <%= yield %>
        
        <!-- Landing Footer -->
        <%= render 'shared/landing_footer' %>
      </div>
    <% end %>
  </body>
</html>