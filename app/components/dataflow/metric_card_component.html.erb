<div class="metric-card">
  <div class="metric-icon"><%= icon %></div>
  <div class="metric-content">
    <h3><%= title %></h3>
    <p class="metric-value"><%= value %></p>
    <% if change.present? %>
      <span class="metric-change <%= change_class %>"><%= change %></span>
    <% end %>
  </div>
</div>